        <mxCell id="t8CTZzge2s8uQhyUlLNi-7" value="&lt;div align=&quot;right&quot;&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;&lt;b&gt;Exemple d&#39;utilisation d&#39;un type de document (rico:DocumentaryFormType), &lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;/div&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;&lt;b&gt;ici défini comme étant également un concept SKOS&lt;br&gt;dans le référentiel des types de documents des Archives nationales&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
