        <mxCell id="GWeJxX-FnaOWpWteAYzn-3" value="&lt;div align=&quot;right&quot;&gt;&lt;b&gt;&lt;font color=&quot;#6C8EBF&quot;&gt;Le préfixe rico: indique que le composant (classe ou propriété) n&#39;existe que dans RiC-O.&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div align=&quot;right&quot;&gt;&lt;b&gt;&lt;font color=&quot;#6C8EBF&quot;&gt;Lorsqu&#39;il n&#39;y a pas de préfixe, le composant existe dans RiC-CM et dans RiC-O.&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
