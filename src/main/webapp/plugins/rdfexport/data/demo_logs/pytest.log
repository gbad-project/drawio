[1m[31mE           (rdflib.term.URIRef('ontology://generated-from-draw-io/mock#Notes%3A%20Some%20Items%20Contain%20Mrs.%20Simcoe%27s%20Original%20Captions%20And%20Dates.%20Others%2C%20Initialed%20%22C.S.%22%2C%20May%20Have%20Been%20Captioned%20By%20Her%20Daughter%20Charlotte.%20In%20A%20Few%20Cases%2C%20Writing%20On%20The%20Back%20Of%20An%20Item%20May%20Have%20Been%20Done%20By%20Members%20Of%20The%20Coles%20Family%20Or%20Archivists.%20Other%20Supplied%20Caption%20And%20Date%20Information%20Was%20Taken%20From%20John%20Ross%20Robertson%27s%201911%20Publication%20The%20Diary%20Of%20Mrs.%20Simcoe.%20The%20Original%20Of%20This%20Diary%20Is%20Contained%20In%20Series%20F%2047-8.%20The%20%22Old%20Code%22%20Reference%20In%20The%20Listings%20Provides%20Cross-references%20To%20Earlier%20Control%20Numbers%20Used%20In%20The%201956%20Archives%20Of%20Ontario%20Finding%20Aid%20To%20The%20Sketches.%20Some%20Item%20Reference%20Codes%20Appear%20Out%20Of%20Sequence%20In%20The%20Listing.%20These%20Represent%20Previously%20Unnumbered%20Sketches%20Found%20On%20The%20Verso%20Of%20Sketches%20Containing%20Old%20Code%20Numbers.%20The%20Titles%20Of%20All%20These%20Items%20Have%20Been%20Supplied.'), rdflib.term.URIRef('http://www.w3.org/2000/01/rdf-schema#label'), rdflib.term.Literal('Notes:\xa0Some items contain Mrs. Simcoe\'s original captions and dates. Others, initialed "C.S.", may have been captioned by her daughter Charlotte.\xa0 In a few cases, writing on the back of an item may have been done by members of the Coles family or archivists. Other supplied caption and date information was taken from John Ross Robertson\'s 1911 publication The Diary of Mrs. Simcoe. The original of this diary is contained in series F 47-8. The "Old Code" reference in the listings provides cross-references to earlier control numbers used in the 1956 Archives of Ontario finding aid to the sketches. Some item reference codes appear out of sequence in the listing. These represent previously unnumbered sketches found on the verso of sketches containing old code numbers. The titles of all these items have been supplied.'))[0m
