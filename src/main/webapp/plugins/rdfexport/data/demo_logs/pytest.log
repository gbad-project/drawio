[1m[31mE           (rdflib.term.URIRef('ontology://generated-from-draw-io/mock#Associated%20Material%3A%20Library%20And%20Archives%20Canada%20Holds%20A%20Large%20Series%20Of%20Transcriptions%20From%20The%20Simcoe%20Family%20Records.%20See%20The%20Correspondence%20Of%20Eliza%20Simcoe%20And%20The%20Coles%20Family%20For%20Details%20On%20These%20Copying%20Projects.%20The%20Originals%20From%20Which%20These%20Transcriptions%20Were%20Made%20Are%20Largely%20Contained%20In%20This%20Fonds.'), rdflib.term.URIRef('http://www.w3.org/2000/01/rdf-schema#label'), rdflib.term.Literal('Associated Material:\xa0Library and Archives Canada holds a large series of transcriptions from the Simcoe family records. See the correspondence of Eliza Simcoe and the Coles family for details on these copying projects. The originals from which these transcriptions were made are largely contained in this fonds.'))[0m
