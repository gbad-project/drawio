[1m[31mE           (rdflib.term.URIRef('ontology://generated-from-draw-io/mock#Associated%20Material%3A%20The%20Clements%20Library%20Of%20The%20University%20Of%20Michigan%20In%20Ann%20Arbor%2C%20Michigan%2C%20Holds%20A%20Collection%20Of%20Correspondence%20From%20John%20Graves%20And%20Elizabeth%20Simcoe%20Dating%20From%20The%201770s%20Through%201810.%20The%20Archives%20Of%20Ontario%20Possesses%20A%20Microfilm%20Copy%20Of%20This%20Collection.'), rdflib.term.URIRef('http://www.w3.org/2000/01/rdf-schema#label'), rdflib.term.Literal('Associated Material:\xa0The Clements Library of the University of Michigan in Ann Arbor, Michigan, holds a collection of correspondence from John Graves and Elizabeth Simcoe dating from the 1770s through 1810. The Archives of Ontario possesses a microfilm copy of this collection.'))[0m
