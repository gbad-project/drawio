[1m[31mE           (rdflib.term.URIRef('ontology://generated-from-draw-io/mock#Simcoe%20Family%20Fonds'), rdflib.term.URIRef('https://www.ica.org/standards/RiC/ontology#generalDescription'), rdflib.term.Literal('Associated Material:\xa0Library and Archives Canada holds a large series of transcriptions from the Simcoe family records. See the correspondence of Eliza Simcoe and the Coles family for details on these copying projects. The originals from which these transcriptions were made are largely contained in this fonds.'))[0m
[1m[31mE           (rdflib.term.URIRef('ontology://generated-from-draw-io/mock#Simcoe%20Family%20Fonds'), rdflib.term.URIRef('https://www.ica.org/standards/RiC/ontology#generalDescription'), rdflib.term.Literal('Associated Material:\xa0The Clements Library of the University of Michigan in Ann Arbor, Michigan, holds a collection of correspondence from John Graves and Elizabeth Simcoe dating from the 1770s through 1810. The Archives of Ontario possesses a microfilm copy of this collection.'))[0m
[1m[31mE           (rdflib.term.URIRef('ontology://generated-from-draw-io/mock#Simcoe%20Family%20Fonds'), rdflib.term.URIRef('https://www.ica.org/standards/RiC/ontology#generalDescription'), rdflib.term.Literal('Availability of Other Formats:\xa0Refer to series and sub-series descriptions for information on the availability of other formats.'))[0m
