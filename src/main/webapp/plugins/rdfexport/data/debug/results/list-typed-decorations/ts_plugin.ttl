@base <ontology://generated-from-draw-io/mock> .
@prefix : <ontology://generated-from-draw-io/mock#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

rdf:type a owl:DatatypeProperty,
        owl:ObjectProperty .

rdfs:seeAlso a owl:DatatypeProperty .

<mock://debug-ontology> a owl:Ontology ;
    owl:imports rico: ;
    skos:note ( "UnconnectedLiteralizedList" ":Item1" ":Item2" ":Item3" ),
        "Literal",
        "some other literal" .

:IndividualList a owl:NamedIndividual,
        :Item1,
        :Item2,
        :Item3,
        :hi,
        "Just a literal" ;
    rdfs:label "IndividualList" ;
    rdfs:seeAlso "ConnectedLiteralizedList" .

:hello a owl:NamedIndividual ;
    rdfs:label "hello" .

:hello2 a owl:NamedIndividual ;
    rdfs:label "hello2" .

:hello3 a owl:NamedIndividual ;
    rdfs:label "hello3" .

:some a owl:NamedIndividual ;
    rdfs:label "some" .

:hi a owl:NamedIndividual ;
    rdfs:label "hi" .

