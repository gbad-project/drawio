[] a rr:TriplesMap ;
    rml:logicalSource [ rml:referenceFormulation ql:CSV ;
            rml:source "gbad/mapping/source/preprocessed/General Authority to RiC-O Model_2025-06-25_PZ.csv" ] ;
    rr:predicateObjectMap [ rr:objectMap [ rr:template "/KB/Date/{DATECONT_BEGINNING}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasBeginningDate ],
        [ rr:objectMap [ rr:template "{CONTAG} - {HEADING} (Agent Control Relation). Context: <urn:uuid:{UUID}>" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rdfs:label ],
        [ rr:objectMap [ rr:constant owl:NamedIndividual ;
                    rr:termType rr:IRI ] ;
            rr:predicate rdf:type ],
        [ rr:objectMap [ rr:template "/KB/Date/{DATECONT_END}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasEndDate ],
        [ rr:objectMap [ rr:template "/KB/{RICO_AUTHTP_TERM}/{HEADING}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:relationHasTarget ],
        [ rr:objectMap [ rr:constant rico:AgentControlRelation ;
                    rr:termType rr:IRI ] ;
            rr:predicate rdf:type ] ;
    rr:subjectMap [ rr:template "/KB/AgentControlRelation/{CONTAG}/{HEADING}/urn:uuid:{UUID}" ;
            rr:termType rr:IRI ] .

