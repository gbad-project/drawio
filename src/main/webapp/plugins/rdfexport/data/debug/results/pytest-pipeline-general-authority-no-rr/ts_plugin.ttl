[] a rr:TriplesMap ;
    rml:logicalSource [ rml:referenceFormulation ql:CSV ;
            rml:source "gbad/mapping/source/preprocessed/General Authority to RiC-O Model_2025-06-25_PZ.csv" ] ;
    rr:predicateObjectMap [ rr:objectMap [ rr:template "/KB/AuthorityRecord/{HEADING}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:isOrWasDescribedBy ],
        [ rr:objectMap [ rr:template "/KB/Agent/{PRED}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:isSuccessorOf ],
        [ rr:objectMap [ rr:template "/KB/VariantAgentName/{VAR}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasOrHadAgentName ],
        [ rr:objectMap [ rr:template "{RICO_AUTHTP_CLASS}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rdf:type ],
        [ rr:objectMap [ rr:template "{CMTAU}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate auth:privateNote ],
        [ rr:objectMap [ rr:template "/KB/NaturalAgentName/{NAME}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasOrHadAgentName ],
        [ rr:objectMap [ rr:template "/KB/Agent/{SUC}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasSuccessor ],
        [ rr:objectMap [ rr:template "/KB/Mandate/{AA}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:authorizedBy ],
        [ rr:objectMap [ rr:template "/KB/Agent/{REFA}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:isEquivalentTo ],
        [ rr:objectMap [ rr:template "/KB/Agent/{CONTAG}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasOrHadController ],
        [ rr:objectMap [ rr:template "/KB/AgencyReferenceCode/{REFA}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasOrHadIdentifier ],
        [ rr:objectMap [ rr:constant "" ;
                    rr:termType rr:Literal ] ;
            rr:predicate rdfs:label ],
        [ rr:objectMap [ rr:constant owl:NamedIndividual ;
                    rr:termType rr:IRI ] ;
            rr:predicate rdf:type ],
        [ rr:objectMap [ rr:template "/KB/ParallelAgentName/{PAR}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasOrHadAgentName ],
        [ rr:objectMap [ rr:template "/KB/Date/{DATEEX_BEGINNING}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasBeginningDate ],
        [ rr:objectMap [ rr:template "/KB/Date/{DATEEX_END}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasEndDate ],
        [ rr:objectMap [ rr:template "{FUN}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate auth:functionNote ],
        [ rr:objectMap [ rr:template "{ADM}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:history ] ;
    rr:subjectMap [ rr:template "/KB/{RICO_AUTHTP_TERM}/{HEADING}" ;
            rr:termType rr:IRI ] .

