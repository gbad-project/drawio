@base <ontology://generated-from-draw-io/mock> .
@prefix : <ontology://generated-from-draw-io/mock#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .

rdf:type a owl:ObjectProperty .

rdfs:seeAlso a owl:ObjectProperty .

<mock://pytest-debug-ontology> a owl:Ontology ;
    owl:imports rico: .

:IndividualList a owl:NamedIndividual,
        :Item1,
        :Item2,
        :Item3,
        :Just%20A%20Literal,
        :hi ;
    rdfs:label "IndividualList" ;
    rdfs:seeAlso :ConnectedLiteralizedList .

:Literal a owl:NamedIndividual ;
    rdfs:label "Literal" .

:Some%20Other%20Literal a owl:NamedIndividual ;
    rdfs:label "some other literal" .

:UnconnectedLiteralizedList a owl:NamedIndividual,
        :Item1,
        :Item2,
        :Item3 ;
    rdfs:label "UnconnectedLiteralizedList" .

:hello a owl:NamedIndividual ;
    rdfs:label "hello" .

:hello2 a owl:NamedIndividual ;
    rdfs:label "hello2" .

:hello3 a owl:NamedIndividual ;
    rdfs:label "hello3" .

:some a owl:NamedIndividual ;
    rdfs:label "some" .

:ConnectedLiteralizedList a owl:NamedIndividual,
        :Item1,
        :Item2,
        :Item3 ;
    rdfs:label "ConnectedLiteralizedList" .

:Just%20A%20Literal a owl:NamedIndividual ;
    rdfs:label "Just a literal" .

:hi a owl:NamedIndividual ;
    rdfs:label "hi" .

