    rr:predicateObjectMap [ rr:objectMap [ rr:parentTriplesMap :rr_template___KB_Date__DATEOFF_10_BEGINNING__ ] ;
            rr:predicate rico:hasBeginningDate ],
        [ rr:objectMap [ rr:parentTriplesMap :rr_template___KB_Agent__ABC_REFA_10__ ] ;
            rr:predicate rico:relationHasTarget ],
