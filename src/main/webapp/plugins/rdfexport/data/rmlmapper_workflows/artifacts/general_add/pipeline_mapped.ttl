  add:findingAidNote <https://data.archives.gov.on.test.gbad.caAn%20online%20listing%20is%20available%20for%20this%20series.>;
  add:relatedMaterial <https://data.archives.gov.on.test.gbad.caRelated%20photographs%20may%20be%20found%20in%20F%204531-30%3A%20Fred%20W.%20Hotson%27s%20collection%20of%20miscellaneous%20de%20Havilland%20Canada%20aircraft%20photographs.>;
