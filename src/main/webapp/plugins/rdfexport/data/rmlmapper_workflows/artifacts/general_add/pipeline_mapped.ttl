  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/CurrentReferenceCode/F%201410-41>,
    <https://data.archives.gov.on.test.gbad.ca/KB/FormerCode/Accession%20numbers%3A%2015615%3B%2016263%3B%2016304%3B%2022740>;
  rico:hasOrHadInstantiation </KB/Instantiation/F%201410-41/urn:uuid:3f61fc77-7011-56c6-b0e0-a7c9f543b16e>;
  rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/KB/Title/Ukrainian%20National%20Federation%20%28National%20Executive%29%20records%20on%20Ukrainian%20Women%27s%20Organization%20central%20executive>;
  rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/Level#Series>;
  rico:isDirectlyIncludedIn <https://data.archives.gov.on.test.gbad.ca/KB/RecordSet/F%201410>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/F%201410-41>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20of%20National%20Executive%20records%20pertaining%20to%20the%20central%20executive%20of%20the%20Ukrainian%20Women%27s%20Organziation%20%28OUK%29.%20The%20Ukrainian%20Women%27s%20Organization%27s%20beginnings%20are%20closely%20tied%20to%20the%20beginnings%20of%20the%20UNF.%20Women%27s%20branches%20of%20the%20Ukrainian%20War%20Veterans%27%20Association%20known%20as%20the%20Olga%20Basarab%20Women%27s%20Associations%20passed%20resolutions%20at%20the%20first%20national%20conference%20of%20the%20UNF%20in%201934%20resulting%20in%20the%20formation%20of%20the%20Ukrainian%20Women%27s%20Organization.%20%20%20The%20Ukrainian%20Women%27s%20Organization%20focussed%20on%20cultural%20and%20organization%20work.%20The%20OUK%20worked%20with%20the%20Canadian%20Red%20Cross%20and%20the%20Ukrainian%20Golden%20Cross%20during%20World%20War%20II.%20In%20the%20post-War%20period%2C%20the%20OUK%20helped%20organize%20youth%20sections%20and%20provided%20aid%20to%20new%20immigrants%20and%20refugees.%20%20The%20OUK%20formed%20an%20integral%20part%20of%20the%20Ukrainian%20National%20Federation%20and%20the%20Ukrainian%20War%20Veterans%20Association%20providing%20assistance%20at%20executive%20and%20branch%20levels%20for%20many%20types%20of%20activities.> .

