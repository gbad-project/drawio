  add:findingAidNote <https://data.archives.gov.on.test.gbad.caTwo%20creator-generated%20indexes%2C%20current%20to%201983%2C%20exist%20for%20this%20series.%20%20the%20first%2C%20found%20in%20Appendix%204%20of%20Inventory%20C%208%2C%20records%20the%20contents%20of%20each%20album%20by%20the%20owner%20of%20the%20vessel%20pictured.%20The%20album%20number%20and%20the%20relevant%20page%20numbers%20in%20the%20albums%20are%20provided.%20The%20second%20creator-generated%20index%2C%20found%20in%20Appendix%205%20of%20Inventory%20C%208%2C%20is%20arranged%20alphabetically%20by%20the%20name%20of%20the%20vessel%20%28sometimes%20listing%20a%20former%20or%20subsequent%20name%20for%20the%20vessel%20and%20the%20location%20of%20the%20photograph%29.>;
  add:notes <https://data.archives.gov.on.test.gbad.caTitle%20based%20on%20contents%20of%20the%20series.>;
  rico:conditionsOfAccess <https://data.archives.gov.on.test.gbad.caNo%20restrictions%20on%20access.>;
  rico:conditionsOfUse <https://data.archives.gov.on.test.gbad.caRecords%20are%20in%20the%20public%20domain.%20There%20are%20no%20restrictions%20on%20reproduction%2C%20howerver%20permission%20of%20the%20Archives%20of%20Ontario%20is%20required%20for%20publication%3B%20submit%20a%20Request%20for%20Permission%20to%20Publish%2C%20Exhibit%20or%20Broadcast%20Form.>;
