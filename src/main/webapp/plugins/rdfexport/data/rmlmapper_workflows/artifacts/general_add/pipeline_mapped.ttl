  rico:hasOrHadInstantiation </KB/Instantiation/F%20604/urn:uuid:3f61fc77-7011-56c6-b0e0-a7c9f543b16e>;
  rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/KB/Title/Charles%20Shirreff%20family%20fonds>;
  rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/Level#Fonds>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/F%20604>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caFonds%20consists%20of%20personal%20and%20professional%20records%20of%20Charles%20Shirreff%20and%20other%20Shirreff%20family%20members.%20Included%20are%20correspondence%2C%20land%20records%2C%20genealogical%20information%20and%20biographical%20information%20regarding%20the%20Shirreff%20family%2C%20notices%20of%20appointments%2C%20diaries%2C%20and%20other%20records.%20%20Correspondence%20includes%3A%20letters%20received%20by%20Charles%20Sherriff%20before%20his%20emigration%20from%20Scotland%3B%20letters%20regarding%20Colonel%20John%20By%3B%20letters%20detailing%20Alexander%20Shirreff%EF%BF%BDs%20expenses%20while%20exploring%20the%20land%20between%20the%20Ottawa%20River%20and%20Lake%20Huron%3B%20letters%20regarding%20the%20purchase%20of%20land%20and%20the%20purchase%20of%20the%20Bytown%20Gazette%3B%20and%20letters%20regarding%20the%20Shirreff%20family%EF%BF%BDs%20claim%20to%20the%20earldom%20of%20Stirling.%20%20Land%20records%20consist%20of%3A%20land%20grants%3B%20a%20Scottish%20property%20transfer%3B%20a%20rent%20roll%20of%20Fitzroy%20Harbour%20lots%3B%20a%20statement%20of%20property%20at%20Fitzroy%20Harbour%3B%20maps%20of%20the%20land%20by%20the%20Carp%20River%20and%20part%20of%20Fitzroy%20Township%3B%20and%20a%20plan%20of%20the%20Fitzroy%20Harbour.%20%20Genealogical%20and%20biographical%20material%20includes%20newspaper%20clippings%2C%20manuscript%20histories%20of%20the%20family%2C%20and%20a%20history%20of%20St.%20Andrew%EF%BF%BDs%20Presbyterian%20Church%20at%20Fitzroy%20Harbour.%20%20Fonds%20also%20includes%20notices%20of%20Charles%20Shirreff%EF%BF%BDs%20appointment%20as%20a%20Justice%20of%20the%20Peace%20for%20the%20Ottawa%20and%20Bathurst%20Districts%2C%20and%20of%20his%20temporary%20appointment%20as%20a%20local%20agent%20of%20the%20Canada%20Company.%20%20Diaries%20contain%20entries%20relating%20to%3A%20Ottawa%20River%20improvements%2C%20Lake%20Nipissing%20exploration%2C%20Gatineau%20timber%2C%20and%20proposed%20settlements%20in%20the%20Ottawa%20District%20and%20at%20Lake%20Nipissing.%20%20Fonds%20also%20includes%3A%20notices%20regarding%20timber%20duties%20and%20the%20construction%20of%20roads%3B%20printed%20copies%20of%20Charles%20Shirreff%EF%BF%BDs%20letter%20to%20the%20Bytown%20Gazette%20entitled%20%22Arguments%20for%20Bytown%20being%20made%20the%20Seat%20of%20the%20Government%20in%20Canada%22%3B%20wills%20and%20a%20marriage%20contract%3B%20tax%20bills%2C%20contracts%2C%20and%20property%20valuations%20of%20property%20belonging%20to%20Charles%20Shirreff%20and%20Company%2C%20Leith%3B%20and%20photographs%20of%20sites%20around%20Fitzroy%20Harbour.%20%20Fonds%20contains%20the%20following%20series%3A%20General%20Correspondence%2C%201723-1893%2C%20N.D.%20%28Series%20A%29%3B%20Land%20Records%2C%201694-%201958%20%28Series%20B%29%3B%20Genealogy%20%28Series%20C%29%3B%20Appointments%2C%201835%2C%20N.D.%20%28Series%20D%29%3B%20Diaries%2C%201831%2C%20N.D.%20%28Series%20E%29%3B%20Memoranda%20%28Series%20F%29%3B%20Ottawa-Bytown%2C%201842%2C%20N.D.%20%28Series%20G%29%3B%20Biographical%20%28Series%20H%29%3B%20Wills%20And%20Marriage%20Contract%2C%201702%2C%201853%2C%201881%20%28Series%20I%29%3B%20Scottish%20Miscellaneous%20%28Series%20J%29> .

