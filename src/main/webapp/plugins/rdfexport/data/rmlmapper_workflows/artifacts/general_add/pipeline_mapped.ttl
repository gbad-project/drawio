  rico:conditionsOfUse <https://data.archives.gov.on.test.gbad.caCopyright%20is%20held%20by%20the%20Canadian%20Broadcasting%20Corporation.%20%20Permission%20of%20the%20CBC%20is%20required%20for%20reproduction%2C%20publication%2C%20broadcast%2C%20exhibit%20or%20other%20uses.>;
  rico:creationDate <https://data.archives.gov.on.test.gbad.ca%5B1964%3F-1967%3F%5D>;
  rico:hasContentOfType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/ContentType#Moving%20images>;
