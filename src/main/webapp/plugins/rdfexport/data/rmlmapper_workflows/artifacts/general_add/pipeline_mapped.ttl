  rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/KB/Title/CBC%20television%20productions%20in%20cooperation%20with%20the%20Ontario%20Department%20of%20Agriculture%20and%20Food>;
  rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/Level#Series>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/RG%2016-307>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20of%20kinescopes%20of%20television%20programs%20produced%20and%20directed%20by%20Rena%20Elmer%20of%20the%20Canadian%20Broadcasting%20Corporation%20%28CBC%29%20in%20cooperation%20with%20the%20Ontario%20Department%20of%20Agriculture%20and%20Food.%20%20The%20programs%20appear%20to%20have%20been%20produced%20under%20two%20program%20series%20titles%3A%20%20%22Let%27s%20look%20at%20farming%20%22%20%281964%3F%29%20and%20%22This%20business%20of%20farming%20%22%20%281965-1967%3F%29.%20%20Divided%20into%20two%2030%20minute%20segments%2C%20the%20programs%20dealt%20with%20various%20aspects%20of%20managing%20a%20modern%20farm.%20%20The%20films%20in%20this%20series%20have%20been%20arranged%20in%20chronological%20order.> .

