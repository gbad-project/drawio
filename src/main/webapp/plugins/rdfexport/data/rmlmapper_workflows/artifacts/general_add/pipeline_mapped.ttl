  add:findingAidNote <https://data.archives.gov.on.test.gbad.caNo%20finding%20aid%20is%20available%20for%20this%20sub-series.>;
  add:notes <https://data.archives.gov.on.test.gbad.caIsaak%20%28Alexander%29%20Shterenberg%20was%20born%20on%20March%2025%2C%201949%20in%20Odessa%2C%20Ukrainian%20S.S.R.%20He%20was%20a%20musician%20and%20a%20chess-player.%20%20Nava%20Shterenberg%20%28nee%20Gordon%29%20was%20born%20in%20Riga%20on%20April%204%2C%201949.%20She%20lived%20in%20Kishinev%20%28Moldavia%29.%20Nava%20was%20an%20internationally%20known%20chess%20player%20and%20the%20best%20female%20chess%20player%20in%20Moldavia%20every%20year%20from%201966%20to%201968.%20She%20was%20the%20second%20best%20chess%20player%20in%20all%20Ukraine%20in%201971.%20Nava%20emigrated%20to%20Israel%20in%201972%20and%20then%20to%20Canada%20on%20October%2028th%2C%201975.%20In%201977%2C%20Nava%20Shterenberg%20became%20the%20top%20Canadian%20woman%20chess%20champion.>;
  rico:conditionsOfAccess <https://data.archives.gov.on.test.gbad.caNo%20restrictions%20on%20access.>;
  rico:conditionsOfUse <https://data.archives.gov.on.test.gbad.caCopyright%20held%20by%20creator.%20There%20are%20no%20restrictions%20on%20reporduction%20for%20research%20and%20private%20study.%20These%20materials%20cannot%20be%20published%20without%20the%20permission%20of%20the%20creator.%20If%20you%20wish%20to%20use%20other%20than%20for%20research%20and%20private%20study%20any%20of%20this%20material%2C%20submit%20a%20Request%20for%20Permission%20to%20Publish%2C%20Exhibit%20or%20Broadcast%20Form.>;
