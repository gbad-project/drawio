  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20of%20three%20albums%2C%20numbered%2091%20to%2093%2C%20which%20contain%20photoprints%20showing%20tugs%2C%20barges%20%28those%20which%20were%20not%20self-propelled%20or%20commercial%20cargo%29%2C%20lighters%2C%20wreckers%2C%20government%20vessels%20and%20other%20miscellaneous%20ships.> .

<https://data.archives.gov.on.test.gbad.ca/KB/RecordSet/F%201028> a owl:NamedIndividual,
    rico:RecordSet;
  add:findingAidNote <https://data.archives.gov.on.test.gbad.caAn%20inventory%20is%20available%20for%20this%20fonds.>;
  add:immediateSourceOfAcquisition <https://data.archives.gov.on.test.gbad.caFonds%20was%20donated%20to%20the%20Archives%20of%20Ontario%20in%201904%20by%20Miss%20Merrill%20of%20Picton%2C%20Ontario.%20Additional%20materials%20were%20donated%20to%20the%20Archives%20in%201961%20by%20Mrs.%20F.C.%20Hood.>;
  add:notes <https://data.archives.gov.on.test.gbad.caTitle%20based%20on%20content%20of%20fonds.>;
  rico:conditionsOfAccess <https://data.archives.gov.on.test.gbad.caNo%20restrictions%20on%20access.>;
  rico:conditionsOfUse <https://data.archives.gov.on.test.gbad.caCopyright%20held%20by%20creator.%20These%20materials%20cannot%20be%20published%20without%20permission%20from%20the%20copyright%20holder.>;
  rico:creationDate <https://data.archives.gov.on.test.gbad.ca1800-1904>;
  rico:hasContentOfType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/ContentType#Textual%20records>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/CurrentReferenceCode/F%201028>,
    <https://data.archives.gov.on.test.gbad.ca/KB/FormerCode/Accession%20Numbers%3A%20497%2C%202982.>;
  rico:hasOrHadInstantiation </KB/Instantiation/F%201028/urn:uuid:3f61fc77-7011-56c6-b0e0-a7c9f543b16e>;
  rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/KB/Title/Samuel%20%26%20Edward%20Merrill%20family%20fonds>;
  rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/Level#Fonds>;
  rico:history <https://data.archives.gov.on.test.gbad.caSamuel%20Merrill%20%28born%20ca.%201800%29%20was%20a%20lawyer%2C%20Registrar%20of%20the%20Surrogate%20Court%2C%20and%20Master-in-Chancery%20in%20Picton.%20His%20son%2C%20Edward%20Merrill%20%28b.%201841%29%20also%20practised%20law%20in%20Picton%2C%20and%20was%20also%20County%20Court%20Judge%20of%20Prince%20Edward.Samuel%20Merrill%20was%20educated%20at%20the%20Kingston%20Grammar%20School%2C%20and%20the%20Law%20Society%20of%20Upper%20Canada%2C%20articling%20with%20the%20Hon.%20C.A.%20Hagerman.%20He%20was%20called%20to%20the%20bar%20in%201823.%20He%20then%20became%20the%20first%20lawyer%20in%20Picton%2C%20the%20first%20Registrar%20of%20the%20Surrogate%20Court%20in%20Picton.%20He%20also%20served%20as%20Master-in-Chancery%20for%20a%20number%20of%20years.His%20son%2C%20Edward%20Merrill%2C%20was%20born%20in%20Picton%2C%20and%20was%20admitted%20as%20a%20student%20to%20the%20Law%20Society%20of%20Upper%20Canada%20in%201858.%20He%20was%20called%20to%20the%20bar%20in%201867%2C%20and%20then%20practised%20law%20with%20his%20father%20in%20Picton.%20In%201890%2C%20he%20was%20appointed%20County%20Court%20Judge%20of%20Prince%20Edward%2C%20a%20position%20he%20held%20until%201904.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/F%201028>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caFonds%20consists%20mainly%20of%20records%20and%20copies%20of%20records%20connected%20with%20Edward%20Merrill%27s%20legal%20practice.%20Included%20is%20correspondence%20relating%20to%20legal%20matters%2C%20and%20also%20includes%20letters%20of%20appointment%20to%20Samuel%20Merrill.%20Legal%20correspondence%20is%20that%20of%20Edward%20Merrill%20regarding%20cases%20tried%20before%20him%2C%20petitions%2C%20the%20and%20position%20of%20County%20Court%20Judges.%20Correspondence%20has%20been%20arranged%20chronologically.%20%20Fonds%20also%20includes%20various%20legal%20records%2C%20including%20affidavits%2C%20agreements%2C%20bonds%2C%20releases%20and%20elections%2C%20wills%20and%20estate%20books%2C%20and%20other%20records.%20Legal%20records%20have%20been%20arranged%20alphabetically.%20%20Also%20included%20are%20miscellaneous%20records%2C%20including%20poll%20books%20for%20elections%20in%201828%20and%201830%2C%20for%20which%20Samuel%20Merrill%20was%20Deputy%20Returning%20Officer.%20Attached%20to%20these%20books%20are%20several%20petitions%20regarding%20the%20contesting%20of%20the%20election%20of%201828.> .

<https://data.archives.gov.on.test.gbad.ca/KB/RecordSet/F%201061> a owl:NamedIndividual,
    rico:RecordSet;
  add:availabilityOfOtherFormats <https://data.archives.gov.on.test.gbad.caPhotocopies%20of%20the%20journals%20are%20available%20in%20container%20MU%204835%20%28barcode%20B286722%29.>;
  add:custodialHistory <https://data.archives.gov.on.test.gbad.caThe%20original%20survey%20journals%20were%20likely%20purchased%20at%20auction%20or%20private%20sale%20by%20Dr.%20George%20and%20Mary%20Armstrong%20before%20the%20mid-1970s.%20Upon%20George%EF%BF%BDs%20death%20in%201981%20%28Mary%20pre-deceased%29%2C%20the%20journals%20were%20inherited%20along%20with%20their%20home%20in%20Merrickville%2C%20Ontario%20by%20George%EF%BF%BDs%20nephew%2C%20Dr.%20Gordon%20W.D.%20Armstrong%20and%20his%20wife%2C%20Mary%20Florence%20%28Molly%29%20Armstrong.%20The%20journals%20were%20loaned%20by%20the%20Armstrong%EF%BF%BDs%20to%20Joan%20F.%20MacKenzie%20of%20Aylmer%2C%20Quebec%20in%20the%201970s%20for%20her%20research%20on%20the%20Opeongo%20Line%2C%20who%20in%20turn%20lent%20them%20to%20the%20Archives%20of%20Ontario%20for%20photocopying%20in%201979%20to%20form%20the%20Hamlet%20Burritt%20fonds%20%28F%201061%29.%20Gordon%20died%20in%202018%2C%20leaving%20his%20estate%20to%20Molly.%20Gordon%20and%20Molly%EF%BF%BDs%20daughter%2C%20Mary%20Jane%20Armstrong%20of%20Ottawa%2C%20Ontario%2C%20inherited%20the%20journals%20from%20her%20mother%EF%BF%BDs%20estate%20following%20her%20death%20in%20January%202021.%20Mary%20Jane%20Armstrong%20donated%20the%20original%20survey%20journals%20to%20the%20Archives%20of%20Ontario%20in%202021%20on%20behalf%20of%20her%20late%20parents.>;
  add:findingAidNote <https://data.archives.gov.on.test.gbad.caAn%20item%20level%20listing%20is%20available%20for%20this%20fonds.>;
  add:notes <https://data.archives.gov.on.test.gbad.caTitle%20supplied%20from%20contents%20of%20fonds.>;
  add:relatedMaterial <https://data.archives.gov.on.test.gbad.caRelated%20records%20may%20be%20found%20in%20RG%201-59%20Crown%20land%20survey%20diaries%2C%20field%20notes%20and%20reports%2C%20including%20those%20of%20Surveyor-General%20Robert%20Bell%3B%20RG%2017-23%20Historical%20plaques%20photographs%2C%20item%20RG%2017-23-0-0-224%20Founding%20of%20Burritt%EF%BF%BDs%20Rapids%3B%20RG%201-445%20Records%20of%20the%20Lake%20Opeongo%20creel%20census%3B%20RG%205-44%20Tourist%20Industry%20Development%20Branch%20records%2C%20File%20178%2C%20Opeongo%20Line%3B%20and%20RG%2052-4%20Colonization%20roads%20additional%20letters%2C%201851-1867.%20%20More%20information%20on%20Hamlet%20Burritt%20and%20the%20journals%2C%20including%20many%20excerpts%20from%20them%2C%20can%20be%20found%20in%20the%20book%20Life%20Along%20the%20Opeongo%20Line%3A%20The%20Story%20of%20a%20Canadian%20Colonization%20Road%20by%20Joan%20Finnigan%2C%20Penumbra%20Press%2C%202004%2C%20which%20is%20available%20in%20the%20Archives%20of%20Ontario%27s%20Library%20with%20call%20number%20971.381%20F56.>;
  rico:accruals <https://data.archives.gov.on.test.gbad.caNo%20further%20accruals%20are%20expected.>;
  rico:conditionsOfAccess <https://data.archives.gov.on.test.gbad.caOriginals%20are%20closed%20for%20conservation.%20Please%20use%20reference%20copies%20in%20MU%204835%20%28barcode%20B286722%29.>;
  rico:conditionsOfUse <https://data.archives.gov.on.test.gbad.caRecords%20are%20in%20the%20public%20domain.%20There%20are%20no%20restrictions%20on%20reproduction%20for%20research%20and%20private%20study.%20If%20you%20wish%20to%20use%20any%20of%20this%20material%2C%20submit%20a%20Request%20for%20Permission%20to%20Publish%2C%20Exhibit%20or%20Broadcast%20Form.>;
  rico:creationDate <https://data.archives.gov.on.test.gbad.ca1851-1852%20%5Bincludes%20photocopies%20from%201979%5D>;
  rico:hasContentOfType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/ContentType#Textual%20records>;
  rico:hasCreator <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Burritt%2C%20Hamlet%2C%201821-1893>,
    <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Burritt%2C%20Hamlett%2C%20fl.%201851>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/CurrentReferenceCode/F%201061>,
    <https://data.archives.gov.on.test.gbad.ca/KB/FormerCode/Accession%2013097%3B%20Lead%20number%202021-012>;
  rico:hasOrHadInstantiation </KB/Instantiation/F%201061/urn:uuid:3f61fc77-7011-56c6-b0e0-a7c9f543b16e>;
  rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/KB/Title/Hamlet%20Burritt%20fonds>;
  rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/Level#Fonds>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/F%201061>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caFonds%20consists%20of%20four%20handwritten%20survey%20journals%20kept%20by%20Hamlet%20Burritt%2C%20a%20land%20surveyor%20who%20surveyed%20the%20route%20for%20the%20Opeongo%20Colonization%20Road%2C%20from%20the%20Ottawa%20River%20to%20Lake%20Opeongo%20from%2010%20April%201851%20to%207%20April%201852.%20The%20journals%20document%20Burritt%EF%BF%BDs%20observations%20on%20camp%20life%2C%20the%20landscape%2C%20daily%20activities%2C%20weather%2C%20working%20conditions%2C%20his%20relationships%20with%20the%20crew%2C%20and%20his%20interactions%20with%20the%20locals.%20%20Three%20of%20the%20four%20journals%20were%20hand-made%20by%20Burritt%20out%20of%20lined%20school%20notebook%20paper%20and%20all%20are%20bound%20together%20with%20thread.%20Journal%203%20consists%20of%20a%20store-bought%20notebook%20with%20a%20red%20and%20blue%20marble%20cover.%20It%20also%20contains%20a%20thin%20piece%20of%20birch%20bark%20with%20some%20notes%20on%20it%20placed%20between%20two%20pages%20and%20a%20bit%20of%20blotting%20paper%20between%20other%20pages.%20%20The%20journals%20have%20been%20arranged%20numerically%20and%20chronologically.> .

