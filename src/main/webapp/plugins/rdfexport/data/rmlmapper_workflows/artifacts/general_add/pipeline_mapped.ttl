  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20of%20records%20created%20and%20maintained%20by%20the%20Ontario%20Status%20of%20Women%20Council%20pertaining%20to%20publications%20produced%20by%20the%20Council.%20Records%20include%20correspondence%2C%20printing%20requisitions%2C%20quotes%2C%20translation%20request%20copies%2C%20agreements%2C%20drafts%20and%20proofs%2C%20original%20sketches%2C%20and%20editors%27%20notes%2C%20as%20well%20as%20final%20copies.%20%20Requests%20for%20publications%20such%20as%20the%20Annual%20Report%2C%20%22About%20Face%22%2C%20and%20%22Status%22%20are%20also%20included.> .

<https://data.archives.gov.on.test.gbad.ca/KB/RecordSet/RG%2080-13> a owl:NamedIndividual,
    rico:RecordSet;
  add:accumulationDate <https://data.archives.gov.on.test.gbad.ca1869-1942>;
  add:availabilityOfOtherFormats <https://data.archives.gov.on.test.gbad.caThis%20series%20is%20available%20on%20microfilm%20%28MS%20940%2C%20Reels%201-30%3B%2035mm%29.>;
  add:findingAidNote <https://data.archives.gov.on.test.gbad.caConsult%20the%20binder%20titled%20Inventory%20of%20the%20Death%20Records%20of%20the%20Office%20of%20the%20Registrar%20General%22%20in%20the%20Archives%27%20Reading%20Room%20or%20consult%20the%20Vital%20Statistics%20pages%20in%20the%20Interloan%20Microfilm%20Catalogue%20on%20the%20Archives%27%20website.%20The%20inventory%20and%20Interloan%20webpages%20provide%20detailed%20instructions%20on%20the%20various%20steps%20required%20in%20using%20these%20vital%20statistics%20records.>;
  add:notes <https://data.archives.gov.on.test.gbad.caThe%20Archives%20of%20Ontario%20has%20acquired%20additional%20Division%20Registrar%20vital%20statistics%20records.%20%20These%20records%20are%20closed%20for%20microfilming%2C%20and%20this%20microfilm%20will%20be%20available%20to%20the%20public%20sometime%20in%202007.>;
  rico:conditionsOfAccess <https://data.archives.gov.on.test.gbad.caResearchers%20must%20use%20microfilm%3B%20otherwise%2C%20there%20are%20no%20restrictions%20on%20access.>;
  rico:conditionsOfUse <https://data.archives.gov.on.test.gbad.caThis%20material%20is%20for%20research%20purposes%20only.%20%20The%20Archives%20of%20Ontario%20does%20not%20issue%20birth%2C%20marriage%20or%20death%20certificates.%20The%20Archives%20of%20Ontario%20will%20certify%20photocopies%20of%20birth%2C%20marriage%20and%20death%20registrations%20which%20are%20produced%20in%20the%20presence%20of%20its%20staff%20in%20the%20Archives%20of%20Ontario%20Main%20Reading%20Room.>;
  rico:creationDate <https://data.archives.gov.on.test.gbad.ca1858-1942>;
  rico:hasContentOfType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/ContentType#Textual%20records>;
  rico:hasCreator <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Office%20of%20the%20Registrar%20General>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/CurrentReferenceCode/RG%2080-13>;
  rico:hasOrHadInstantiation </KB/Instantiation/RG%2080-13/urn:uuid:3f61fc77-7011-56c6-b0e0-a7c9f543b16e>;
  rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/KB/Title/Division%20Registrar%20vital%20statistics%20records>;
  rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/Level#Series>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/RG%2080-13>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20largely%20of%20volumes%20containing%20registrations%20of%20births%2C%20marriages%20and%20deaths%20created%20by%20various%20Division%20Registrars%20%28who%20were%20in%20fact%20city%2C%20town%20or%20county%20clerks%29%20under%20the%20authority%20of%20the%20Vital%20Statistics%20Act.%20%20These%20records%20were%20subsequently%20transferred%20to%20the%20Registrar%20General%20for%20a%20variety%20of%20reasons%20%28e.g.%20lack%20of%20space%2C%20retirement%20of%20a%20registrar%29%20under%20the%20authority%20of%20the%20Act.%20When%20an%20individual%20went%20to%20the%20Division%20Registrar%20to%20register%20an%20event%2C%20the%20information%20was%20recorded%20in%20a%20book%20or%20register%20and%20then%20forwarded%20to%20the%20Registrar%20General.%20%20The%20registers%20themselves%2C%20along%20with%20any%20index%20books%20that%20may%20have%20been%20created%2C%20remain%20in%20the%20custody%20and%20control%20of%20the%20registrars%20and%20their%20successors%2C%20until%20such%20time%20as%20they%20are%20transferred%20to%20the%20Registrar%20General.%20%20Certain%20other%20volumes%20in%20this%20series%20appear%20to%20have%20been%20created%20before%20the%20existence%20of%20the%20Registrar%20General%2C%20but%20they%20were%20later%20transferred%20to%20the%20Registrar%20General%20under%20the%20authority%20of%20the%20Vital%20Statistics%20Act.%20%20The%20registers%20in%20this%20series%20are%20arranged%20by%20the%20year%20that%20they%20were%20acquired%20by%20the%20Archives%20of%20Ontario%2C%20and%20within%20each%20year%2C%20they%20are%20listed%20alphabetically%20by%20name%20of%20city%2C%20township%2C%20county%20or%20district.%20%20The%20registers%20themselves%20are%20arranges%20by%20various%20methods%2C%20with%20the%20two%20most%20common%20being%3A%20chronological%20by%20the%20date%20of%20registration%20of%20the%20event%3B%20and%20by%20letter%20of%20the%20alphabet%20%28i.e.%20all%20surnames%20beginning%20with%20the%20same%20letter%20are%20grouped%20together%29.%20%20Registrations%20that%20are%20chronological%20by%20date%20of%20event%20are%20most%20often%20indexed%20at%20the%20front%20of%20the%20volume.> .

