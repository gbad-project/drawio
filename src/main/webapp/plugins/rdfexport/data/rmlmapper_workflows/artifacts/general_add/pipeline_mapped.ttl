  rico:history <https://data.archives.gov.on.test.gbad.caUnder%20the%20Coroners%20Act%20%28Statutes%20of%20Ontario%201927%2C%20chap.%20122%29%2C%20Coroners%20in%20Ontario%20had%20the%20authority%20to%20call%20an%20inquest%20whenever%20someone%20died%20suddenly%20or%20unexpectedly%2C%20while%20an%20inmate%20in%20a%20provincial%20facility%2C%20or%20of%20an%20illness%20for%20which%20they%20were%20not%20being%20treated%20by%20a%20physician.%20%20At%20the%20inquest%2C%20a%20jury%20%28composed%20of%207%20to%2012%20people%20before%201948%3B%20afterwards%2C%20of%205%20persons%29%20heard%20testimony%20from%20witnesses%2C%20medical%20personnel%2C%20and%20police%20testimony%20about%20how%20the%20decease%20died.%20Evidence%20in%20the%20form%20of%20photographs%2C%20site%20drawings%2C%20autopsy%20reports%2C%20hospital%20records%2C%20and%20police%20reports%20were%20submitted%20to%20the%20jury%20for%20its%20consideration.%20%20The%20jury%20presented%20its%20verdict%20and%20recommendations%20for%20further%20actions%20if%20necessary.If%20the%20Coroner%20decided%20that%20the%20circumstances%20surrounding%20a%20death%20were%20not%20unusual%20and%20did%20not%20warrant%20an%20inquest%2C%20he%20was%20required%20under%20the%20Coroners%20Act%20to%20issue%20a%20report%2C%20later%20called%20%27Coroner%27s%20Statement%20to%20Bury%20the%20Body%20of%20a%20Deceased%20Persons%27.%20%20Reports%20and%20%27Statements%20to%20Bury%27%20listed%20the%20name%20of%20the%20deceased%2C%20the%20date%20and%20cause%20of%20death.%20%20A%20brief%20narrative%20was%20often%20included%20stating%20the%20medical%20condition%20at%20the%20time%20of%20death.%20%20If%20an%20autopsy%20was%20conducted%20its%20findings%20were%20stated%20on%20this%20document.>;
  rico:isAssociatedWithPlace <https://data.archives.gov.on.test.gbad.ca/KB/Place/Lennox%20and%20Addington%20%28Ont.%20%3A%20County%29>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/RG%2022-3095>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20of%20files%2C%20kept%20by%20the%20Crown%20Attorney%2C%20relating%20to%20Coroners%27%20investigations.%20%20%20%20The%20files%20generally%20contain%2C%20site%20drawings%2C%20photographs%2C%20autopsy%20reports%2C%20hospital%20records%2C%20and%20police%20reports%20and%20are%20arranged%20alphabetically%20by%20the%20surname%20of%20the%20deceased.> .

