  rico:conditionsOfAccess <https://data.archives.gov.on.test.gbad.caNegatives%20in%20this%20sereis%20are%20closed%20for%20conservation%20reasons.%20No%20restrictions%20apply%20to%20the%20remainder%20of%20this%20series.>;
  rico:conditionsOfUse <https://data.archives.gov.on.test.gbad.caRecords%20are%20in%20the%20public%20domain.%20There%20are%20no%20restrictions%20on%20reproduction%2C%20however%20permission%20from%20the%20Archives%20of%20Ontario%20is%20required%20for%20publication%3B%20submit%20a%20Request%20for%20Permission%20to%20Publish%2C%20Exhibit%20or%20Broadcast%20Form.>;
  rico:creationDate <https://data.archives.gov.on.test.gbad.ca1900-1928>;
  rico:hasContentOfType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/ContentType#Graphic%20materials>,
    <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/ContentType#Textual%20records>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/CurrentReferenceCode/C%20267-2>;
  rico:hasOrHadInstantiation </KB/Instantiation/C%20267-2/urn:uuid:3f61fc77-7011-56c6-b0e0-a7c9f543b16e>;
  rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/KB/Title/Toronto%20-%20Sudbury%20railroad%20construction%20%3A%20prints%20and%20negatives>;
  rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/Level#Series>;
  rico:isDirectlyIncludedIn <https://data.archives.gov.on.test.gbad.ca/KB/RecordSet/C%20267>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/C%20267-2>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20of%20366%20prints%20in%20two%20albums%2C%20and%2094%20cellulose%20nitrate%20film%20negatives%2C%20mainly%20depicting%20the%20construction%20of%20the%20Canadian%20Pacific%20Railway%27s%20Toronto-Sudbury%20line%20from%201904-1908%2C%20taken%20by%20Alexander%20Isbester%20and%20fellow%20workers.%20A%20few%20date%20from%20some%20of%20Isbester%27s%20earlier%20work%20on%20the%20Algoma%20Central%20Railway%20%281900%29%2C%20the%20Ottawa%20Northern%20and%20Western%20Railway%2C%20and%20the%20Canadian%20Pacific%20Railway%20in%20Saskatoon.%20Also%20found%20in%20the%20second%20album%20%28C%20267-2-1-2%29%20are%20photos%20from%20Isbester%27s%20later%20projects%2C%20such%20as%20the%20Grand%20Trunk%20Railway%20%281920%29%20and%20breakwater%20construction%20in%20Port%20Arthur%20%281928%29.%20%20Images%20in%20this%20series%20portray%20various%20aspects%20of%20the%20life%20and%20work%20of%20construction%20engineers%20in%20Northern%20Ontario.%20Geographic%20locations%20include%20Byng%20Inlet%2C%20Whitefish%20Creek%2C%20and%20the%20French%20River.%20There%20are%20also%20family%20photos%20of%20the%20Isbesters.%20The%20photos%20are%20grouped%20by%20location%20and%20event%2C%20but%20are%20not%20in%20alphabetical%20or%20chronological%20order.%20%20Series%20is%20divided%20into%20three%20sub-series%3A%20albums%2C%20negatives%20and%20captions%2Fcross-references.%20The%20albums%20contain%20prints%20which%20were%20numbered%20by%20James%20Isbester.%20For%20each%20numbered%20print%20there%20is%20a%20corresponding%20caption%2C%20see%20description%20for%20sub-series%20C%20267-2-3.%20In%20some%20cases%2C%20however%2C%20captions%20contain%20no%20information%20about%20the%20prints.%20Cross-reference%20indexes%20indicate%20which%20prints%20have%20negatives%20and%20which%20have%20duplicates%20in%20other%20albums.%20Corresponding%20negatives%20for%20some%20of%20the%20prints%20are%20listed%20in%20sub-series%20C%20267-2-2.%20%20See%20the%20sub-series%20descriptions%20for%20further%20information%20and%20for%20item%20listings.> .

