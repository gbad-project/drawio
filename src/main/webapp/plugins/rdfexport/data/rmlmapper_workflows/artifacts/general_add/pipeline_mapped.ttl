  rico:creationDate <https://data.archives.gov.on.test.gbad.ca%5Bca.%201955%5D-1996>;
  rico:hasContentOfType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/ContentType#Graphic%20materials>,
    <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/ContentType#Textual%20records>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/CurrentReferenceCode/F%204531-15>;
  rico:hasOrHadInstantiation </KB/Instantiation/F%204531-15/urn:uuid:3f61fc77-7011-56c6-b0e0-a7c9f543b16e>;
  rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/KB/Title/Fred%20W.%20Hotson%27s%20Grumman%20CP-121%20Tracker%20research%20files>;
  rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/Level#Series>;
  rico:isDirectlyIncludedIn <https://data.archives.gov.on.test.gbad.ca/KB/RecordSet/F%204531>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/F%204531-15>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20of%20Fred%20W.%20Hotson%27s%20research%20files%20on%20the%20Grumman%20CP-121%20Tracker%20aircraft%2C%20created%20and%20accumulated%20in%20the%20course%20of%20writing%20books%20on%20de%20Havilland%20Canada.%20%20Records%20include%20magazine%20articles%2C%20a%20news%20release%2C%20research%20notes%2C%20and%20photographs.%20Photographs%20depict%20the%20interior%20and%20exterior%20of%20the%20aircraft%2C%20including%20details%20of%20the%20cockpit%20and%20controls.%20Also%20included%20are%20official%20photographs%20of%20the%20100th%20Tracker%2C%20made%20for%20the%20Royal%20Canadian%20Navy.%20Several%20photographs%20show%20the%20Tracker%20in%20flight%20and%20in%20formation.%20%20Note%20that%20most%20of%20the%20photographs%20in%20this%20series%20are%20professional%20photographs%2C%20taken%20for%20public%20relations%20or%20advertising%20purposes%3B%20there%20are%20very%20few%20amateur%20snapshots%20included%20in%20this%20series.%20%20%20De%20Havilland%20Canada%20produced%20100%20Grumman%20Trackers%20under%20licence%2C%20between%201955%20and%201957.%20%20Some%20parts%20were%20manufactured%20by%20other%20Canadian%20companies%2C%20with%20the%20forward%20fuselage%20and%20cockpit%20built%20by%20de%20Havilland%20Canada.%20%20DHC%20assembled%20and%20tested%20the%20aircraft.%20%20%20The%20Tracker%20was%20an%20anti-submarine%20aircraft%2C%20and%20was%20the%20first%20Canadian-built%20aircraft%20ordered%20by%20the%20Royal%20Canadian%20Navy.> .

