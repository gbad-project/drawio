  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20of%20a%20bound%20volume%20of%20chronological%20minutes%20of%20proceedings%20of%20the%20superior%20court%20Judge%20sitting%20in%20criminal%20assizes.%20Typically%2C%20the%20superior%20court%20criminal%20assizes%20only%20dealt%20with%20serious%20offences%20such%20as%20rape%2C%20murder%2C%20perjury%20and%20so%20on.%20%20These%20minutes%20generally%20include%20names%20of%20the%20relevant%20officers%2C%20a%20list%20of%20the%20accused%20and%20charges%2C%20names%20of%20witnesses%2C%20lists%20of%20evidence%2C%20names%20of%20the%20members%20of%20the%20Grand%20Jury%2C%20verdicts%20and%20sentences.> .

<https://data.archives.gov.on.test.gbad.ca/KB/RecordSet/RG%2022-5512> a owl:NamedIndividual,
    rico:RecordSet;
  add:findingAidNote <https://data.archives.gov.on.test.gbad.caNo%20finding%20aid%20is%20available%20for%20this%20series.>;
  rico:conditionsOfAccess <https://data.archives.gov.on.test.gbad.caNo%20restrictions%20on%20access.>;
  rico:conditionsOfUse <https://data.archives.gov.on.test.gbad.caCopyright%20is%20primarily%20held%20by%20the%20Crown.%20There%20are%20no%20restrictions%20on%20reproduction.%20Permission%20of%20the%20Archives%20of%20Ontario%20is%20required%20for%20publication%3B%20submit%20a%20Request%20for%20Permission%20to%20Publish%2C%20Exhibit%20or%20Broadcast%20Form.>;
  rico:creationDate <https://data.archives.gov.on.test.gbad.ca1882-1884%2C%201902-1912>;
  rico:hasContentOfType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/ContentType#Textual%20records>;
  rico:hasCreator <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Supreme%20Court>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/CurrentReferenceCode/RG%2022-5512>;
  rico:hasOrHadInstantiation </KB/Instantiation/RG%2022-5512/urn:uuid:3f61fc77-7011-56c6-b0e0-a7c9f543b16e>;
  rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/KB/Title/Welland%20County%20Local%20Master%27s%20minute%20books>;
  rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/Level#Series>;
  rico:history <https://data.archives.gov.on.test.gbad.caUnder%20the%20Ontario%20Judicature%20Act%20of%201881%2C%20Local%20Masters%20of%20the%20Court%20of%20Chancery%20became%20Local%20Masters%20of%20the%20Supreme%20Court.%20Local%20Masters%20were%20appointed%20by%20the%20Lieutenant%20Governor%20in%20Council%20in%20each%20of%20the%20counties%20of%20the%20Province%20of%20Ontario%2C%20on%20the%20recommendation%20of%20the%20Attorney%20General.%20In%201989%2C%20legislation%20was%20passed%20which%20merged%20the%20Supreme%20and%20District%20Courts%20of%20the%20province%20and%20regionalized%20the%20court%20system.%20As%20a%20result%2C%20Local%20Masters%20of%20the%20Supreme%20Court%20were%20replaced%20with%20Local%20Masters%20of%20the%20Ontario%20Court%20%28General%20Division%29.>;
  rico:isAssociatedWithPlace <https://data.archives.gov.on.test.gbad.ca/KB/Place/Welland%20%28Ont.%20%3A%20County%29>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/ArchivalDescriptionRecord/RG%2022-5512>;
  rico:scopeAndContent <https://data.archives.gov.on.test.gbad.caSeries%20consists%20of%20minute%20books%20to%20serve%20as%20a%20record%20of%20cases%20heard%20by%20the%20Local%20Master%20at%20Welland.%20Entries%20typically%20record%20the%20style%20of%20cause%20in%20the%20form%20plaintiff%20versus%20defendant%2C%20the%20date%20each%20writ%20or%20other%20process%20was%20issued%2C%20the%20filing%20of%20any%20further%20proceedings%2C%20names%20of%20the%20solicitors%2C%20the%20verdict%2C%20and%20the%20costs.%20%20Cases%20include%3A%20administration%20of%20partition%20without%20action%3B%20vacating%20certificates%20of%20lis%20pendens%3B%20motions%20to%20wind%20up%20companies%3B%20motions%20for%20interpleader%3B%20payment%20into%20court%20of%20moneys%20under%20the%20Trustee%20Act%3B%20payment%20of%20money%20out%20of%20court%3B%20hearing%20motions%20for%20judgment%20on%20specially%20endorsed%20writs%20and%20actions%20for%20account%3B%20certain%20motions%20relating%20to%20estates.> .

