  rico:history <https://data.archives.gov.on.test.gbad.caHe%20was%20born%20in%20Brockville%2C%20Ontario%20in%201940.%20After%20studying%20political%20science%20and%20journalism%20at%20Ryerson%20Polytechnical%20Institute%20from%201961-1964%2C%20Hoy%20has%20covered%20political%20events%20for%20a%20number%20of%20newspapers%2C%20including%20the%20Toronto%20Telegram%20and%20Toronto%20Star.%20As%20well%2C%20Hoy%20was%20the%20Toronto%20Sun%27s%20Queen%27s%20Park%20columnist%20from%201975-1984.%20He%20has%20since%20become%20the%20Toronto%20Sun%27s%20Ottawa%20political%20correspondent.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Hoy%2C%20Claire%2C%201940-> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Hunter%2C%20Donald%20F.%2C%201911-1976>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Person>,
    rico:Person;
  rdfs:label <https://data.archives.gov.on.test.gbad.caHunter%2C%20Donald%20F.%2C%201911-1976 (Person)>,
    "";
  rico:history <https://data.archives.gov.on.test.gbad.caDonald%20F.%20Hunter%20%281911-1976%29%2C%20was%20born%20on%20January%2022%2C%201911%20to%20Horace%20T.%20Hunter%20and%20Christine%20Fleming%20in%20Toronto%2C%20Ontario.%20He%20was%20educated%20at%20Upper%20Canada%20College%20and%20the%20University%20of%20Toronto%2C%20but%20left%20university%20in%201930%20to%20begin%20working%20in%20the%20audit%20department%20of%20the%20Maclean%20Publishing%20Company.%20In%201938%2C%20he%20was%20appointed%20Managing%20Director%20of%20its%20British%20subsidiary.%20During%20the%20Second%20World%20War%2C%20he%20served%20with%20the%20Governor-General%27s%20Horse%20Guards%2C%20which%20was%20converted%20to%20a%20tank%20regiment.%20He%20went%20overseas%20as%20a%20staff%20captain%20with%20the%205th%20Canadian%20Armored%20Brigade.%20He%20served%20as%20a%20Brigade%20Major%20in%20the%204th%20Canadian%20Armored%20Division%20in%20England%2C%20then%20in%20Italy%20with%20the%20First%20Canadian%20Army%20Tank%20Brigade%2C%20before%20returning%20to%20Canada%20and%20to%20Maclean-Hunter%20as%20manager%20of%20Mayfair%20magazine.%20In%201946%2C%20he%20was%20appointed%20Executive%20Assistant%20to%20T.%20H.%20Howse%2C%20then%20Vice-president%20and%20company%20Treasurer%2C%20and%20he%20became%20involved%20in%20the%20company%27s%20London%20and%20Chicago%20operations.%20He%20was%20also%20closely%20involved%20in%20the%20design%20and%20development%20of%20the%20company%27s%20new%20printing%20plant%2C%20which%20opened%20in%20Willowdale%20in%201948.%20He%20was%20appointed%20Vice-president%20and%20Managing%20Director%20in%201952%2C%20President%20in%201962%2C%20and%20President%20and%20Chairman%20of%20the%20Board%20in%201969.%20He%20was%20President%20of%20the%20Business%20Newspapers%20Association%2C%20and%20a%20Director%20of%20the%20Periodical%20Press%20Association%20of%20Canada%20and%20the%20Audit%20Bureau%20of%20Circulations%20in%20the%20United%20States.%20Hunter%20died%20on%20October%203%2C%201976.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Hunter%2C%20Donald%20F.%2C%201911-1976> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Inquiry%20into%20Motor%20Vehicle%20Accident%20Compensation%20in%20Ontario>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Inquiry%20into%20Motor%20Vehicle%20Accident%20Compensation%20in%20Ontario%20conducted%20research%20into%20the%20provision%20of%20insurance%20for%20motor%20vehicle%20accidents%2C%20particularly%20the%20provision%20of%20%22no-fault%22%20insurance.%20The%20Inquiry%20also%20examined%20the%20benefits%20of%20a%20publicly%20owned%20insurance%20system.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Inquiry%20into%20Motor%20Vehicle%20Accident%20Compensation%20in%20Ontario>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#B%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/BA483>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Inquiry%20into%20Motor%20Vehicle%20Accident%20Compensation%20in%20Ontario%20was%20appointed%20on%20November%206%2C%201986.%20The%20Inquiry%20was%20headed%20by%20a%20Commissioner%2C%20the%20Hon.%20Mr.%20Justice%20Coulter%20A.A.%20Osborne%2C%20who%20was%20assisted%20by%20an%20Advisory%20Committee%20of%20ten%20members.%20The%20Committee%20was%20composed%20of%20experts%20in%20the%20field%20of%20automobile%20accident%20compensation%2C%20including%20representatives%20from%20insurance%20bureaus%20and%20companies%2C%20consumer%27s%20assocations%2C%20the%20handicapped%20and%20other%20groups.%20The%20Inquiry%20conducted%20in-depth%20research%20into%20all%20facets%20of%20automobile%20insurance%20in%20Ontario%2C%20including%20standard%20automobile%20insurance%20contracts%2C%20the%20history%20of%20insurance%2C%20litigated%20claims%2C%20and%20a%20wide%20variety%20of%20methods%20of%20providing%20adequate%20insurance%20to%20drivers%20in%20Ontario%20and%20elsewhere.%20The%20Inquiry%20concluded%20that%20no-fault%20benefits%20should%20be%20substantially%20expanded%20and%20made%20truly%20%22no-fault%22%20in%20their%20character%2C%20and%20that%20the%20right%20to%20individual%20compensation%20in%20the%20tort%20system%20should%20be%20maintained.%20In%20other%20words%2C%20the%20need%20to%20sue%20to%20receive%20compensation%20was%20reduced%20although%20the%20right%20to%20sue%20was%20preserved.%20The%20Inquiry%20did%20not%20recommend%20public%20ownership%20of%20the%20insurance%20industry%20in%20Ontario%2C%20but%20rather%20closer%20regulation%20of%20the%20industry.%20The%20inquiry%20made%20a%20great%20number%20of%20detailed%20recommendations%20about%20regulation%20of%20the%20automobile%20insurance%20industry%2C%20insurance%20coverage%20and%20premiums%2C%20systems%20of%20compensation%2C%20other%20insurance%20issues%2C%20public%20or%20private%20provision%20of%20insurance%2C%20rate%20regulation%2C%20and%20accident%20prevention.%20The%20inquiry%20was%20dissolved%20in%201988.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/BA483>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Inquiry%20into%20Motor%20Vehicle%20Accident%20Compensation%20in%20Ontario> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Jessup%2C%20Edward%2C%201735-1816>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Person>,
    rico:Person;
  rdfs:label <https://data.archives.gov.on.test.gbad.caJessup%2C%20Edward%2C%201735-1816 (Person)>,
    "";
  rico:history <https://data.archives.gov.on.test.gbad.caHe%20was%20born%20in%20Stamford%2C%20Connecticut%2C%20and%20married%20Abigail%20Dibble%20in%201760.%20Before%20the%20American%20Revolution%2C%20he%20was%20a%20Justice%20of%20the%20Peace%20for%20the%20City%20and%20County%20of%20Albany.%20In%20the%20fall%20of%201776%2C%20he%20and%20his%20brothers%20formed%20a%20band%20of%20Loyalists%20which%20went%20to%20Canada%20to%20join%20Sir%20Guy%20Carleton%20at%20Crown%20Point.%20In%201777%2C%20he%20was%20made%20a%20Captain%20in%20the%20%22King%27s%20Loyal%20Americans%22%2C%20a%20corps%20of%20Loyalists%20formed%20by%20his%20younger%20brother%2C%20Lt.%20Col.%2C%20Ebenezer%20Jessup.%20In%20November%20of%201781%2C%20this%20corps%20was%20reorganized%2C%20and%20Edward%20Jessup%20was%20appointed%20to%20be%20Major%20Commandant%20to%20a%20corps%20called%20the%20Loyal%20Rangers%20%28sometimes%20referred%20to%20as%20Jessup%27s%20Rangers%29.%20This%20regiment%20was%20disbanded%20in%201783%2C%20and%20in%201784%2C%20Jessup%20worked%20to%20settle%20his%20soldiers%20in%20the%20area%20that%20now%20comprises%20the%20counties%20of%20Leeds%2C%20Grenville%2C%20Addington%2C%20and%20the%20Bay%20of%20Quinte.%20In%201785%2C%20he%20went%20to%20England%20to%20present%20his%20schedule%20of%20losses%20to%20the%20commissioners%20appointed%20for%20inquiry%20into%20the%20losses%20and%20services%20of%20American%20Loyalists.%20In%201787%2C%20he%20proceeded%20to%20Augusta%20Township%2C%20and%20settled%20on%20his%20grant%20of%201200%20acres%20%28he%20was%20also%20granted%203000%20acres%20in%20the%20District%20of%20Lunenburg%29.%20In%201810%2C%20he%20had%20a%20town%20plot%20surveyed%20on%20the%20front%20of%20Lots%202%20and%203%20in%20the%20First%20Concession%20of%20Augusta%20Township%2C%20Grenville%20County%2C%20which%20he%20named%20Prescott%20%28in%20honour%20of%20General%20Robert%20Prescott%2C%20Governor-in-Chief%20of%20Canada%20from%201787-1807%29.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Jessup%2C%20Edward%2C%201735-1816> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Jessup%2C%20Hamilton%20Dibble%2C%201806-1892>
