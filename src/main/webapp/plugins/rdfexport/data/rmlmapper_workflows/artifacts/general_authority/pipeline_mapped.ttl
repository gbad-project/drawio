  rico:hasSuccessor <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Environmental%20Protection%20Branch.>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Forest%20Protection%20Branch%20was%20created%20within%20the%20Ontario%20Department%20of%20Lands%20and%20Forests%20in%201960%2C%20replacing%20the%20Division%20of%20Forest%20Protection.%20The%20branch%20was%20comprised%20of%20the%20Forest%20Protection%20Section%20and%20for%20Air%20Services%20Section.%20In%201969%2C%20the%20Engineering%20Services%20Section%20was%20also%20formed%20as%20part%20of%20the%20branch.%20The%20Forest%20Protection%20Branch%20ceased%20to%20exist%20in%201971.%20The%20Forest%20Protection%20Section%20and%20Air%20Services%20Section%20became%20part%20of%20the%20Environmental%20Protection%20Branch%2C%20and%20the%20Engineering%20Services%20Section%20became%20part%20of%20the%20Surveys%20and%20Engineering%20Branch.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/CA445>;
