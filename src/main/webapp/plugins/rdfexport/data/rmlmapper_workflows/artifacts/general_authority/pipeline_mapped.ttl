  a owl:NamedIndividual, rico:CorporateBody .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario%20Telephone%20Services%20Commission>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Ontario%20Telephone%20Services%20Commission%20was%20a%20provincial%2C%20quasi-%20judicial%20regulatory%20body%20responsible%20for%20hearing%20and%20deciding%20all%20applications%20filed%20by%20the%20industry%20as%20well%20as%20by%20the%20public.%20The%20Commission%20issued%20orders%20and%20directions%20for%20the%20regulation%20of%20the%20thirty%20independent%20telephone%20systems%20in%20Ontario%2C%20and%20ensured%20that%20rates%20charged%20for%20services%20were%20just%20and%20reasonable%20and%20that%20efficient%20and%20adequate%20services%20were%20provided%20to%20the%20systems%20customers.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Ontario%20Telephone%20Services%20Commission>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#B%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/BA94>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Ontario%20Telephone%20Service%20Commission%20was%20formed%20on%20April%201%2C%201960%20replacing%20the%20former%20Ontario%20Telephone%20Authority.%20It%20was%20located%20within%20the%20Department%20of%20Agriculture%20and%20Food.%20On%2023%20June%201971%20it%20became%20part%20of%20the%20Department%2C%20later%20the%20Ministry%2C%20of%20Transportation%20and%20Communications.%20In%201987%2C%20it%20was%20moved%20to%20the%20Ministry%20of%20Culture%20and%20Communications%2C%20and%20finally%20became%20part%20of%20the%20Ministry%20of%20Economic%20Development%20and%20Trade%20in%201993%20when%20that%20ministry%20became%20responsible%20for%20communications%20policy%20and%20programs.%20The%20Supreme%20Court%20of%20Canada%20ruled%20in%20Spring%201994%20that%20communications%20was%20the%20responsibility%20of%20the%20CRTC%20%28the%20federal%20communications%20regulatory%20body%29.%20The%20Ontario%20Telephone%20Services%20Commission%20was%20consequently%20closed%20down%20in%20the%20Fall%20of%201994.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/BA94>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario%20Telephone%20Services%20Commission>;
  rico:isSuccessorOf <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario%20Telephone%20Authority> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Clerks%20of%20the%20Peace%20%281777-1968%29>
  a owl:NamedIndividual, rico:CorporateBody .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Clerks%20of%20the%20Peace%20%281968-1984%29>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caClerks%20of%20the%20Peace%20were%20appointed%20to%20keep%20the%20county%20record%20and%20to%20assist%20the%20justices%20of%20the%20peace%20in%20quarter%20sessions%20in%20drawing%20indictments%2C%20entering%20judgements%2C%20issuing%20process%20etc.%2C%20and%20in%20administering%20business.%20Basic%20duties%20of%20the%20Clerks%20of%20the%20Peace%20included%3A%20recording%20forfeited%20estates%20of%20traitors%3B%20prosecuting%20negligent%20assessors%3B%20laying%20property%20assessment%20suits%20before%20Quarter%20Sessions%3B%20furnishing%20government%20with%20annual%20returns%20of%20assessed%20property%3B%20%20making%20writs%20of%20assessments%3B%20notifying%20parish%20and%20town%20officials%20to%20take%20oath%3B%20granting%20certificates%20of%20pardon%3B%20delivering%20jury%20lists%20to%20the%20Sheriff%3B%20recording%20marriages%3B%20transmitting%20to%20the%20government%20lists%20of%20licences%20granted%3B%20recording%20and%20transmitting%20to%20government%20lists%20of%20population%3B%20making%20up%2C%20yearly%2C%20a%20list%20of%20inhabitant%20householders%20and%20delivering%20it%20to%20the%20Sheriff%20for%20jurors%3B%20returning%20convictions%20to%20the%20General%20Quarter%20Session%20of%20the%20Peace%20and%20filing%20Justice%20of%20the%20Peace%27s%20Returns%20of%20Convictions%20and%20Returns%20of%20Finis%2C%20Penalties%20etc.%3B%20publishing%20the%20returns%20in%20the%20newspaper%20of%20the%20district%3B%20recording%20the%20place%20and%20time%20of%20sittings%20of%20the%20County%2FDistrict%20Court%3B%20and%20taking%20the%20affidavit%20of%20bastardy%20from%20unmarried%20mothers%20for%20support%20by%20declaring%20the%20father.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Upper%20Canada.%20Clerks%20of%20the%20Peace.>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Dept.%20of%20the%20Attorney%20General>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA952>;
  rico:history <https://data.archives.gov.on.test.gbad.caIn%201968%2C%20the%20Government%20of%20Ontario%2C%20through%20the%20Department%20of%20the%20Attorney%20General%2C%20became%20responsible%20for%20all%20aspects%20of%20the%20administration%20of%20justice%20in%20the%20province.%20As%20a%20result%2C%20the%20Clerks%20of%20the%20Peace%20of%20the%20province%2C%20who%20prior%20to%201968%20were%20local%20county%20officials%2C%20became%20officials%20of%20the%20Department%20of%20the%20Attorney%20General.%20Clerks%20of%20the%20Peace%20were%20appointed%20by%20the%20Lieutenant%20Governor%20and%20were%20required%20to%20be%20a%20Barrister%20at%20Law%2C%20with%20not%20less%20than%20three%20years%20standing%20at%20the%20bar%20of%20Ontario.%20The%20positions%20of%20Clerk%20of%20the%20Peace%20and%20Crown%20Attorney%20were%2C%20in%20general%2C%20held%20by%20the%20same%20individual.%20However%2C%20if%20it%20was%20necessary%20for%20health%20reasons%2C%20the%20individual%20could%20resign%20as%20Crown%20Attorney%20and%20remain%20as%20Clerk%20of%20the%20Peace.%20If%20this%20was%20the%20case%2C%20the%20newly%20appointed%20Crown%20Attorney%20would%20then%20become%20Clerk%20of%20the%20Peace%20upon%20the%20vacancy%20of%20that%20position.%20With%20the%20abolition%20of%20the%20General%20Sessions%20of%20the%20Peace%20in%201984%2C%20the%20position%20of%20Clerk%20of%20the%20Peace%20lost%20much%20of%20its%20remaining%20raison%20d%27etre%20and%20subsequently%20faded%20away%20completely.%20The%20following%20is%20an%20alphabetical%20listing%20of%20the%20counties%2Fdistricts%2Fjudicial%20districts%20that%20have%20existed%20within%20the%20Province%20since%201968%20%28with%20Dt.%3D%20District%2C%20Co.%3DCounty%2C%20and%20J.D.%3DJudicial%20District%29%2C%20along%20with%20the%20dates%20for%20which%20they%20existed%3A%20Algoma%20Dt.%20%281859-%20%29%3B%20%20Brant%20Co.%20%281853-%20%20%20%20%29%3B%20Bruce%20Co.%20%281867-%20%20%20%20%20%29%3B%20Carleton%20Co.%20%281850-1969%29%3B%20Cochrane%20Dt.%20%281922-%20%29%3B%20Dufferin%20Co.%20%281881-%20%20%20%20%20%29%3B%20Durham%20J.D.%20%281974-%20%20%20%20%20%29%3B%20Elgin%20Co.%20%281853-%20%29%3B%20Essex%20Co.%20%281853-%20%20%20%20%20%29%3B%20Frontenac%20Co.%20%281865-%20%20%20%20%20%29%3B%20Grey%20Co.%20%281853-%20%29%3B%20Haldimand%20Co.%20%281851-1974%29%3B%20Haldimand%20J.D.%20%281974-%20%20%20%20%20%29%3B%20Haliburton%20Co.%20%281874-%20%20%20%20%20%29%3B%20Halton%20Co.%20%281855-1973%29%3B%20Halton%20J.D.%20%281974-%20%20%20%20%20%29%3B%20Hamilton-%20Wentworth%20J.D.%20%281974-%20%20%20%20%20%29%3B%20Hastings%20Co.%20%281850-%20%20%20%20%20%29%3B%20Huron%20Co.%20%281867-%20%29%3B%20Kenora%20Dt.%20%281898-%20%20%20%20%20%29%3B%20Kent%20Co.%20%281851-%20%29%3B%20Lambton%20Co.%20%281853-%20%20%20%20%20%29%3B%20Lanark%20and%20Renfrew%20United%20Cos.%20%281850-1866%29%3B%20Lanark%20Co.%20%281866-%20%29%3B%20Leeds%20and%20Grenville%20United%20Cos.%20%281850-%20%20%20%20%20%29%3B%20Lennox%20and%20Addington%20United%20Co.%20%281865-%20%29%3B%20%20Lincoln%2C%20Haldimand%20and%20Welland%20United%20Cos.%20%281850-1851%29%3B%20Lincoln%20and%20Welland%20United%20Cos.%20%281851-1856%29%3B%20Lincoln%20Co.%20%281856-%201970%29%3B%20London%20Dt.%20%281798-1849%29%3B%20Luneburg%20Dt.%20%281788-1792%29%3B%20Manitoulin%20Dt.%20%281899-%20%20%20%20%20%29%3B%20Mecklenburg%20Dt.%20%281788-1792%29%3B%20Middlesex%20Co.%20%281850-1851%3B%201853-%20%29%3B%20Middlesex%20and%20Elgin%20United%20Cos.%20%281851-1853%29%3B%20Midland%20Dt.%20%281792-1849%29%3B%20Montreal%20%281777-%201788%29%3B%20Muskoka%20and%20Parry%20Sound%20Dt.%20%281888-1898%29%3B%20Muskoka%20Dt.%20%281898-%20%29%3B%20Nassau%20Dt.%20%281788-%201792%29%3B%20Newcastle%20Dt.%20%281802-%201849%29%3B%20Niagara%20Dt.%20%281798-1849%29%3B%20Niagara%20North%20J.D.%20%281970-%20%20%20%20%20%29%3B%20Niagara%20South%20J.D.%20%281970-%20%29%3B%20Nipissing%20Dt.%20%281858-%20%20%20%20%20%29%3B%20Norfolk%20Co.%20%281850-1974%29%3B%20Norfolk%20J.D.%20%281974-%20%20%20%20%20%29%3B%20Northumberland%20and%20Durham%20United%20Cos.%20%281850-1973%29%3B%20Northumberland%20Co.%20%281974-%20%20%20%20%20%29%3B%20Ontario%20Co.%20%281853-1973%29%3B%20Ottawa%20Dt.%20%281816-%201849%29%3B%20Ottawa-Carleton%20J.D.%20%281969-%20%20%20%20%20%29%3B%20%20%20%20%29%3B%20Peel%20Co.%20%281866-1973%29%3B%20Peel%20J.D.%20%281974-%20%29%3B%20Perth%20Co.%20%281853-%20%29%3B%20Peterborough%20Co.%20%281850-1851%3B%201863-%20%20%20%20%20%29%3B%20Peterborough%20and%20Victoria%20United%20Cos.%20%281851-%201863%29%3B%20Prescott%20and%20Russell%20United%20Cos.%20%281850-%20%20%20%20%20%29%3B%20Prince%20Edward%20Dt.%20%281834-1849%29%3B%20Prince%20Edward%20Co.%20%281850-%20%20%20%20%20%29%3B%20Rainy%20River%20Dt.%20%281909-%20%20%20%20%20%29%3B%20Renfrew%20Co.%20%281866-%20%20%20%20%20%29%3B%20Simcoe%20Dt.%20%281837-1849%29%3B%20%20Simcoe%20Co.%20%281850-%20%29%3B%20Stormont%2C%20Dundas%20and%20Glengarry%20United%20Cos.%20%281850-%20%29%3B%20Sudbury%20Dt.%20%281907-%20%20%20%20%20%29%3B%20Talbot%20Dt.%20%281837-1849%29%3B%20Temiskaming%20Dt.%20%281913-%20%20%20%20%20%29%3B%20Thunder%20Bay%20Dt.%20%281884-%20%20%20%20%20%29%3B%20Victoria%20Dt.%20%281839-1849%29%3B%20Victoria%20Co.%20%281863-%20%20%20%20%20%29%3B%20Waterloo%20Co.%20%281850-1851%3B%201853-%201973%29%3B%20Waterloo%20J.D.%20%281974-%20%29%3B%20Waterloo%2C%20Wellington%20and%20Grey%20United%20Cos.%20%281851-1853%29%3B%20Wellington%20Dt.%20%281840-1849%29%3B%20Wellington%20Co.%20%281853-%20%20%20%20%20%29%3B%20Welland%20Co.%20%281856-1970%29%3B%20Wentworth%20and%20Halton%20United%20Cos.%20%281850-1851%3B%201853-1855%29%3B%20Wentworth%2C%20Halton%20and%20Brant%20United%20Cos.%20%281851-1853%29%3B%20Wentworth%20Co.%20%281855-1973%29%3B%20Western%20Dt.%20%281792-1849%29%3B%20York%20Co.%20%281850-1851%3B%201866-1970%29%3B%20York%2C%20Ontario%20and%20Peel%20United%20Cos.%20%281851-1853%29%3B%20York%20and%20Peel%20United%20Cos.%20%281853-1866%29%3B%20York%20J.D.%20%281971-%20%20%20%20%20%29%3B%20and%20York%20Region%20J.D.%20%281980-%20%20%20%20%20%29.>;
