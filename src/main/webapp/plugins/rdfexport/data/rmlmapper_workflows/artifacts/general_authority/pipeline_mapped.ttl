<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Occupational%20Health%20and%20Safety%20Branch>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20function%20of%20this%20branch%20is%20to%20coordinate%20the%20programs%20and%20services%20that%20administer%20the%20Occupational%20Health%20and%20Safety%20Act%20and%20its%20regulations.%20It%20aims%20to%20foster%20a%20healthy%20and%20safe%20working%20environment%20and%20to%20encourage%20cooperation%20between%20employers%20and%20workers%20in%20identifying%20and%20controlling%20health%20and%20safety%20hazards.%20The%20branch%20operates%20the%20following%20programs%3A%20Professional%20and%20Specialized%20Services%2C%20Industrial%20Health%20and%20Safety%20Program%2C%20Construction%20Health%20and%20Safety%20Program%2C%20Mining%20Health%20and%20Safety%20Program%2C%20Mine%20Rescue%20Program%2C%20Regulation%20Development%20Unit%2C%20Health%20and%20Safety%20Studies%20Unit%20%28amalgamated%20with%20Professional%20and%20Specialized%20Services%20in%201996-97%29%2C%20Occupational%20Health%20Laboratory%20Services%2C%20Materials%20Testing%20Laboratory%2C%20Radiation%20Protection%20Services.%20The%20services%20are%20provided%20in%20the%20Area%2C%20District%20and%20Satellite%20Offices%20across%20the%20province.>;
  rico:hasEndDate <https://data.archives.gov.on.test.gbad.ca/KB/Date/1991>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Occupational%20Health%20and%20Safety%20Branch>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Labour>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA1796>;
  rico:history <https://data.archives.gov.on.test.gbad.caThis%20branch%20was%20created%20in%201991%20as%20one%20of%20the%20two%20branches%20of%20the%20newly%20established%20Operations%20Division%20and%20assumed%20the%20functions%20of%20the%20former%20Occupational%20Health%20and%20Safety%20Division.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/CA1796>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario.%20Occupational%20Health%20and%20Safety%20Branch>;
  rico:isSuccessorOf <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Occupational%20Health%20and%20Safety%20Division> .

