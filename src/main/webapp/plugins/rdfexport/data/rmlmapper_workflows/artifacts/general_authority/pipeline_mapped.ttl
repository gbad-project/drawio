<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Community%20Information%20Services>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Community%20Information%20Services%20unit%20administered%20the%20Community%20Information%20Services%20Program.%20The%20unit%20provided%20functional%20support%20for%20a%20network%20of%20community%20information%20centres%20%28CIC%29%20in%20Ontario%2C%20including%20funding%20through%20grants%2C%20providing%20advice%20on%20information%20management%2C%20staffing%20and%20volunteer%20training%2C%20and%20the%20production%20of%20resource%20material.>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Dept.%20of%20the%20Provincial%20Secretary%20and%20Citizenship>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA673>;
  rico:history <https://data.archives.gov.on.test.gbad.caCommunity%20Information%20Services%20was%20established%20in%201971%20as%20part%20of%20the%20Community%20Development%20Branch%20of%20the%20Ontario%20Department%20of%20the%20Provincial%20Secretary%20and%20Citizenship.%20The%20Community%20Information%20Services%20unit%20was%20%20transferred%20to%20the%20Ontario%20Ministry%20of%20Community%20and%20Social%20Services%20in%20April%201972%2C%20forming%20part%20of%20the%20Community%20Services%20Division.%20In%201974%2C%20however%2C%20the%20office%20became%20part%20of%20the%20Program%20Development%20Division.%20Effective%20April%201975%2C%20responsibility%20for%20the%20Community%20Information%20Services%20Office%20unit%20was%20transferred%20to%20the%20Ontario%20Ministry%20of%20Culture%20and%20Recreation%2C%20where%20it%20formed%20a%20part%20of%20the%20Multicultural%20Development%20and%20Public%20Libraries%20Division.%20For%20a%20brief%20period%20in%201979%2C%20the%20unit%20formed%20a%20part%20of%20the%20Citizens%27%20Inquiry%20Branch%20of%20the%20Information%20Access%20Division.%20By%20December%201979%2C%20however%2C%20it%20was%20transferred%20to%20the%20new%20Libraries%20and%20Community%20Information%20Branch.%20In%201989%2C%20responsibility%20for%20Community%20Information%20Services%20Program%20was%20transferred%20to%20the%20Grants%20Administration%2C%20Planning%20and%20Evaluation%20Unit%2C%20of%20the%20Libraries%20and%20Community%20Information%20Branch.%20With%20this%20change%2C%20the%20Community%20Information%20Services%20unit%20ceased%20to%20exist.%20Ministerial%20responsibility%20for%20Community%20Information%20Services%20rested%20with%20the%20Ontario%20Department%20of%20the%20Provincial%20Secretary%2C%20from%201971%20to%201972%3B%20the%20Ontario%20Ministry%20of%20Community%20and%20Social%20Services%2C%20from%201972%20to%201975%3B%20the%20Ontario%20Ministry%20of%20Culture%20and%20Recreation%2C%20form%201975-%201982%3B%20the%20Ontario%20Ministry%20of%20Citizenship%20and%20Culture%2C%20from%201982-%201987%3B%20and%20with%20the%20Ontario%20Ministry%20of%20Culture%20and%20Communications%2C%20from%201987-1989.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/CA673>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario.%20Community%20Information%20Services> .

