  rico:hasSuccessor <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Tourism%20Marketing%20Branch>;
  rico:history <https://data.archives.gov.on.test.gbad.caIn%201972%2C%20the%20Tourist%20Promotion%20and%20Information%20Branch%20of%20the%20Ontario%20Department%20of%20Tourism%20and%20Information%20was%20replaced%20with%20the%20Travel%20Services%20Branch.%20The%20branch%20formed%20part%20of%20the%20new%20Ministry%20of%20Industry%20and%20Tourism%2C%20and%20was%20situated%20within%20the%20Communications%20Division.%20In%201974%2C%20the%20Travel%20Services%20Branch%20was%20in%20turn%20replaced%20with%20the%20Tourism%20Marketing%20Branch.>;
