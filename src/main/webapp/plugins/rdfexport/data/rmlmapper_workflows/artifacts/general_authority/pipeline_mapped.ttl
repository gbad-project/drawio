<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Education%20%281972-1993%29.%20Research%20Branch>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Research%20Branch%20was%20responsible%20for%20the%20Ontario%20Ministry%20of%20Education%27s%20educational%20research%20program.%20The%20Research%20Branch%20developed%20systems%20that%20would%20evaluate%20Ministry%20of%20Education%20programs%20and%20the%20provincial%20education%20system.%20The%20Research%20Branch%20was%20also%20responsible%20for%20the%20Information%20Centre%20of%20the%20Ministry%20of%20Education%20and%20for%20the%20Ontario%20Education%20Resources%20Information%20Systems%20%28ONTERIS%29%2C%20which%20developed%20data%20bases%20providing%20information%20on%20education%20research%20and%20documents.%20The%20Research%20Branch%20provided%20similar%20services%20to%20the%20Ministry%20of%20Colleges%20and%20Universities.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Research%20Branch>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Education%20%281972-1993%29>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA1635>;
  rico:hasSuccessor <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Education%20%281972-1993%29.%20Research%20and%20Information%20Branch>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Research%20Branch%20of%20the%20Ministry%20of%20Education%20was%20created%20in%201981%20and%20resulted%20from%20a%20combination%20of%20the%20Research%20and%20Evaluation%20Branch%20and%20the%20Information%20Centre%20%28previously%20named%20the%20Information%20Resources%20Centre%29.%20The%20Research%20Branch%20was%20part%20of%20the%20Planning%20and%20Policy%20Analysis%20Division.%20The%20Research%20Branch%20ceased%20to%20exist%20when%20it%20was%20merged%20with%20the%20Statistical%20Information%20Services%20Unit%20of%20the%20former%20Management%20Information%20Systems%20Branch%20to%20form%20the%20Research%20and%20Information%20Branch%2C%20effective%20January%201%2C%201984.>;
