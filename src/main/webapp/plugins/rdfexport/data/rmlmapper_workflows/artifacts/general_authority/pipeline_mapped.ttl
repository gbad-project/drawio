<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario%20Committee%20on%20Student%20Awards>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20primary%20mandate%20of%20the%20Ontario%20Committee%20on%20Student%20Awards%20was%20%22to%20ensure%20a%20clear%20articulation%20of%20the%20financial%20arrangements%20that%20will%20be%20required%20to%20ensure%20that%20all%20students%20have%20the%20necessary%20resources%20to%20undertake%20post-secondary%20education.%22%20%20A%20full%20statement%20of%20the%20%22Terms%20of%20Reference%22%20can%20be%20found%20in%20Appendix%20B-1%20of%20the%20Annual%20Report%2C%20University%20Affairs%2C%201969-70%2C%20p.%2021.%20In%20addition%20to%20the%20detailed%20study%20of%20current%20programs%20of%20student%20financial%20assistance%2C%20the%20Committee%20initiated%20several%20research%20projects%2C%20resulting%20in%20the%20preparation%20of%20the%20Cook-Stager%20Report%20%28A%20Study%20of%20Programs%20for%20Financial%20Assistance%20to%20Students%20in%20the%20Province%20of%20Ontario%29%2C%20part%20of%20which%20was%20developed%20as%20the%20Clarke-Kent%20Report%20%28Student%20Aid%20and%20Access%20to%20Higher%20Education%20in%20Ontario%29.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Ontario%20Committee%20on%20Student%20Awards>,
    <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Ontario%20Student%20Awards%20Committee.>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Dept.%20of%20University%20Affairs>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA147>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Ontario%20Committee%20on%20Student%20Awards%20was%20first%20appointed%20by%20the%20Minister%20of%20University%20Affairs%20in%201966%20as%20an%20ad%20hoc%20advisory%20board%20on%20policies%20relating%20to%20financial%20assistance%20to%20students%20in%20all%20areas%20of%20post-secondary%20education.%20The%20committee%20was%20broadly%20representative%20of%20the%20academic%20community%20in%20Ontario%2C%20including%20administrators%2C%20faculty%20and%20students%20from%20both%20the%20universities%20and%20colleges%20of%20applied%20arts%20and%20technology%20as%20well%20as%20members%20of%20the%20Department%20and%20of%20the%20Association%20of%20Student%20Awards%20Officers.%20The%20Committee%20appears%20to%20have%20been%20alternatively%20known%20as%20The%20Ontario%20Student%20Awards%20Committee%20%28OSAC%29.%20It%20continued%20to%20exist%20after%20the%20formation%20of%20the%20Department%20%28later%20Ministry%29%20of%20Colleges%20and%20Universities%20in%201971.%20After%20an%20internal%20review%20by%20the%20Management%20Committee%20of%20the%20Ministry%20of%20Colleges%20and%20Universities%20in%201974%2C%20the%20Committee%20on%20Student%20Awards%20was%20replaced%20by%20a%20joint%20subcommittee%20of%20the%20Ontario%20Comittee%20on%20University%20Affairs%20and%20the%20Council%20of%20Regents.%20The%20Committee%20on%20Student%20Awards%20voted%20itself%20out%20of%20existence%20in%20February%201974%20and%20dissolved%20on%20March%2031%2C%201974.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/CA147>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario%20Committee%20on%20Student%20Awards> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario%20Concentrated%20Milk%20Producers%27%20Marketing%20Board>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Ontario%20Manufactured%20Milk%20Producers%27%20Association%20.>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#Corporate%20Name>;
  rico:hasSuccessor <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Dairy%20Farmers%20of%20Ontario>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20future%20Ontario%20Concentrated%20Milk%20Producers%27%20Marketing%20Board%20began%20when%20concentrated%20milk%20producers%20were%20represented%20on%20the%20Board%20of%20the%20Ontario%20Milk%20and%20Cream%20Producers%27%20Association%20from%201917%20to%201932.%20From%201933%20to%201934%2C%20these%20producers%20were%20supported%20by%20the%20Ontario%20Whole%20Milk%20Producers%27%20Association.%20In%201934%2C%20the%20Ontario%20Manufactured%20Milk%20Producers%27%20Association%20was%20created%20to%20establish%20minimum%20milk%20prices.%20In%201937%2C%20their%20name%20was%20changed%20to%20the%20Ontario%20Concentrated%20Producers%27%20Association.%20The%20Association%20became%20incorporated%20under%20the%20Agricultural%20Associations%20Act%20in%201944.%20As%20a%20result%20of%20the%20Farm%20Products%20Marketing%20Act%2C%20the%20Association%27s%20name%20changed%20in%201954%20to%20the%20Ontario%20Concentrated%20Milk%20Producers%27%20Marketing%20Board.%20The%20Ontario%20Concentrated%20Milk%20Producers%27%20Marketing%20Board%20surrendered%20its%20charter%20in%201966%20with%20its%20assets%20and%20liabilities%20being%20transferred%20to%20the%20Ontario%20Milk%20Marketing%20Board.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario%20Concentrated%20Milk%20Producers%27%20Marketing%20Board> .

