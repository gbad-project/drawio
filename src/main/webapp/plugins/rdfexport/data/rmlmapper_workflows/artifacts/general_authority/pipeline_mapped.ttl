<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Energy%20Division>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Energy%20Division%20provided%20a%20structure%20for%20identifying%20strategic%20issues%2C%20coordinating%20policy%20and%20program%20development%20and%20integrating%20interaction%20between%20the%20ministry%20and%20other%20governments%20on%20issues%20related%20to%20affordable%20energy%2C%20energy%20regulation%20and%20economic%20growth%2C%20among%20others.>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Energy%2C%20Science%20and%20Technology>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA2181>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Energy%20Division%20was%20formed%20in%201997%20as%20part%20of%20the%20newly%20created%20Ministry%20of%20Energy%2C%20Science%20and%20Technology%20out%20of%20portions%20of%20the%20Policy%20Division%20of%20the%20former%20Ministry%20of%20Environment%20and%20Energy.%20At%20various%20times%20during%20its%20history%2C%20the%20Energy%20Division%20included%20the%20Electricity%20Policy%20Branch%3B%20the%20Electricity%20Restructuring%20Office%3B%20the%20Energy%20Policy%20Branch%3B%20the%20Energy%20Economics%20and%20Financial%20Analysis%20Section%20and%20the%20Oil%20and%20Gas%20Section%2C%20among%20others.%20The%20Energy%20Division%20was%20placed%20back%20under%20the%20Ministry%20of%20Environment%20and%20Energy%20when%20that%20Ministry%20was%20briefly%20re-established%20from%20April%202002-August%202002.%20The%20Energy%20Division%20continued%20to%20exist%20as%20part%20of%20the%20newly%20created%20Ministry%20of%20Energy%20in%202003%20but%2C%20in%202004%2C%20its%20responsibilities%20were%20transferred%20to%20the%20Office%20of%20Energy%20Supply%20and%20Conservation.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/CA2181>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario.%20Energy%20Division> .

