  rico:hasSuccessor <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Lands%20and%20Surveys%20Branch>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Division%20of%20Surveys%20of%20the%20Ontario%20Department%20of%20Lands%20and%20Forests%20was%20renamed%20the%20Division%20of%20Surveys%20and%20Engineering%20in%201944%2C%20when%20it%20was%20given%20responsibility%20over%20the%20leasing%20of%20water%20power%20on%20Crown%20lands%20and%20authority%20to%20approve%20plans%20for%20the%20construction%20of%20dams.%20The%20Division%20was%20headed%20by%20C.H.%20Fullerton%20%281944-1947%29%2C%20and%20by%20F.W.%20Beatty%20from%201947-1957.%20The%20Division%20consisted%20of%20two%20sections%20-%20the%20Ground%20Surveys%20Section%20and%20the%20Aerial%20Surveys%20Section.%20On%20December%201%2C%201957%2C%20the%20Division%20of%20Surveys%20and%20Engineering%20and%20the%20Division%20of%20Lands%20were%20amalgamated%20under%20the%20title%20of%20the%20Division%20of%20Surveys%20%28renamed%20the%20Lands%20and%20Surveys%20Branch%20in%201960%29.>;
