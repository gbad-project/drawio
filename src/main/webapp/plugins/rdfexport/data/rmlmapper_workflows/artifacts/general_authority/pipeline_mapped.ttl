  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Operations%20Branch%20administered%20the%20construction%20and%20maintenance%20of%20King%27s%20Highways%20and%20secondary%20roads%20in%20Ontario.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Operations%20Branch>,
    <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Ontario.%20Dept.%20of%20Transportation%20and%20Communications.%20Operations%20Branch>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Dept.%20of%20Highways>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA1113>;
  rico:hasSuccessor <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Transportation%20and%20Communications.%20Operations%20Division>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Operations%20Branch%20was%20established%20in%201954%20within%20the%20Ontario%20Department%20of%20Highways.%20The%20Operations%20Branch%20was%20comprised%20of%20three%20sections%20%28later%20called%20divisions%29%3A%20Construction%3B%20%20Maintenance%3B%20and%20Materials%20and%20Research%20%28in%201964%2C%20Material%20and%20Research%20was%20divided%20into%20two%20offices%2C%20one%20of%20which%20-%20the%20Materials%20Testing%20Office%20-%20remained%20within%20the%20Operations%20Branch%29.%20In%201962%20the%20Municipal%20Roads%20Division%20was%20added%20to%20the%20branch.%20In%201971%2C%20the%20Operations%20Branch%20became%20part%20of%20the%20Ontario%20Department%20of%20Transportation%20and%20Communications.%20In%201972%2C%20the%20Operations%20Branch%20was%20replaced%20by%20the%20Operations%20Division%2C%20within%20the%20Ontario%20Ministry%20of%20Transportation%20and%20Communications.>;
