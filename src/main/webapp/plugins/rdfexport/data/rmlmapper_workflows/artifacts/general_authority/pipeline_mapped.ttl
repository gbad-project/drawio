  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Hamilton%20Normal%20School%20was%20an%20educational%20institution%20which%20trained%20teachers%2C%20primarily%20for%20the%20primary%20level%20of%20schools.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Hamilton%20Normal%20School>,
    <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Hamilton%20Teachers%20College.>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#B%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/BA700>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Hamilton%20Normal%20School%20was%20established%20in%201908.%20In%201953%2C%20the%20Hamilton%20Normal%20School%20became%20known%20as%20the%20Hamilton%20Teachers%27%20College%20%28all%20Normal%20Schools%20were%20re-named%20Teachers%27%20Colleges%20at%20this%20time%29.%20In%201974%2C%20the%20Hamilton%20Teachers%27%20College%20was%20reorganized%20as%20the%20Hamilton%20campus%20of%20the%20newly%20created%20Ontario%20Teacher%20Education%20College%3B%20there%20was%20also%20a%20Toronto%20campus.%20In%201979%2C%20the%20Ontario%20Teacher%20Education%20College%2C%20including%20the%20Hamilton%20campus%2C%20was%20closed.%20The%20Hamilton%20building%2C%20beside%20McMaster%20University%2C%20was%20sold%20to%20the%20Hamilton-Wentworth%20Roman%20Catholic%20Separate%20School%20Board%20for%20use%20as%20a%20high%20school.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/BA700>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Hamilton%20Normal%20School%20%28Ont.%29> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Hoy%2C%20Claire%2C%201940-> a
