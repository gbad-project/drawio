  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Principe%20Umberto%20Lodge%20of%20the%20Order%20Sons%20of%20Italy%20of%20Canada%20was%20established%20in%201917%20in%20St.%20Catharines.%20In%201938%2C%20after%20the%20Order%20underwent%20a%20significant%20period%20of%20growth%2C%20Principe%20Umberto%20divided%20to%20allow%20for%20the%20formation%20of%20a%20separate%20lodge%20for%20its%20female%20members.%20This%20lodge%2C%20called%20Savoia%2C%20lasted%20under%20ten%20years%2C%20after%20which%20time%20it%20was%20re-incorporated%20into%20the%20main%20lodge.%20The%20Principe%20Umberto%20Lodge%20was%20unable%20to%20re-build%20its%20membership%20after%20WWII%20and%20it%20consequently%20dissolved%20in%20the%20early%201971.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Order%20Sons%20of%20Italy%20of%20Canada.%20Principe%20Umberto%20Lodge%20%28St.%20Catharines%2C%20Ont.%29> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ryde%20%28Ont.%20%3A%20Township%29>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#Corporate%20Name>;
  rico:history <https://data.archives.gov.on.test.gbad.caThis%20Act%20permitted%20communities%20to%20petition%20the%20Legislative%20Assembly%20or%20county%20for%20incorporation%20as%20townships%2C%20towns%20or%20villages%20on%20reaching%20specified%20population%20levels.%20An%20incorporated%20township%2C%20lower%20tier%20municipality%2C%20has%20a%20council%20consisting%20of%20an%20elected%20Reeve%2C%20Deputy%20Reeves%2C%20and%20councillors%20the%20number%20of%20which%20depend%20on%20the%20population%20of%20the%20township.%20Its%20responsibilities%20relate%20largely%20to%20the%20upkeep%20of%20the%20local%20road%20system%20and%20the%20delivery%20of%20services%20such%20as%20water%20and%20sewage.%20It%20has%20wide%20powers%20relating%20to%20the%20regulation%20of%20land%20and%20local%20administration%20through%20by-laws.%20It%20has%20the%20power%20to%20raise%20money%20through%20direct%20taxation%20on%20land%20and%20through%20the%20use%20of%20debentures.%20The%20Township%20of%20Ryde%20was%20dissolved%20and%20incorporated%20into%20the%20Town%20of%20Gravenhurst%20in%201971%20under%20the%20District%20Municipality%20of%20Muskoka%20Act%2C%20Ontario%20Statutes%201970%2C%20Chapter%2032.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ryde%20%28Ont.%20%3A%20Township%29> .

