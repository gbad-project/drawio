<https://data.archives.gov.on.test.gbad.ca/KB/Place/Oneida%20%28Ont.%20%3A%20Township%29>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Place>,
    rico:Place;
  rdfs:label <https://data.archives.gov.on.test.gbad.caOneida%20%28Ont.%20%3A%20Township%29 (Place)>,
    "";
  rico:history <https://data.archives.gov.on.test.gbad.caThis%20act%20provided%20for%20the%20creation%20of%20municipal%20governments%20at%20the%20town%2C%20village%20and%20township%20levels%20and%20identified%20those%20which%20would%20automatically%20be%20granted%20municipal%20status%20when%20the%20act%20came%20into%20effect%2C%20January%201%2C%201850.%20Communities%20not%20named%20in%20the%20original%20act%20could%20petition%20the%20county%20council%20or%20legislative%20assembly%20for%20incorporation%20on%20reaching%20specified%20population%20levels.%20An%20incorporated%20township%2C%20lower%20tier%20municipality%2C%20has%20a%20council%20consisting%20of%20an%20elected%20Reeve%2C%20Deputy%20Reeves%2C%20and%20councillors%20the%20number%20of%20which%20depend%20on%20the%20population%20of%20the%20township.%20Its%20responsibilities%20relate%20largely%20to%20the%20upkeep%20of%20the%20local%20road%20system%20and%20the%20delivery%20of%20services%20such%20as%20water%20and%20sewage.%20It%20has%20wide%20powers%20relating%20to%20the%20regulation%20of%20land%20and%20local%20administration%20through%20by-laws.%20It%20has%20the%20power%20to%20raise%20money%20through%20direct%20taxation%20on%20land%20and%20through%20the%20use%20of%20debentures.%20The%20Township%20was%20dissolved%20in%201974%20and%20amalgamated%20into%20the%20new%20Town%20of%20Haldimand%20in%20the%20Regional%20Municipality%20of%20Haldimand-Norfolk%20under%20Ontario%20Statutes%201973%2C%20Chapter%2096.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Oneida%20%28Ont.%20%3A%20Township%29> .

