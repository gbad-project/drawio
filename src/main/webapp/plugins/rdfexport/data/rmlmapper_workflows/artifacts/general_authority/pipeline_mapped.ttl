<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Employment%20Service%20Council%20of%20Ontario>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Employment%20Service%20Council%20of%20Ontario%20was%20designed%20to%20made%20recommendations%20to%20the%20Minister%20of%20Labour%20with%20regards%20to%20the%20establishment%20and%20operation%20of%20Ontario%20offices%20of%20the%20Employment%20Service%20of%20Canada.%20The%20council%20divided%20itself%20into%20three%20committees%3A%20one%20for%20general%20administration%20of%20the%20Employment%20Service%3B%20one%20for%20Private%20Employment%20Agencies%3B%20and%20one%20for%20other%20questions%20of%20public%20policy>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Employment%20Service%20Council%20of%20Ontario>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#B%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/BA592>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Employment%20Service%20Council%20of%20Ontario%20was%20established%20on%20August%203%2C%201922.%20It%20is%20not%20known%20how%20long%20the%20council%20continued%20in%20operation%20but%20it%20appears%20in%20the%20annual%20reports%20up%20until%20about%201940.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/BA592>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Employment%20Service%20Council%20of%20Ontario> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Fraser%2C%20Frederick%20George%20Mackenzie%2C%20fl.%201878-1889>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Person>,
    rico:Person;
  rdfs:label <https://data.archives.gov.on.test.gbad.caFraser%2C%20Frederick%20George%20Mackenzie%2C%20fl.%201878-1889 (Person)>,
    "";
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Fraser%2C%20Frederick%20G.%20M.>;
  rico:history <https://data.archives.gov.on.test.gbad.caHis%20duty%20was%20to%20enforce%20the%20issuing%20of%20licenses%20and%20the%20confiscation%20of%20the%20gear%20of%20violators.%20In%201884%20he%20reported%20that%20the%20Muskoka%20Lumber%20Mills%20was%20dumping%20sawdust%20into%20the%20Muskoka%20River%2C%20which%20led%20to%20the%20trial%20and%20conviction%20of%20the%20mill%27s%20owner%2C%20Trueman%20Aldrich.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Fraser%2C%20Frederick%20George%20Mackenzie%2C%20fl.%201878-1889> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Gilling%2C%20Walter%20J.%2C%201906-1993>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Person>,
    rico:Person;
  rdfs:label <https://data.archives.gov.on.test.gbad.caGilling%2C%20Walter%20J.%2C%201906-1993 (Person)>,
    "";
  rico:history <https://data.archives.gov.on.test.gbad.caWalter%20J.%20Gilling%20was%20born%20in%20Edinburgh%2C%20Scotland%20to%20Sergeant%20Richard%20Gilling%20and%20Clara%20Maude%20Gilling.%20Richard%20Gilling%20was%20captured%20at%20Mons%2C%20France%20during%20the%20First%20World%20War%20and%20underwent%20serious%20privations%20as%20a%20prisoner%20of%20war.%20He%20was%20repatriated%20to%20Switzerland%20in%201917%20and%20returned%20to%20England%20in%201918.%20He%20immigrated%20to%20Canada%20in%201918%20and%20he%20became%20the%20Chief%20of%20Police%20in%20Ingersoll%2C%20Ontario%20and%20later%20Watford.%20Walter%20J.%20Gilling%2C%20left%20school%20at%20the%20age%20of%20fourteen%20and%20began%20working%20for%20the%20Ingersoll%20File%20Company.%20He%20travelled%20to%20England%20looking%20for%20work%20unsuccessfully%20in%201923%2C%20drove%20a%20truck%20for%20the%20Ingersoll%20Tool%20and%20Machine%20Company%20and%20worked%20as%20a%20harvest%20labourer%20in%20Saskatchewan.%20He%20returned%20home%20in%201929%20and%20worked%20at%20J.C.%20Labatt%20Company%20in%20order%20to%20save%20money%20for%20divinity%20college.%20He%20was%20admitted%20to%20Trinity%20College%20in%201931%20and%20graduated%20with%20a%20licentiate%20of%20theology%20in%201935.%20Walter%20J.%20Gilling%20served%20as%20an%20assistant%20curate%20at%20St.%20John%20the%20Evangelist%20Anglican%20Church%20in%20Peterborough%2C%20Ontario%20where%20he%20joined%20the%20Canadian%20Chaplain%20Service%20in%20the%20Militia%20and%20served%20as%20chaplain%20of%20the%204th%20Machine%20Gun%20Battalion.%20He%20moved%20to%20Toronto%20and%20was%20appointed%20chaplain%20at%20Trinity%20College%20in%201937.%20With%20the%20outbreak%20of%20war%20in%201939%2C%20Gilling%20volunteered%20for%20service%20and%20went%20to%20England%20as%20chaplain%20of%20the%20Toronto%20Scottish%20Regiment.%20He%20returned%20to%20Canada%20in%20October%201946%20having%20served%20as%20Principal%20Chaplain%20Overseas%20since%20November%201945.%20In%20his%20time%20overseas%2C%20Gilling%20served%20with%20the%20Toronto%20Scottish%2C%20the%20Hastings%20and%20Prince%20Edward%20Regiment%2C%20The%20Royal%20Canadian%20Dragoons%2C%20in%20several%20capacities%20with%20the%20Central%20Mediterranean%20Forces%2C%20The%20Canadian%20Army%20in%20North%20West%20Europe%20and%20at%20The%20Canadian%20Military%20Headquarters%20in%20London%2C%20England.%20After%20the%20war%20Gilling%20became%20Rector%20of%20St.%20Luke%27s%20Anglican%20Church%20in%20Peterborough%20%281946-1956%29%20and%20was%20appointed%20Archdeacon%20of%20Peterborough%20in%201955.%20He%20moved%20to%20Toronto%20and%20was%20Archdeacon%20of%20the%20Diocese%20of%20Toronto%20from%201956%20to%201961%20and%20Rector%20of%20the%20Cathedral%20Church%20of%20St.%20James%20and%20the%20Dean%20of%20Toronto%20%281961-1973%29.%20Walter%20J.%20Gilling%20married%20Phyllis%20%28nee%20Douglas%29%20Gilling%20in%201945%20and%20raised%20his%20stepson%20Alec%20Douglas.%20He%20married%20Kathleen%20%28nee%20English%29%20Gilling%20in%201968.%20Walter%20J.%20Gilling%20died%20in%201993.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Gilling%2C%20Walter%20J.%2C%201906-1993> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Grobb%2C%20Reita%20Margaret%20%281910-1988%29>
