  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Trade%20Division%20was%20responsible%20for%20the%20promotion%20of%20exports%20of%20Ontario%20products%20internationally.%20This%20was%20accomplished%20through%20export%20seminars%2C%20trade%20missions%20and%20fairs%2C%20market%20research%2C%20and%20policy%20advocacy.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Trade%20Division>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Industry%20and%20Trade>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA933>;
  rico:hasSuccessor <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Industry%20and%20Trade%20Expansion>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Trade%20Division%20was%20formed%20when%20the%20Ministry%20of%20Industry%20and%20Tourism%20was%20replaced%20by%20the%20Ministry%20of%20Industry%20and%20Trade%20in%201982.%20It%20had%20no%20immediate%20predecessor%2C%20but%20acquired%20some%20functions%20from%20the%20Industry%20Division%20%28which%20continued%20to%20exist%20after%201982%29%20and%20from%20the%20Policy%20and%20Priorities%20Division.%20Within%20the%20new%20division%2C%20two%20branches%20were%20created%3A%20the%20International%20Trade%20and%20Investment%20Branch%2C%20and%20the%20Trade%20Policy%20and%20Analysis%20Branch.%20The%20division%20was%20also%20responsible%20for%20administering%20the%20international%20offices%20of%20the%20ministry.%20The%20Trade%20Division%20ceased%20to%20exist%20when%20parts%20of%20the%20Trade%20Division%20and%20the%20Industry%20Division%20were%20combined%20together%20in%20a%20single%2C%20new%20division%20in%20November%2C%201986%2C%20known%20as%20Industry%20and%20Trade%20Expansion.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/CA933>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario.%20Ministry%20of%20Industry%20and%20Trade.%20Trade%20Division> .

