<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Dept.%20of%20Lands%20and%20Forests>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Department%20of%20Lands%20and%20Forests%20was%20responsible%20for%20developing%2C%20administering%2C%20and%20regulating%20the%20Crown%20Lands%2C%20forests%2C%20fish%20and%20wildlife%20of%20the%20Province.%20Specific%20responsibilities%20of%20the%20Department%20included%20forest%20protection%20and%20forest%20fire%20fighting%2C%20control%20and%20sale%20of%20crown%20lands%2C%20reforestation%20and%20timber%20management%2C%20and%20research%20into%20forest%20management.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Department%20of%20Lands%20and%20Forests>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#A%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/AA52>;
  rico:hasSuccessor <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Natural%20Resources>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Department%20of%20Lands%20and%20Forests%20was%20established%20in%201920%2C%20when%20the%20Bureau%20of%20Mines%20of%20the%20former%20Department%20of%20Lands%2C%20Forests%20and%20Mines%20was%20elevated%20into%20a%20separate%20department.%20The%20Department%20was%20presided%20over%20by%20the%20Minister%20of%20Lands%20and%20Forests%2C%20who%20was%20assisted%20by%20a%20Deputy%20Minister%20and%20a%20number%20of%20Divisional%20Chiefs.%20Most%20of%20the%20former%20non-mine%20functions%20of%20the%20Department%20of%20Lands%2C%20Forests%20and%20Mines%20were%20continued%20by%20the%20Department%20of%20Lands%20and%20Forests.%20An%20exception%20to%20this%2C%20however%2C%20was%20the%20transfer%20of%20the%20Colonization%20and%20Immigration%20Branch%20to%20the%20Department%20of%20Agriculture%20in%201920.%20In%201926%2C%20the%20Northern%20Development%20Branch%20was%20also%20removed%20from%20the%20Department%20of%20Lands%20and%20Forests%20and%20established%20as%20the%20Department%20of%20Northern%20Development.%20Although%20a%20separate%20Minister%20was%20given%20direction%20over%20this%20Department%2C%20the%20Department%20was%20still%20required%20to%20submit%20its%20annual%20reports%20to%20the%20Minister%20of%20Lands%20and%20Forests%20until%201935.%20In%201941%2C%20the%20Department%20was%20considerably%20reorganized%2C%20and%20many%20of%20the%20branches%20of%20the%20Department%20were%20restructured%20as%20divisions.%20The%20Forestry%20Branch%20was%20divided%20into%20three%20new%20divisions%20-%20the%20Division%20of%20Forest%20Protection%2C%20the%20Division%20of%20Air%20Services%2C%20and%20the%20Division%20of%20Reforestation%3B%20the%20Lands%20Branch%20was%20renamed%20the%20Division%20of%20Land%20and%20Recreational%20Areas%3B%20the%20Surveys%20Branch%20was%20renamed%20the%20Division%20of%20Surveys%3B%20the%20Accounts%20Branch%20was%20renamed%20the%20Division%20of%20Accounts%3B%20and%20the%20Woods%20and%20Forest%20Branch%20was%20renamed%20the%20Division%20of%20Timber%20Management.%20Two%20new%20divisions%20-%20the%20Division%20of%20Law%20and%20the%20Division%20of%20Research%20-%20were%20also%20created%20at%20this%20time.%20Further%20developments%20within%20the%20Department%2C%20between%201941%20and%201972%2C%20included%20the%20transfer%20of%20the%20Games%20and%20Fisheries%20Department%20to%20the%20Department%20of%20Lands%20and%20Forests%2C%20and%20its%20subsequent%20renaming%20as%20the%20Division%20of%20Fish%20and%20Wildlife%2C%20in%201946%3B%20the%20separation%20of%20the%20Division%20of%20Lands%20and%20Recreational%20Parks%20into%20the%20Division%20of%20Lands%20and%20the%20Division%20of%20Parks%2C%20in%201954%3B%20the%20transfer%20of%20the%20Conservation%20Authorities%20Branch%20from%20the%20Department%20of%20Planning%20and%20Development%20in%201962%3B%20and%20the%20renaming%20of%20many%20of%20the%20divisions%20of%20the%20Department%20as%20branches%2C%20in%201959.%20The%20Department%20existed%20until%201972%2C%20when%20it%20amalgamated%20with%20the%20Department%20of%20Mines%20and%20Northern%20Affairs%20to%20form%20the%20Ministry%20of%20Natural%20Resources.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/AA52>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario.%20Dept.%20of%20Lands%20and%20Forests>;
  rico:isSuccessorOf <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Dept.%20of%20Lands%2C%20Forests%20and%20Mines>;
  rico:thingIsSourceOfRelation </KB/AgentControlRelation/Ontario.%20Dept.%20of%20Lands%20and%20Forests/Ontario.%20Dept.%20of%20Lands%20and%20Forests.%20Division%20of%20Surveys%20and%20Engineering/urn:uuid:5edbe9a2-1ae1-58ae-b978-ba7d9a23e3a6>,
    </KB/AgentControlRelation/Ontario.%20Dept.%20of%20Lands%20and%20Forests/Ontario.%20Division%20of%20Reforestation/urn:uuid:5edbe9a2-1ae1-58ae-b978-ba7d9a23e3a6>,
