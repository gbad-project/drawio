<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Milton%20Jail%20%28Ont.%29> a
    owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Milton%20Jail%20was%20a%20%20maximum%20security%20correctional%20facility%20providing%20short%20term%2C%20secure%20custody%20for%20persons%20awaiting%20trial%20or%20sentencing%2C%20those%20being%20held%20for%20immigration%20hearings%20or%20deportation%2C%20those%20serving%20short%20sentences%20%28under%2090%20days%29%20and%20those%20awaiting%20transfer%20to%20other%20Ontario%20correctional%20institutions%20or%20to%20federal%20institutions.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Milton%20Jail>,
    <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Milton%20Gaol%20%28Ont.%29>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#B%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/BA409>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Milton%20Jail%20was%20opened%20in%201863%20and%20closed%20in%201978.%20Until%201968%2C%20all%20jails%20in%20Ontario%20were%20administered%20locally%20through%20municipal%20bodies%20under%20the%20guidance%20of%20the%20Ontario%20provincial%20government.%20Responsibility%20for%20jails%20within%20the%20government%20fell%20to%20the%20Office%20of%20the%20Inspector%20of%20Prisons%20and%20Public%20Charities%20%281868-1934%29%2C%20the%20Reformatories%20and%20Prisons%20Branch%20of%20the%20Department%20of%20the%20Provincial%20Secretary%20%281934-1946%29%2C%20and%20the%20Department%20of%20Reform%20Institutions%20%281946-1968%29.%20In%201968%2C%20their%20administration%20was%20assumed%20directly%20by%20the%20provincial%20government.%20Since%20then%2C%20jails%20have%20been%20administered%20within%20the%20Department%20of%20Correctional%20Services%20%281968-1972%29%2C%20and%20the%20Ministry%20of%20Correctional%20Services%20%281972-1993%29.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/BA409>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Milton%20Jail%20%28Ont.%29> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Montaigne%2C%20Bill%2C%201915-1988>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Person>,
    rico:Person;
  rdfs:label <https://data.archives.gov.on.test.gbad.caMontaigne%2C%20Bill%2C%201915-1988 (Person)>,
    "";
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Montaigne%2C%20William%20J.>;
  rico:history <https://data.archives.gov.on.test.gbad.caBorn%20in%20Montreal%2C%20Quebec%20Montaigne%20graduated%20in%201936%20from%20St.%20James%20College%20in%20Minneapolis%2C%20Minnesota%20with%20a%20B.A.%20in%20journalism.%20After%20graduation%20he%20worked%20as%20a%20freelance%20journalist%20for%20a%20number%20of%20major%20American%20newspapers%20and%20magazines%2C%20and%20also%20wrote%20radio%20scripts.%20Montaigne%20served%20in%20World%20War%20Two%20as%20a%20member%20of%20a%20Canadian%20artillery%20unit%2C%20and%20while%20in%20Scotland%2C%20married%20Barbara%20Malcolm%20Hope%2C%20a%20native%20of%20Pembroke%2C%20Ontario.%20After%20the%20war%20ended%2C%20they%20settled%20in%20Pembroke%2C%20and%20Montaigne%20began%20work%20with%20radio%20station%20CHOV%20as%20a%20commercial%20representative%2C%20involved%20in%20advertising%2C%20news%20gathering%2C%20writing%20and%20producing.%20In%201948%20Bill%20and%20Barbara%20Montaigne%20opened%20Montaigne%27s%20Flowers%2C%20Gifts%20and%20Photography%20Shop%2C%20where%20he%20focussed%20primarily%20on%20photographing%20local%20events.%20In%20the%201950s%20the%20photography%20part%20of%20the%20business%20expanded%20to%20include%20film%20productions%2C%20sound%20recordings%2C%20and%20television%20journalism%2C%20with%20Montaigne%20freelancing%20for%20CBC%20television.%20He%20also%20became%20more%20active%20in%20photojournalism%2C%20contributing%20work%20for%20magazines%2C%20journals%2C%20and%20local%20newspapers.%20In%20the%201970s%20Montaigne%20involved%20himself%20more%20in%20commercial%20photography%2C%20focussing%20upon%20weddings%2C%20portraits%20and%20graduations.%20In%201979%20he%20published%20a%20book%20entitled%20%22How%20to%20Begin%20and%20Operate%20a%20Successful%20Commercial%20Photography%20Business.%22%20Montaigne%20operated%20his%20photography%20business%20until%20his%20death%20in%201988.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Montaigne%2C%20Bill%2C%201915-1988> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/North%20Bay%20Psychiatric%20Hospital%20%28Ont.%29>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20North%20Bay%20Psychiatric%20Hospital%20functioned%20as%20an%20accredited%20mental%20health%20facility%20providing%20inpatient%20programs%2C%20community%20programs%20and%20services%2C%20and%20consultation%20and%20education%20programs.%20North%20Bay%20also%20provided%20curriculum%20training%20in%20Chronic%20Care%20psychiatry%20sponsored%20by%20the%20University%20of%20Western%20Ontario.%20The%20hospital%20was%20also%20used%20by%20many%20nursing%20programs%20in%20the%20region%20for%20their%20psychiatric%20training.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/North%20Bay%20Psychiatric%20Hospital%20%28Ont.%29>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#B%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/BA611>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20North%20Bay%20Psychiatric%20Hospital%20%28NBPH%29%20was%20established%20in%20October%201957%20by%20the%20Mental%20Health%20Division%20of%20the%20Department%20of%20Health.%20Encompassing%20Northeastern%20Ontario%2C%20NBPH%27s%20catchment%20area%20covered%20close%20to%20one%20third%20of%20the%20province%20of%20Ontario.%20Inpatient%20services%20were%20provided%20through%20four%20functional%20programs%3A%20District%20Mental%20Health%20Program%2C%20Regional%20Specialized%20Mental%20Health%20Program%2C%20Seniors%27%20Mental%20Health%20Program%20and%20the%20Forensic%20Program.%20In%20addition%20to%20its%20acute%20care%20role%2C%20the%20hospital%20served%20as%20the%20region%27s%20tertiary%20care%20centre%20with%20a%20large%20proportion%20of%20beds%20dedicated%20to%20long%20term%20rehabilitation%20and%20care%20of%20those%20with%20serious%20mental%20illness.%20Care%20and%20treatment%20of%20the%20mentally%20disordered%20offender%20population%20and%20patients%20referred%20by%20the%20courts%20was%20an%20important%20service%20of%20the%20hospital.%20Small%20rural%20and%20isolated%20areas%20depended%20heavily%20on%20NBPH%20for%20the%20provision%20of%20acute%20care%20services.%20The%20Northeastern%20Regional%20Mental%20Health%20Centre%20was%20closed%20March%2031%2C%201975%3A%20patients%20were%20transferred%20to%20the%20North%20Bay%20Psychiatric%20Hospital.%20The%20Hospital%20was%20divested%20by%20the%20Ministry%20of%20Health%20and%20Long-Term%20Care%20on%2021%20November%202005.%20It%20was%20known%20as%20the%20North%20Bay%20site%20of%20the%20Northeast%20Mental%20Health%20Centre%20until%201%20April%202011%20when%20the%20Northeast%20Mental%20Health%20Centre%20amalgamated%20with%20the%20North%20Bay%20General%20Hospital.%20It%20is%20now%20known%20as%20the%20North%20Bay%20Regional%20Health%20Centre%20%28NBRHC%29.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/BA611>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/North%20Bay%20Psychiatric%20Hospital%20%28Ont.%29> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Northern%20Telephone%20Company>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Temiskaming%20Telephone%20Company>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#Corporate%20Name>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Northern%20Telephone%20Company%20was%20founded%20in%20New%20Liskeard%2C%20Temiskaming%20District%2C%20Ontario%20on%20April%205%2C%201905.%20It%20was%20originally%20called%20the%20Temiskaming%20Telephone%20Company.%20Its%20range%20of%20customers%20expanded%20regularly%20over%20the%20next%2050%20years%2C%20through%20purchases%20of%20other%20telephone%20companies.%20The%20first%20of%20these%20was%20the%20Kirkland%20Lake%20and%20Swastika%20Telephone%20System%2C%20bought%20in%201921.%20In%201928%20the%20company%20changed%20its%20name%20to%20Northern%20Telephone%20Company%20Limited.%20In%201966%2C%20Bell%20Canada%20acquired%20a%20controlling%20share%20in%20the%20company%20through%20stock%20purchases%2C%20although%20it%20continued%20to%20exist%20as%20a%20separate%20entity.%20In%201985%20the%20company%20was%20still%20operational.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Northern%20Telephone%20Company> .

