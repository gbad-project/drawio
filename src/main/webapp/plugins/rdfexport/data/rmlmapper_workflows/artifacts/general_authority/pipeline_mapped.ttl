<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Transportation%20Regulation%20Operations%20Division>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Transportation%20Regulation%20Operations%20Division%20regulated%20the%20licensing%20of%20vehicles%20covered%20by%20the%20Public%20Vehicles%20Act%20%28e.g.%20buses%20and%20charter%20bus%20operations%2C%20for-hire%20trucks%29.%20The%20division%20also%20monitored%20the%20performance%20and%20qualifications%20of%20Ontario%20drivers%20and%20vehicles%20and%20provided%20information%20on%20this%20to%20the%20public%2C%20courts%2C%20and%20law%20enforcement%20agencies.%20In%20addition%2C%20this%20agency%20investigated%20possible%20contraventions%20to%20various%20transportation%20acts%20and%20monitored%20the%20operation%20of%20carriers.%20After%201980%2C%20the%20division%20offered%20systems%20support%20for%20all%20agencies%20administered%20by%20the%20Safety%20and%20Regulation%20Division.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Transportation%20Regulation%20Operations%20Division>,
    <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Ontario.%20Transportation%20Regulation%20Division.>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Transportation%20and%20Communications>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA1144>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Transportation%20Regulation%20Operations%20Division%20was%20formed%20in%20January%201976%20within%20the%20Ontario%20Ministry%20of%20Transportation%20and%20Communications%2C%20assuming%20the%20administrative%20functions%20of%20the%20Licensing%20Control%20Division%20as%20well%20as%20responsibility%20for%20the%20newly%20created%20Program%20Development%20Branch.%20The%20Transportation%20Regulation%20Operations%20Division%20was%20initially%20known%20as%20the%20Transportation%20and%20Regulation%20Division%20and%20reported%20to%20the%20Assistant%20Deputy%20Minister%20of%20Drivers%20and%20Vehicles%20between%201976%20and%201979%20%28changing%20its%20name%20to%20the%20Transportation%20Regulation%20Division%20in%201977%29.%20From%201980%20until%20its%20closure%2C%20the%20Assistant%20Deputy%20Minister%20of%20Safety%20and%20Regulation%20administered%20the%20division.%20The%20agency%20changed%20its%20name%20to%20the%20Transportation%20Regulation%20Operations%20Division%20in%201981.%20The%20division%20ceased%20to%20exist%20in%201991%20when%20the%20subordinate%20branches%20that%20it%20administered%20began%20reporting%20directly%20to%20the%20Assistant%20Deputy%20Minister%20of%20the%20Safety%20and%20Regulation%20Division.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/CA1144>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario.%20Transportation%20Regulation%20Operations%20Division> .

