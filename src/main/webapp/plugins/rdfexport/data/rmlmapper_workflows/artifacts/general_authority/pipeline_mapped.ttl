<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Solski%2C%20Mike%2C%201918-1999>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Person>,
    rico:Person;
  rdfs:label <https://data.archives.gov.on.test.gbad.caSolski%2C%20Mike%2C%201918-1999 (Person)>,
    "";
  rico:history <https://data.archives.gov.on.test.gbad.caBorn%20in%20Coniston%2C%20Solski%20was%20educated%20in%20Sudbury.%20Between%201935%20and%201978%2C%20he%20was%20employed%20by%20INCO%20as%20a%20labourer%2C%20tradesman%2C%20foreman%2C%20co-ordinator%2C%20and%20Supervisor%20of%20Central%20Assets%20and%20Surplus.%20Solski%20was%20also%20active%20in%20Local%20598%20of%20the%20International%20Union%20of%20Mine%20Mill%20and%20Smelter%20Workers%2C%20serving%20as%20local%20union%20shop%20steward%2C%20organiser%2C%20vice-president%20treasurer%20and%20eventually%20president.%20He%20was%20also%20Secretary%20of%20the%20Canadian%20Mine%20Mill%20Union%20Council%20as%20well%20as%20Eastern%20Canadian%20Director%20of%20the%20International%20Mine%2C%20Mill%20and%20Smelter%20Workers.%20In%20addition%20to%20labour%20activism%2C%20Solksi%20was%20involved%20in%20local%20politics.%20In%201954%2C%20he%20became%20Councillor%20for%20Coniston%20and%2C%20in%201963%2C%20Mayor%2C%20a%20position%20he%20held%20for%20ten%20years.%20Solski%20also%20served%20as%20Mayor%20of%20Nickel%20Centre%20for%20six%20years.%20Further%2C%20he%20was%20a%20Regional%20Councillor%20and%20President%20of%20the%20Sudbury%20District%20Municipal%20Association.%20He%20also%20acted%20as%20Vice-Chairman%20of%20the%20Regional%20Municipality%20of%20Sudbury%20for%203%20years.%20Solski%20served%20on%20various%20boards%2C%20committees%20and%20commissions%20including%20the%20Hydro%20Commission%2C%20Sudbury%20Regional%20Police%20Commission%2C%20the%20Police%20Governing%20Authority%20of%20Ontario%2C%20the%20Sudbury%20General%20Hospital%20Board%20and%20the%20Canada%20Employment%20and%20Immigration%20Advisory%20Council.%20Solski%20also%20authored%20and%20co-authored%20numerous%20books%20and%20booklets%20such%20as%3A%20The%20Coniston%20Story%3B%20Mine%20Mill%20-%20The%20History%20of%20the%20International%20Union%20of%20Mine%20Mill%20and%20Smelter%20Workers%20in%20Canada%20since%201895%3B%20and%20the%20Industrial%20Communities%20of%20the%20Sudbury%20Basin%3A%20Copper%2C%20Cliff%2C%20Victoria%20Mines%2C%20Mond%20and%20Coniston.%20Solksi%20was%20married%20to%20Irene%20Horrick%20with%20whom%20he%20has%20one%20daughter%2C%20Sandra%20Spratt.%20He%20died%20in%20November%2C%201999.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Solski%2C%20Mike%2C%201918-1999> .

