<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Canniff%2C%20William%2C%201830-1910>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Person>,
    rico:Person;
  rdfs:label <https://data.archives.gov.on.test.gbad.caCanniff%2C%20William%2C%201830-1910 (Person)>,
    "";
  rico:history <https://data.archives.gov.on.test.gbad.caHe%20was%20born%20in%20Thurlow%20Township%2C%20Hastings%20County%2C%20and%20attended%20Victoria%20College%2C%20Cobourg%2C%20the%20Toronto%20School%20of%20Medicine%20and%20the%20University%20of%20New%20York%2C%20where%20he%20graduated%20in%201854.%20He%20became%20a%20member%20of%20the%20English%20Royal%20College%20of%20Surgeons%20in%201855%20and%20served%20as%20a%20medical%20officer%20in%20the%20Crimean%20War.%20On%20his%20return%20to%20Canada%2C%20he%20practised%20medicine%20at%20Belleville%20and%20Toronto.%20He%20was%20a%20professor%20of%20general%20pathology%20and%20surgery%20at%20Victoria%20College%20and%20Sub-Dean%20of%20the%20Toronto%20Medical%20School.%20He%20was%20also%20the%20first%20Medical%20Health%20Officer%20of%20Toronto%2C%201883-1891.%20Canniff%20was%20also%20the%20author%20of%20two%20historical%20works%20entitled%20A%20History%20of%20the%20early%20settlement%20of%20Upper%20Canada%20%281869%29%2C%20and%20The%20medical%20profession%20in%20Upper%20Canada%3A%20a%20historical%20narrative%20%28Toronto%2C%201894%29.%20Topics%20in%20his%20other%20papers%20included%3A%20the%20Toronto%20General%20Hospital%2C%20the%20Canadian%20Medical%20Association%2C%20Victoria%20College%2C%20settlement%20in%20Belleville%20and%20Prince%20Edward%20County%2C%20the%20Northwest%20Rebellion%20and%20historical%20societies.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Canniff%2C%20William%2C%201830-1910> .

