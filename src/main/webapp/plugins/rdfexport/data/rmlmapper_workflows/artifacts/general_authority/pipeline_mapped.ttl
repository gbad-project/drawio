<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Troster%2C%20David%2C%201949-1995>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Person>,
    rico:Person;
  rdfs:label <https://data.archives.gov.on.test.gbad.caTroster%2C%20David%2C%201949-1995 (Person)>,
    "";
  rico:history <https://data.archives.gov.on.test.gbad.caTroster%20was%20born%20in%20Toronto%20on%2012%20June%201949.%20%20From%201968%20to%201970%20he%20studied%20in%20the%20honours%20B.A.%20program%20at%20York%20University%20majoring%20in%20film.%20In%201970%2C%20while%20at%20York%20%20he%20produced%20his%20first%20independent%20film%20The%20Spell%20That%20Comes%20After.%20Between%201970%20and%201974%20he%20produced%2C%20through%20Christopher%20Chapman%20Ltd.%2C%20several%20film%20shorts%20for%20Mr.%20Rogers%27%20Neighborhood%20broadcast%20over%20PBS%20in%20the%20United%20States.%20Christopher%20Chapman%20had%20a%20mentoring%20influence%20on%20Troster%27s%20filmmaking%20career.%20%20Troster%20went%20on%20to%20serve%20as%20producer%20and%20researcher%20of%20An%20Outside%20View%20in%201973%2C%20produced%20at%20Nielsen%20Ferns%20Ltd.%2C%20a%2030%20minute%20educational%20TV%20talk%20show%20broadcast%20over%20TV%20Ontario.%20In%201975%20he%20produced%20One%20Afternoon%2C%20an%20experimental%20short%20for%20children%27s%20television%20at%20CBC.%20%20In%201976%20he%20produced%20his%20second%20independent%20film%2C%20Bubbie%20%28or%20My%20Grandmother%27s%20Film%29%2C%20a%20portrait%20of%20his%20grandmother%20Sarah%20Salsberg.%20He%20worked%20as%20a%20film%20editor%20at%20CBC%20television%20in%20Toronto%20from%201976%20to%201979.%20%20Troster%20began%20work%20on%20his%20third%20independent%20film%20Spadina%20by%201980%20and%20completed%20it%20in%201984.%20In%201980%20Troster%20formed%20his%20own%20production%20company%20in%20Toronto%2C%20David%20Troster%20Productions.%20Through%20this%20company%20he%20produced%20films%20and%20videos%20for%20corporate%20clients%20including%20medical%20and%20pharmaceutical%20companies%2C%20major%20banks%20and%20government%20agencies.%20Between%20work%20on%20corporate%20productions%2C%20Troster%20wrote%20scripts%20and%20worked%20to%20create%20films%20of%20his%20own%2C%20a%20number%20of%20%20which%20explored%20gay%20relationships%20%28Jamie%20and%20Eric%2C%20Dear%20John%2C%20Seeing%20Someone%2C%20A%20Family%20Likeness%20and%20Binding%20Offers%29.%20Troster%27s%20documentary%20film%20proposals%20included%20treatments%20of%20the%20lives%20of%20%20music%20artist%2C%20Jackie%20Washington%20and%20filmmaker%2C%20Christopher%20Chapman%2C%20%20as%20well%20as%20political%20figures%2C%20Tommy%20Douglas%20and%20J.B.%20Salsberg%2C%20Troster%27s%20uncle.%20However%2C%20Troster%20was%20not%20able%20to%20complete%20any%20of%20these%20works.%20David%20Troster%20died%20on%2018%20November%201995.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Troster%2C%20David%2C%201949-1995> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/Walmsley%2C%20Thomas%2C%201859-ca.%201929>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23Person>,
    rico:Person;
  rdfs:label <https://data.archives.gov.on.test.gbad.caWalmsley%2C%20Thomas%2C%201859-ca.%201929 (Person)>,
    "";
  rico:history <https://data.archives.gov.on.test.gbad.caThomas%20Walmsley%2C%20son%20of%20Samuel%20and%20Eliza%20Walmsley%20of%20Athol%2C%20Ontario%2C%20was%20born%20in%20Ontario%20on%2013%20February%201859.%20He%20was%20a%20schoolteacher%20in%20Athol%20in%201881%20but%20later%20became%20a%20barrister%2C%20establishing%20a%20practice%20in%20Picton%2C%20Ontario%20about%201890.%20He%20married%20Ada%20F.%20Rorke%20on%2026%20August%201896%2C%20and%20they%20had%20a%20son%2C%20Gordon%20Turnbull%20Walmsley%20who%20later%20joined%20his%20father%27s%20law%20practice.%20Thomas%20Walmsley%20died%20about%201929.>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Walmsley%2C%20Thomas%2C%201859-ca.%201929> .

<https://data.archives.gov.on.test.gbad.ca/KB/Agent/War%20Memorial%20Committee%20of%20Ontario>
  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20War%20Memorial%20Committee%20of%20Ontario%20was%20established%20following%20%20a%20resolution%20of%20the%20Legislative%20Assembly%20calling%20for%20a%20suitable%20mark%20of%20appreciation%20for%20those%20who%20had%20been%20killed%20during%20the%20First%20World%20War.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/War%20Memorial%20Committee%20of%20Ontario>,
    <https://data.archives.gov.on.test.gbad.ca/KB/VariantAgentName/Ontario.%20Committee%20on%20a%20Memorial%20of%20the%20Recent%20War.>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Legislative%20Assembly>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA436>;
  rico:history <https://data.archives.gov.on.test.gbad.caSelect%20Committees%20are%20ad-hoc%20committees%20of%20the%20Legislative%20Assembly%20of%20Ontario%20with%20specific%20terms%20of%20reference%20to%20investigate%20and%20report%20on%20a%20specific%20issue.%20This%20committee%20was%20initially%20established%20on%20April%2022%2C%201920%20with%20Henry%20Sloane%20Cooper%20as%20Chair%2C%20and%20was%20re-appointed%20on%20April%2028%2C%201921%20and%20March%2030%2C%201922.%20They%20issued%20their%20final%20report%20on%20February%2015%2C%201923.%20The%20committee%20recommended%20the%20construction%20of%20a%20cenotaph%20on%20University%20Avenue%20in%20Toronto%2C%20but%20recommended%20that%20it%20be%20postponed%20until%20the%20creation%20of%20a%20new%20archives%20building%20at%20the%20same%20time.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/CA436>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/War%20Memorial%20Committee%20of%20Ontario> .

