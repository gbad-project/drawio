  a owl:NamedIndividual, <https://data.archives.gov.on.test.gbad.cahttps%3A%2F%2Fwww.ica.org%2Fstandards%2FRiC%2Fontology%23CorporateBody>,
    rico:CorporateBody;
  rdfs:label "";
  auth:functionNote <https://data.archives.gov.on.test.gbad.caThe%20Trade%20Development%20Branch%20was%20responsible%20for%20promoting%20Ontario%20exports%20internationally.>;
  rico:hasOrHadAgentName <https://data.archives.gov.on.test.gbad.ca/KB/NaturalAgentName/Trade%20Development%20Branch>;
  rico:hasOrHadController <https://data.archives.gov.on.test.gbad.ca/KB/Agent/Ontario.%20Ministry%20of%20Economic%20Development%20and%20Trade%20%281993-1995%29>;
  rico:hasOrHadCorporateBodyType <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/AuthorityType#C%20Ontario%20Government%20Name>;
  rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/KB/AgencyReferenceCode/CA931>;
  rico:history <https://data.archives.gov.on.test.gbad.caThe%20Trade%20Development%20Branch%20was%20formed%20in%201993%20in%20the%20Ontario%20Ministry%20of%20Economic%20Development%20and%20Trade%20within%20the%20Trade%20and%20Investment%20Marketing%20Division.%20It%20assumed%20some%20of%20the%20responsibilities%20of%20the%20former%20Trade%20and%20Investment%20Support%20Branch.%20The%20branch%20consisted%20at%20creation%20of%20the%20Export%20Services%20Section%2C%20the%20Americas%20Section%20and%20the%20Overseas%20Section.%20These%20last%20two%20sections%20assumed%20some%20of%20the%20responsibilities%20of%20the%20former%20international%20offices%20of%20the%20ministry%2C%20which%20were%20closed%20in%201993.%20In%201996%20the%20Trade%20Development%20Branch%20ceased%20to%20exist%20when%20its%20functions%20were%20assumed%20by%20the%20Ontario%20International%20Trade%20Corporation.>;
  rico:isEquivalentTo <https://data.archives.gov.on.test.gbad.ca/KB/Agent/CA931>;
  rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/KB/AuthorityRecord/Ontario.%20Trade%20Development%20Branch%20%281993-1996%29>;
