raw-io/mock#Ontario.%20Chest%20Disease%20Service%20Authority%20Record> a owl:NamedIndividual,\n        rico:Record ;\n    rdfs:label \"Ontario. Chest Disease Service Authority Record\" ;\n    rico:generalDescription \"Source Note: Not in Canadiana. Inventory for RG 10. Archivaria, Number 41, Spring 1996.\" ;\n    rico:hasDocumentaryFormType <ontology://generated-from-draw-io/mock#Authority%20Record> ;\n    rico:hasRecordState <ontology://generated-from-draw-io/mock#Status%3A%20Approved>,\n        <ontology://generated-from-draw-io/mock#Web%20Ready%3A%20Y> ;\n    rico:isOrWasRegulatedBy <ontology://generated-from-draw-io/mock#Rules%20For%20Archival%20Description> ;\n    rico:lastModificationDate \"2010-07-19\"^^xsd:date ;\n    rico:resultsOrResultedFrom <ontology://generated-from-draw-io/mock#Authority%20Record%20Creation> .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Division%20Of%20Tuberculosis%20Prevention> a owl:NamedIndividual,\n        rico:CorporateBody ;\n    rdfs:label \"Ontario. Division of Tuberculosis Prevention\" .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Ministry%20Of%20Health> a owl:NamedIndividual,\n        rico:CorporateBody ;\n    rdfs:label \"Ontario. Ministry of Health\" ;\n    rico:thingIsSourceOfRelation <ontology://generated-from-draw-io/mock#Controlling%20Agency%20Relation> .\n\n<ontology://generated-from-draw-io/mock#Rules%20For%20Archival%20Description> a owl:NamedIndividual,\n        rico:Rule ;\n    rdfs:label \"Rules for Archival Description\" .\n\n<ontology://generated-from-draw-io/mock#Status%3A%20Approved> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Status: Approved\" .\n\n<ontology://generated-from-draw-io/mock#Web%20Ready%3A%20Y> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Web Ready: Y\" .\n\n<ontology://generated-from-draw-io/mock#1974> a owl:NamedIndividual,\n        rico:Date ;\n    rdfs:label \"1974\" .\n\n<ontology://generated-from-draw-io/mock#1982> a owl:NamedIndividual,\n        rico:Date ;\n    rdfs:label \"1982\" .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Chest%20Disease%20Service> a owl:NamedIndividual,\n        rico:AgentName,\n        rico:CorporateBody ;\n    rdfs:label \"Ontario. Chest Disease Service\" ;\n    rico:generalDescription \"Function Note: The Chest Disease Service was established to eradicate tuberculosis and to deal with other diseases of the chest and lungs.\" ;\n    rico:hasBeginningDate <ontology://generated-from-draw-io/mock#1974> ;\n    rico:hasEndDate <ontology://generated-from-draw-io/mock#1982> ;\n    rico:hasOrHadAgentName <ontology://generated-from-draw-io/mock#Ontario.%20Chest%20Disease%20Service> ;\n    rico:hasOrHadController <ontology://generated-from-draw-io/mock#Ontario.%20Ministry%20Of%20Health> ;\n    rico:hasOrHadCorporateBodyType <ontology://generated-from-draw-io/mock#C%20Ontario%20Government%20Name> ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#CA1853> ;\n    rico:history \"In 1974, in response to the continuing decline of the incidence of TB, the Tuberculosis Prevention Service was renamed Chest Disease Service, and was moved, within the Clinic Services Branch, to the Community Health Division.  Throughout the late 1970s and into the 1980s, the Chest Disease Service was transferred several times within the public health function to different offices. Finally in 1982 it was effectively shut down. Of the 23 chest clinics that the service operated, 18 were closed and the remaining 5, all located in Northern Ontario, were transferred to the Ministry of Labour for the purposes of screening miners.\" ;\n    rico:isOrWasDescribedBy <ontology://generated-from-draw-io/mock#Ontario.%20Chest%20Disease%20Service%20Authority%20Record> ;\n    rico:isSuccessorOf <ontology://generated-from-draw-io/mock#Ontario.%20Division%20Of%20Tuberculosis%20Prevention> ;\n    rico:normalizedValue \"Chest Disease Service\" .\n\n"
