graph.parse(data="@base <ontology://generated-from-draw-io/mock#> .\n@prefix : <ontology://generated-from-draw-io/mock#> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n\n<ontology://generated-from-draw-io/mock> a owl:Ontology ;\n    owl:imports rico: .\n\n<ontology://generated-from-draw-io/mock#Archival%20Description> a owl:NamedIndividual,\n        rico:DocumentaryFormType ;\n    rdfs:label \"Archival Description\" .\n\n<ontology://generated-from-draw-io/mock#Archival%20Description%20Creation> a owl:NamedIndividual,\n        rico:Activity ;\n    rdfs:label \"Archival Description Creation\" ;\n    rico:isOrWasPerformedBy <ontology://generated-from-draw-io/mock#Walz> .\n\n<ontology://generated-from-draw-io/mock#Current%20Reference%20Code> a owl:NamedIndividual,\n        rico:IdentifierType ;\n    rdfs:label \"Current Reference Code\" .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches> a owl:NamedIndividual,\n        rico:RecordSet,\n        rico:Title ;\n    rdfs:label \"Elizabeth Simcoe loose sketches\" ;\n    rico:accruals \"No further accruals are expected.\" ;\n    rico:conditionsOfAccess \"The original artworks in this sub-series are closed for conservation reasons. Please refer either to reference slides and transparencies, or to the Archives' on-line Visual Database.\" ;\n    rico:conditionsOfUse \"Records are in the public domain. There are no restrictions on reproduction for research and private study.  If you wish to use any of this material for a purpose other than research and private study, submit a Request for Permission to Publish, Exhibit or Broadcast Form.\" ;\n    rico:creationDate \"1791-1842, predominant 1791-1796\" ;\n    rico:generalDescription \"Availability of Other Formats: This material is available as reference slides and/or transparencies, and through the Archives' on-line Visual Database.\",\n        \"Finding Aid Note: An online list is available for this sub-series.\",\n        \"Notes: Some items contain Mrs. Simcoe's original captions and dates. Others, initialed \\\"C.S.\\\", may have been captioned by her daughter Charlotte.  In a few cases, writing on the back of an item may have been done by members of the Coles family or archivists. Other supplied caption and date information was taken from John Ross Robertson's 1911 publication The Diary of Mrs. Simcoe. The original of this diary is contained in series F 47-8. The \\\"Old Code\\\" reference in the listings provides cross-references to earlier control numbers used in the 1956 Archives of Ontario finding aid to the sketches. Some item reference codes appear out of sequence in the listing. These represent previously unnumbered sketches found on the verso of sketches containing old code numbers. The titles of all these items have been supplied.\" ;\n    rico:hasContentOfType <ontology://generated-from-draw-io/mock#Graphic%20Materials> ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#F%2047-11-1> ;\n    rico:hasOrHadInstantiation <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches-i1> ;\n    rico:hasOrHadTitle <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Sub-Series> ;\n    rico:history \"Custodial History: The material in this sub-series was acquired in 1952 under the terms of a long-term loan agreement with the University of Toronto Library, which owns the records.\" ;\n    rico:isDirectlyIncludedIn <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches> ;\n    rico:isOrWasDescribedBy <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches%20Archival%20Description> ;\n    rico:scopeAndContent \"Sub-series consists largely of watercolours and drawings, most of which were created by Elizabeth Simcoe. The majority are of Upper Canada and Lower Canada, created during her husband's tenure as Lieutenant-Governor of Upper Canada.  Some of the more detailed watercolours may have been completed after her return to England in 1796. Most of the works depict the St. Lawrence River, Lake Ontario, and the Niagara region. There are also views of Montreal, Quebec, and southern places in England. Along with the landscapes, there are some portraits, primarily of aboriginal people, and drawings of flowers, birds, butterflies and fish.  A number of sketches are clearly the work of other artists. Items F 47-11-1-0-109 through F 47-11-1-0-117 are identified as being drawn by Lieutenant Pilkington. A few others contain differences in style, suggesting that Mrs. Simcoe was not the artist.  The sub-series also contains prints collected by Mrs. Simcoe and a photograph of either one of her watercolours or a watercolour collected by her.\" .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches%20Archival%20Description> a owl:NamedIndividual,\n        rico:Record ;\n    rdfs:label \"Elizabeth Simcoe loose sketches Archival Description\" ;\n    rico:hasDocumentaryFormType <ontology://generated-from-draw-io/mock#Archival%20Description> ;\n    rico:hasRecordState <ontology://generated-from-draw-io/mock#Status%3A%20Approved>,\n        <ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> ;\n    rico:lastModificationDate \"2009-07-23\"^^xsd:date ;\n    rico:resultsOrResultedFrom <ontology://generated-from-draw-io/mock#Archival%20Description%20Creation> .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches-i1> a owl:NamedIndividual,\n        rico:Instantiation ;\n    rdfs:label \"Elizabeth Simcoe loose sketches-i1\" ;\n    rico:generalDescription \"How to Order: Consult the online list to identify the records that you require. Order reference transparencies or slides using reference code and barcode number, or refer to the on-line Visual Database.\" ;\n    rico:instantiationExtent \"318 watercolours  58 drawings  8 prints  1 photograph\" .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Elizabeth Simcoe sketches\" ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#F%2047-11> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Series> .\n\n<ontology://generated-from-draw-io/mock#F%2047-11> a owl:NamedIndividual,\n        rico:Identifier ;\n    rdfs:label \"F 47-11\" .\n\n<ontology://generated-from-draw-io/mock#F%2047-11-1> a owl:NamedIndividual,\n        rico:Identifier ;\n    rdfs:label \"F 47-11-1\" ;\n    rico:hasIdentifierType <ontology://generated-from-draw-io/mock#Current%20Reference%20Code> .\n\n<ontology://generated-from-draw-io/mock#Graphic%20Materials> a owl:NamedIndividual,\n        rico:ContentType ;\n    rdfs:label \"Graphic materials\" .\n\n<ontology://generated-from-draw-io/mock#Series> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Series\" .\n\n<ontology://generated-from-draw-io/mock#Status%3A%20Approved> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Status: Approved\" .\n\n<ontology://generated-from-draw-io/mock#Sub-Series> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Sub-Series\" .\n\n<ontology://generated-from-draw-io/mock#Walz> a owl:NamedIndividual,\n        rico:Person ;\n    rdfs:label \"Walz\" .\n\n<ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Web Enabled: Y\" .\n\n", format="turtle")
graph.parse(data="@base <ontology://generated-from-draw-io/mock#> .\n@prefix : <ontology://generated-from-draw-io/mock#> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n\n<ontology://generated-from-draw-io/mock> a owl:Ontology ;\n    owl:imports rico: .\n\n<ontology://generated-from-draw-io/mock#Archival%20Description> a owl:NamedIndividual,\n        rico:DocumentaryFormType ;\n    rdfs:label \"Archival Description\" .\n\n<ontology://generated-from-draw-io/mock#Archival%20Description%20Creation> a owl:NamedIndividual,\n        rico:Activity ;\n    rdfs:label \"Archival Description Creation\" ;\n    rico:isOrWasPerformedBy <ontology://generated-from-draw-io/mock#Walz> .\n\n<ontology://generated-from-draw-io/mock#Current%20Reference%20Code> a owl:NamedIndividual,\n        rico:IdentifierType ;\n    rdfs:label \"Current Reference Code\" .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches> a owl:NamedIndividual,\n        rico:RecordSet,\n        rico:Title ;\n    rdfs:label \"Elizabeth Simcoe loose sketches\" ;\n    rico:accruals \"No further accruals are expected.\" ;\n    rico:conditionsOfAccess \"The original artworks in this sub-series are closed for conservation reasons. Please refer either to reference slides and transparencies, or to the Archives' on-line Visual Database.\" ;\n    rico:conditionsOfUse \"Records are in the public domain. There are no restrictions on reproduction for research and private study.  If you wish to use any of this material for a purpose other than research and private study, submit a Request for Permission to Publish, Exhibit or Broadcast Form.\" ;\n    rico:creationDate \"1791-1842, predominant 1791-1796\" ;\n    rico:generalDescription \"Availability of Other Formats: This material is available as reference slides and/or transparencies, and through the Archives' on-line Visual Database.\",\n        \"Finding Aid Note: An online list is available for this sub-series.\",\n        \"Notes: Some items contain Mrs. Simcoe's original captions and dates. Others, initialed \\\"C.S.\\\", may have been captioned by her daughter Charlotte.  In a few cases, writing on the back of an item may have been done by members of the Coles family or archivists. Other supplied caption and date information was taken from John Ross Robertson's 1911 publication The Diary of Mrs. Simcoe. The original of this diary is contained in series F 47-8. The \\\"Old Code\\\" reference in the listings provides cross-references to earlier control numbers used in the 1956 Archives of Ontario finding aid to the sketches. Some item reference codes appear out of sequence in the listing. These represent previously unnumbered sketches found on the verso of sketches containing old code numbers. The titles of all these items have been supplied.\" ;\n    rico:hasContentOfType <ontology://generated-from-draw-io/mock#Graphic%20Materials> ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#F%2047-11-1> ;\n    rico:hasOrHadInstantiation <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches-i1> ;\n    rico:hasOrHadTitle <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Sub-Series> ;\n    rico:history \"Custodial History: The material in this sub-series was acquired in 1952 under the terms of a long-term loan agreement with the University of Toronto Library, which owns the records.\" ;\n    rico:isDirectlyIncludedIn <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches> ;\n    rico:isOrWasDescribedBy <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches%20Archival%20Description> ;\n    rico:scopeAndContent \"Sub-series consists largely of watercolours and drawings, most of which were created by Elizabeth Simcoe. The majority are of Upper Canada and Lower Canada, created during her husband's tenure as Lieutenant-Governor of Upper Canada.  Some of the more detailed watercolours may have been completed after her return to England in 1796. Most of the works depict the St. Lawrence River, Lake Ontario, and the Niagara region. There are also views of Montreal, Quebec, and southern places in England. Along with the landscapes, there are some portraits, primarily of aboriginal people, and drawings of flowers, birds, butterflies and fish.  A number of sketches are clearly the work of other artists. Items F 47-11-1-0-109 through F 47-11-1-0-117 are identified as being drawn by Lieutenant Pilkington. A few others contain differences in style, suggesting that Mrs. Simcoe was not the artist.  The sub-series also contains prints collected by Mrs. Simcoe and a photograph of either one of her watercolours or a watercolour collected by her.\" .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches%20Archival%20Description> a owl:NamedIndividual,\n        rico:Record ;\n    rdfs:label \"Elizabeth Simcoe loose sketches Archival Description\" ;\n    rico:hasDocumentaryFormType <ontology://generated-from-draw-io/mock#Archival%20Description> ;\n    rico:hasRecordState <ontology://generated-from-draw-io/mock#Status%3A%20Approved>,\n        <ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> ;\n    rico:lastModificationDate \"2009-07-23\"^^xsd:date ;\n    rico:resultsOrResultedFrom <ontology://generated-from-draw-io/mock#Archival%20Description%20Creation> .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Loose%20Sketches-i1> a owl:NamedIndividual,\n        rico:Instantiation ;\n    rdfs:label \"Elizabeth Simcoe loose sketches-i1\" ;\n    rico:generalDescription \"How to Order: Consult the online list to identify the records that you require. Order reference transparencies or slides using reference code and barcode number, or refer to the on-line Visual Database.\" ;\n    rico:instantiationExtent \"318 watercolours  58 drawings  8 prints  1 photograph\" .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Elizabeth Simcoe sketches\" ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#F%2047-11> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Series> .\n\n<ontology://generated-from-draw-io/mock#F%2047-11> a owl:NamedIndividual,\n        rico:Identifier ;\n    rdfs:label \"F 47-11\" .\n\n<ontology://generated-from-draw-io/mock#F%2047-11-1> a owl:NamedIndividual,\n        rico:Identifier ;\n    rdfs:label \"F 47-11-1\" ;\n    rico:hasIdentifierType <ontology://generated-from-draw-io/mock#Current%20Reference%20Code> .\n\n<ontology://generated-from-draw-io/mock#Graphic%20Materials> a owl:NamedIndividual,\n        rico:ContentType ;\n    rdfs:label \"Graphic materials\" .\n\n<ontology://generated-from-draw-io/mock#Series> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Series\" .\n\n<ontology://generated-from-draw-io/mock#Status%3A%20Approved> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Status: Approved\" .\n\n<ontology://generated-from-draw-io/mock#Sub-Series> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Sub-Series\" .\n\n<ontology://generated-from-draw-io/mock#Walz> a owl:NamedIndividual,\n        rico:Person ;\n    rdfs:label \"Walz\" .\n\n<ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Web Enabled: Y\" .\n\n", format="turtle")
