co:generalDescription \"How to Order: To view these records, order Series RG 10-145, container B 972.\" ;\n    rico:instantiationExtent \"ca. 200 photographs\" .\n\n<ontology://generated-from-draw-io/mock#O%27Rourke> a owl:NamedIndividual,\n        rico:Person ;\n    rdfs:label \"O'Rourke\" .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Dept.%20Of%20Health> a owl:NamedIndividual,\n        rico:CorporateBody ;\n    rdfs:label \"Ontario. Dept. of Health\" .\n\n<ontology://generated-from-draw-io/mock#RG%2010-145> a owl:NamedIndividual,\n        rico:Identifier ;\n    rdfs:label \"RG 10-145\" ;\n    rico:hasIdentifierType <ontology://generated-from-draw-io/mock#Current%20Reference%20Code> .\n\n<ontology://generated-from-draw-io/mock#Series> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Series\" .\n\n<ontology://generated-from-draw-io/mock#Status%3A%20Approved> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Status: Approved\" .\n\n<ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Web Enabled: Y\" .\n\n"
