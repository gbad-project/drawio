graph.parse(data="@base <ontology://generated-from-draw-io/mock#> .\n@prefix : <ontology://generated-from-draw-io/mock#> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n\n<ontology://generated-from-draw-io/mock> a owl:Ontology ;\n    owl:imports rico: .\n\n<ontology://generated-from-draw-io/mock#1972> a owl:NamedIndividual,\n        rico:Date ;\n    rdfs:label \"1972\" .\n\n<ontology://generated-from-draw-io/mock#1999> a owl:NamedIndividual,\n        rico:Date ;\n    rdfs:label \"1999\" .\n\n<ontology://generated-from-draw-io/mock#A%20Ontario%20Government%20Name> a owl:NamedIndividual,\n        rico:CorporateBodyType ;\n    rdfs:label \"A Ontario Government Name\" .\n\n<ontology://generated-from-draw-io/mock#AA42> a owl:NamedIndividual,\n        rico:Identifier ;\n    rdfs:label \"AA42\" ;\n    rico:hasIdentifierType <ontology://generated-from-draw-io/mock#Agent%20Identifier> .\n\n<ontology://generated-from-draw-io/mock#Agent%20Identifier> a owl:NamedIndividual,\n        rico:IdentifierType ;\n    rdfs:label \"Agent Identifier\" .\n\n<ontology://generated-from-draw-io/mock#Authority%20Record> a owl:NamedIndividual,\n        rico:DocumentaryFormType ;\n    rdfs:label \"Authority Record\" .\n\n<ontology://generated-from-draw-io/mock#Authority%20Record%20Creation> a owl:NamedIndividual,\n        rico:Activity ;\n    rdfs:label \"Authority Record Creation\" ;\n    rico:isOrWasPerformedBy <ontology://generated-from-draw-io/mock#R.%20Anger> .\n\n<ontology://generated-from-draw-io/mock#MOH> a owl:NamedIndividual,\n        rico:AgentName ;\n    rdfs:label \"MOH\" ;\n    rico:hasOrHadCategory <ontology://generated-from-draw-io/mock#Variant%20Name> .\n\n<ontology://generated-from-draw-io/mock#MS> a owl:NamedIndividual,\n        rico:AgentName ;\n    rdfs:label \"MS\" ;\n    rico:hasOrHadCategory <ontology://generated-from-draw-io/mock#Variant%20Name> .\n\n<ontology://generated-from-draw-io/mock#Ministry%20Of%20Health%20Act%2C%20Statutes%20Of%20Ontario%201972%2C%20Chap.%2092> a owl:NamedIndividual,\n        rico:Mandate ;\n    rdfs:label \"Ministry of Health Act, Statutes of Ontario 1972, Chap. 92\" .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Dept.%20Of%20Health> a owl:NamedIndividual,\n        rico:CorporateBody ;\n    rdfs:label \"Ontario. Dept. of Health\" .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Ministry%20Of%20Health> a owl:NamedIndividual,\n        rico:AgentName,\n        rico:CorporateBody ;\n    rdfs:label \"Ontario. Ministry of Health\" ;\n    rico:authorizedBy <ontology://generated-from-draw-io/mock#Ministry%20Of%20Health%20Act%2C%20Statutes%20Of%20Ontario%201972%2C%20Chap.%2092> ;\n    rico:generalDescription \"Function Note: The Ministry of Health is responsible for administering the health care system and providing services to the Ontario public through programs such as health insurance, care for the mentally ill, drug services, home care services, and the regulation of hospitals and nursing homes. The Ministry also operates psychiatric hospitals, medical laboratories and provides funding and leadership for local public health services.\" ;\n    rico:hasBeginningDate <ontology://generated-from-draw-io/mock#1972> ;\n    rico:hasEndDate <ontology://generated-from-draw-io/mock#1999> ;\n    rico:hasOrHadAgentName <ontology://generated-from-draw-io/mock#MOH>,\n        <ontology://generated-from-draw-io/mock#MS>,\n        <ontology://generated-from-draw-io/mock#Ontario.%20Ministry%20Of%20Health>,\n        <ontology://generated-from-draw-io/mock#Ontario.%20Ministère%20De%20La%20Santé> ;\n    rico:hasOrHadCorporateBodyType <ontology://generated-from-draw-io/mock#A%20Ontario%20Government%20Name> ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#AA42> ;\n    rico:hasSuccessor <ontology://generated-from-draw-io/mock#Ontario.%20Ministry%20Of%20Health%20And%20Long-Term%20Care> ;\n    rico:history \"The Department of Health was renamed the Ministry of Health in 1972.   Since 1972, the Ministry has been restructured often and a number of different divisions have existed within it.  They have, however, tended to focus around five primary areas: health insurance; community and public health services; institutional health (including administration of hospitals, ambulance services, nursing homes and psychiatric hospitals); administration and finance; and information systems.   Agencies which report to the Ministry include the Addiction Research Foundation, the Ontario Cancer Treatment and Research Foundation, the District Health Councils, and the Ontario Mental Health Foundation.   On June 17, 1999 the Ministry of Health was renamed the Ministry of Health and Long-Term Care.\" ;\n    rico:isOrWasDescribedBy <ontology://generated-from-draw-io/mock#Ontario.%20Ministry%20Of%20Health%20Authority%20Record> ;\n    rico:isSuccessorOf <ontology://generated-from-draw-io/mock#Ontario.%20Dept.%20Of%20Health> ;\n    rico:normalizedValue \"Ministry of Health\" .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Ministry%20Of%20Health%20And%20Long-Term%20Care> a owl:NamedIndividual,\n        rico:CorporateBody ;\n    rdfs:label \"Ontario. Ministry of Health and Long-Term Care\" .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Ministry%20Of%20Health%20Authority%20Record> a owl:NamedIndividual,\n        rico:Record ;\n    rdfs:label \"Ontario. Ministry of Health Authority Record\" ;\n    rico:generalDescription \"Source Note: Government of Ontario Telephone Directory, 1995-96. KWIC Indexes, 1972-1995. Canadiana Name Authorities, 1996-12-24.\" ;\n    rico:hasDocumentaryFormType <ontology://generated-from-draw-io/mock#Authority%20Record> ;\n    rico:hasRecordState <ontology://generated-from-draw-io/mock#Status%3A%20Approved>,\n        <ontology://generated-from-draw-io/mock#Web%20Ready%3A%20Y> ;\n    rico:isOrWasRegulatedBy <ontology://generated-from-draw-io/mock#Rules%20For%20Archival%20Description> ;\n    rico:lastModificationDate \"2024-04-18\"^^xsd:date ;\n    rico:resultsOrResultedFrom <ontology://generated-from-draw-io/mock#Authority%20Record%20Creation> .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Ministère%20De%20La%20Santé> a owl:NamedIndividual,\n        rico:AgentName ;\n    rdfs:label \"Ontario. Ministère de la Santé\" ;\n    rico:hasOrHadCategory <ontology://generated-from-draw-io/mock#Parallel%20Name> .\n\n<ontology://generated-from-draw-io/mock#Parallel%20Name> a owl:NamedIndividual,\n        rico:Type ;\n    rdfs:label \"Parallel Name\" .\n\n<ontology://generated-from-draw-io/mock#R.%20Anger> a owl:NamedIndividual,\n        rico:Person ;\n    rdfs:label \"R. Anger\" .\n\n<ontology://generated-from-draw-io/mock#Rules%20For%20Archival%20Description> a owl:NamedIndividual,\n        rico:Rule ;\n    rdfs:label \"Rules for Archival Description\" .\n\n<ontology://generated-from-draw-io/mock#Status%3A%20Approved> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Status: Approved\" .\n\n<ontology://generated-from-draw-io/mock#Web%20Ready%3A%20Y> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Web Ready: Y\" .\n\n<ontology://generated-from-draw-io/mock#Variant%20Name> a owl:NamedIndividual,\n        rico:Type ;\n    rdfs:label \"Variant Name\" .\n\n", format="turtle")
