       rico:RecordSet,\n        rico:Title ;\n    rdfs:label \"Notes on Elizabeth Simcoe sketches\" ;\n    rico:accruals \"No further accruals are expected.\" ;\n    rico:conditionsOfAccess \"No restrictions on access.\" ;\n    rico:conditionsOfUse \"Records are in the public domain. There are no restrictions on reproduction for research and private study.  If you wish to use any of this material for a purpose other than research and private study, submit a Request for Permission to Publish, Exhibit or Broadcast Form.\" ;\n    rico:creationDate \"[ca. 1790-184--]\" ;\n    rico:generalDescription \"Finding Aid Note: An online list is available for this sub-series.\" ;\n    rico:hasContentOfType <ontology://generated-from-draw-io/mock#Cartographic%20Materials>,\n        <ontology://generated-from-draw-io/mock#Textual%20Records> ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#F%2047-11-4> ;\n    rico:hasOrHadInstantiation <ontology://generated-from-draw-io/mock#Notes%20On%20Elizabeth%20Simcoe%20Sketches-i1> ;\n    rico:hasOrHadTitle <ontology://generated-from-draw-io/mock#Notes%20On%20Elizabeth%20Simcoe%20Sketches> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Sub-Series> ;\n    rico:history \"Custodial History: The material in this sub-series was acquired in 1952 under the terms of a long-term loan agreement with the University of Toronto Library, which owns the records.\" ;\n    rico:isDirectlyIncludedIn <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches> ;\n    rico:isOrWasDescribedBy <ontology://generated-from-draw-io/mock#Notes%20On%20Elizabeth%20Simcoe%20Sketches%20Archival%20Description> ;\n    rico:scopeAndContent \"Sub-series consists of records providing information about the artworks contained within sub-series F 47-11-1 to F 47-11-3. It is not clear whether Elizabeth Simcoe was the author of these documents. Two are caption lists of some of her sketches; the remaining two documents are scraps, containing a few names and notes. There is also a map indicating places where Elizabeth Simcoe made sketches.\" .\n\n<ontology://generated-from-draw-io/mock#Notes%20On%20Elizabeth%20Simcoe%20Sketches%20Archival%20Description> a owl:NamedIndividual,\n        rico:Record ;\n    rdfs:label \"Notes on Elizabeth Simcoe sketches Archival Description\" ;\n    rico:hasDocumentaryFormType <ontology://generated-from-draw-io/mock#Archival%20Description> ;\n    rico:hasRecordState <ontology://generated-from-draw-io/mock#Status%3A%20Approved>,\n        <ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> ;\n    rico:lastModificationDate \"2009-07-17\"^^xsd:date ;\n    rico:resultsOrResultedFrom <ontology://generated-from-draw-io/mock#Archival%20Description%20Creation> .\n\n<ontology://generated-from-draw-io/mock#Notes%20On%20Elizabeth%20Simcoe%20Sketches-i1> a owl:NamedIndividual,\n        rico:Instantiation ;\n    rdfs:label \"Notes on Elizabeth Simcoe sketches-i1\" ;\n    rico:generalDescription \"How to Order: Consult the online list to identify the records that you require. Order using reference code and barcode number.\" ;\n    rico:instantiationExtent \"1 centimetre of textual records 1 map\" .\n\n<ontology://generated-from-draw-io/mock#Series> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Series\" .\n\n<ontology://generated-from-draw-io/mock#Status%3A%20Approved> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Status: Approved\" .\n\n<ontology://generated-from-draw-io/mock#Sub-Series> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Sub-Series\" .\n\n<ontology://generated-from-draw-io/mock#Textual%20Records> a owl:NamedIndividual,\n        rico:ContentType ;\n    rdfs:label \"Textual records\" .\n\n<ontology://generated-from-draw-io/mock#Walz> a owl:NamedIndividual,\n        rico:Person ;\n    rdfs:label \"Walz\" .\n\n<ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> a owl:NamedIndiv