    "isomorphic": baseline_iso == actual_iso,
    "baseline_triples": len(baseline_graph),
    "actual_triples": len(actual_graph),
    "baseline_filtered_triples": len(baseline_filtered),
    "actual_filtered_triples": len(actual_filtered),
})
      
