graph.parse(data="@base <ontology://generated-from-draw-io/mock#> .\n@prefix : <ontology://generated-from-draw-io/mock#> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n\n<ontology://generated-from-draw-io/mock> a owl:Ontology ;\n    owl:imports rico: .\n\n<ontology://generated-from-draw-io/mock#1948> a owl:NamedIndividual,\n        rico:Date ;\n    rdfs:label \"1948\" .\n\n<ontology://generated-from-draw-io/mock#1982> a owl:NamedIndividual,\n        rico:Date ;\n    rdfs:label \"1982\" .\n\n<ontology://generated-from-draw-io/mock#Archival%20Description> a owl:NamedIndividual,\n        rico:DocumentaryFormType ;\n    rdfs:label \"Archival Description\" .\n\n<ontology://generated-from-draw-io/mock#Archival%20Description%20Creation> a owl:NamedIndividual,\n        rico:Activity ;\n    rdfs:label \"Archival Description Creation\" ;\n    rico:isOrWasPerformedBy <ontology://generated-from-draw-io/mock#Stabile> .\n\n<ontology://generated-from-draw-io/mock#Correspondence%20Of%20The%20Chief%20Of%20The%20Chest%20Disease%20Service> a owl:NamedIndividual,\n        rico:RecordSet,\n        rico:Title ;\n    rdfs:label \"Correspondence of the Chief of the Chest Disease Service\" ;\n    rico:accruals \"No further accruals are expected.\" ;\n    rico:conditionsOfAccess \"Access to these records is governed by the Freedom of Information and Protection of Privacy Act. Requests for access to records 100 years old or less must be submitted in writing to the Information and Privacy Unit of the Archives of Ontario.\" ;\n    rico:conditionsOfUse \"Copyright is held primarily by the Crown. There are no restrictions on reproduction. Permission of the Archives of Ontario is required for publication; submit a Request for Permission to Publish, Exhibit or Broadcast Form.\" ;\n    rico:creationDate \"1948-1982\" ;\n    rico:generalDescription \"Finding Aid Note: No file list is available.\" ;\n    rico:hasContentOfType <ontology://generated-from-draw-io/mock#Textual%20Records> ;\n    rico:hasCreator <ontology://generated-from-draw-io/mock#Chest%20Disease%20Service>,\n        <ontology://generated-from-draw-io/mock#Division%20Of%20Tuberculosis%20Prevention> ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#RG%2010-142> ;\n    rico:hasOrHadInstantiation <ontology://generated-from-draw-io/mock#Correspondence%20Of%20The%20Chief%20Of%20The%20Chest%20Disease%20Service-i1> ;\n    rico:hasOrHadTitle <ontology://generated-from-draw-io/mock#Correspondence%20Of%20The%20Chief%20Of%20The%20Chest%20Disease%20Service> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Series> ;\n    rico:history \"Immediate Source of Acquisition: Records in this series were transferred to the Archives of Ontario by the Ministry of Health.\" ;\n    rico:isOrWasDescribedBy <ontology://generated-from-draw-io/mock#Correspondence%20Of%20The%20Chief%20Of%20The%20Chest%20Disease%20Service%20Archival%20Description> ;\n    rico:scopeAndContent \"Series consists of records created and maintained by the Chest Disease Service and its predecessor agencies to provide a cumulative record in reviewing, preventing, and treating tuberculosis in Ontario.  Records consist of originals of incoming and copies of outgoing correspondence, both inter and intra Ministry, with the federal government, sanatoria, chest clinics, professional associations, other agencies outside the provincial government, and private citizens relating to the prevention and treatment of tuberculosis in Ontario.     Subjects include the following: drugs, chemotheraphy, chest x-ray programs, epidemiology, home care programs, health standards, immigrants and refugees, mass survey x-ray interpretaion, smoking and health education material.     Files are arranged alphabetically by subject.\" ;\n    rico:thingIsSourceOfRelation 