def normalise(source: Graph) -> Graph:
    filtered = Graph()
    for s, p, o in source:
        if p == RDF.type and o in {OWL.ObjectProperty, OWL.DatatypeProperty, OWL.Ontology}:
            continue
        if p == OWL.imports:
            continue
        filtered.add((s, p, o))
    return filtered

