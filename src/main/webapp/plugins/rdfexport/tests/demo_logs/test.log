graph.parse(data="@base <ontology://generated-from-draw-io/mock#> .\n@prefix : <ontology://generated-from-draw-io/mock#> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n\n<ontology://generated-from-draw-io/mock> a owl:Ontology ;\n    owl:imports rico: .\n\n<ontology://generated-from-draw-io/mock#Archival%20Description> a owl:NamedIndividual,\n        rico:DocumentaryFormType ;\n    rdfs:label \"Archival Description\" .\n\n<ontology://generated-from-draw-io/mock#Archival%20Description%20Creation> a owl:NamedIndividual,\n        rico:Activity ;\n    rdfs:label \"Archival Description Creation\" ;\n    rico:isOrWasPerformedBy <ontology://generated-from-draw-io/mock#Walz> .\n\n<ontology://generated-from-draw-io/mock#Cartographic%20Materials> a owl:NamedIndividual,\n        rico:ContentType ;\n    rdfs:label \"Cartographic materials\" .\n\n<ontology://generated-from-draw-io/mock#Current%20Reference%20Code> a owl:NamedIndividual,\n        rico:IdentifierType ;\n    rdfs:label \"Current Reference Code\" .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches> a owl:NamedIndividual,\n        rico:RecordSet,\n        rico:Title ;\n    rdfs:label \"Elizabeth Simcoe sketches\" ;\n    rico:accruals \"No further accruals are expected.\" ;\n    rico:conditionsOfAccess \"See sub-series descriptions for information on access restrictions on this material.\" ;\n    rico:conditionsOfUse \"Records are in the public domain. There are no restrictions on reproduction for research and private study.  If you wish to use any of this material for a purpose other than research and private study, submit a Request for Permission to Publish, Exhibit or Broadcast Form.\" ;\n    rico:creationDate \"ca. 1790-[184-?] (Predominant 1791-1796)\" ;\n    rico:generalDescription \"Availability of Other Formats: See sub-series descriptions for information on the availability of other formats.\",\n        \"Finding Aid Note: Please see sub-series descriptions.\" ;\n    rico:hasContentOfType <ontology://generated-from-draw-io/mock#Cartographic%20Materials>,\n        <ontology://generated-from-draw-io/mock#Graphic%20Materials>,\n        <ontology://generated-from-draw-io/mock#Textual%20Records> ;\n    rico:hasCreator <ontology://generated-from-draw-io/mock#Simcoe%2C%20Elizabeth%20Posthuma%2C%201762-1850> ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#F%2047-11> ;\n    rico:hasOrHadInstantiation <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches-i1> ;\n    rico:hasOrHadTitle <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Series> ;\n    rico:history \"Custodial History: The material in this series was acquired in 1952 under the terms of a long-term loan agreement with the University of Toronto Library, which owns the records.\" ;\n    rico:isDirectlyIncludedIn <ontology://generated-from-draw-io/mock#Simcoe%20Family%20Fonds> ;\n    rico:isOrWasDescribedBy <ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches%20Archival%20Description> ;\n    rico:scopeAndContent \"Series consists of artworks and other related records created or cellected by Elizabeth Simcoe. The watercolours and drawings consist primarily of landscapes, the majority of which are views of Upper and Lower Canada.  Differences in style within the series, such as more detailed trees, sharper contrasts and less perspective, suggests that Simcoe was not the artist of all the artworks in the series, and that she collected drawings done by others. In two cases, other artists are identified. More details on the attribution of works is in the description for sub-series F 47-11-1.  The Canadian sketches provide a visual compliment to her diaries (see Series F 47-8), which contain documentation regarding when scenes were sketched. Additional sketches are contained within the diaries which make up series F 47-8.\" .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches%20Archival%20Description> a owl:NamedIndividual,\n        rico:Record ;\n    rdfs:label \"Elizabeth Simcoe sketches Archival Description\" ;\n    rico:hasDocumentaryFormType <ontology://generated-from-draw-io/mock#Archival%20Description> ;\n    rico:hasRecordState <ontology://generated-from-draw-io/mock#Status%3A%20Approved>,\n        <ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> ;\n    rico:lastModificationDate \"2009-07-17\"^^xsd:date ;\n    rico:resultsOrResultedFrom <ontology://generated-from-draw-io/mock#Archival%20Description%20Creation> .\n\n<ontology://generated-from-draw-io/mock#Elizabeth%20Simcoe%20Sketches-i1> a owl:NamedIndividual,\n        rico:Instantiation ;\n    rdfs:label \"Elizabeth Simcoe sketches-i1\" ;\n    rico:generalDescription \"How to Order: Please see sub-series descriptions for ordering information.\" ;\n    rico:instantiationExtent \"353 watercolours  63 drawings  8 prints  1 sketchbook (63 watercolours and drawings)  1 photograph  1 centimetre of textual records  1 map\" .\n\n<ontology://generated-from-draw-io/mock#F%2047> a owl:NamedIndividual,\n        rico:Identifier ;\n    rdfs:label \"F 47\" .\n\n<ontology://generated-from-draw-io/mock#F%2047-11> a owl:NamedIndividual,\n        rico:Identifier ;\n    rdfs:label \"F 47-11\" ;\n    rico:hasIdentifierType <ontology://generated-from-draw-io/mock#Current%20Reference%20Code> .\n\n<ontology://generated-from-draw-io/mock#Fonds> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Fonds\" .\n\n<ontology://generated-from-draw-io/mock#Graphic%20Materials> a owl:NamedIndividual,\n        rico:ContentType ;\n    rdfs:label \"Graphic materials\" .\n\n<ontology://generated-from-draw-io/mock#Series> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Series\" .\n\n<ontology://generated-from-draw-io/mock#Simcoe%20Family%20Fonds> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Simcoe family fonds\" ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#F%2047> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Fonds> .\n\n<ontology://generated-from-draw-io/mock#Simcoe%2C%20Elizabeth%20Posthuma%2C%201762-1850> a owl:NamedIndividual,\n        rico:Person ;\n    rdfs:label \"Simcoe, Elizabeth Posthuma, 1762-1850\" .\n\n<ontology://generated-from-draw-io/mock#Status%3A%20Approved> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Status: Approved\" .\n\n<ontology://generated-from-draw-io/mock#Textual%20Records> a owl:NamedIndividual,\n        rico:ContentType ;\n    rdfs:label \"Textual records\" .\n\n<ontology://generated-from-draw-io/mock#Walz> a owl:NamedIndividual,\n        rico:Person ;\n    rdfs:label \"Walz\" .\n\n<ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Web Enabled: Y\" .\n\n", format="turtle")
