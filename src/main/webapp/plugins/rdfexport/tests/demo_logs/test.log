def normalise(source: Graph) -> Graph:
    filtered = Graph()
    for s, p, o in source:
        if p == RDF.type and o in {OWL.ObjectProperty, OWL.DatatypeProperty, OWL.Ontology}:
            continue
        if p == OWL.imports:
            continue
        filtered.add((s, p, o))
    return filtered

baseline_filtered = normalise(baseline_graph)
actual_filtered = normalise(actual_graph)

