://generated-from-draw-io/mock#Graphic%20Materials> ;\n    rico:hasCreator <ontology://generated-from-draw-io/mock#Ontario.%20Dept.%20Of%20Health> ;\n    rico:hasOrHadIdentifier <ontology://generated-from-draw-io/mock#RG%2010-145> ;\n    rico:hasOrHadInstantiation <ontology://generated-from-draw-io/mock#Mobile%20Tuberculosis%20Testing%20Clinic%20Photographs-i1> ;\n    rico:hasOrHadTitle <ontology://generated-from-draw-io/mock#Mobile%20Tuberculosis%20Testing%20Clinic%20Photographs> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Series> ;\n    rico:isOrWasDescribedBy <ontology://generated-from-draw-io/mock#Mobile%20Tuberculosis%20Testing%20Clinic%20Photographs%20Archival%20Description> ;\n    rico:scopeAndContent \"This series contains photographs of the mobile tuberculosis testing clinics administered by the Department of Health. This includes photographs of chest X-ray machinery, Community X-ray Survey trucks, the Chest X-ray train, information displays for fairs, TB testing equipment, department staff, and interior views of the clinics.\" .\n\n<ontology://generated-from-draw-io/mock#Mobile%20Tuberculosis%20Testing%20Clinic%20Photographs%20Archival%20Description> a owl:NamedIndividual,\n        rico:Record ;\n    rdfs:label \"Mobile Tuberculosis Testing Clinic photographs archival description\" ;\n    rico:hasDocumentaryFormType <ontology://generated-from-draw-io/mock#Archival%20Description> ;\n    rico:hasRecordState <ontology://generated-from-draw-io/mock#Status%3A%20Approved>,\n        <ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> ;\n    rico:lastModificationDate \"2002-08-20\"^^xsd:date ;\n    rico:resultsOrResultedFrom <ontology://generated-from-draw-io/mock#Archival%20Description%20Creation> .\n\n<ontology://generated-from-draw-io/mock#Mobile%20Tuberculosis%20Testing%20Clinic%20Photographs-i1> a owl:NamedIndividual,\n        rico:Instantiation ;\n    rdfs:label \"Mobile Tuberculosis Testing Clinic photographs-i1\" ;\n    rico:generalDescription \"How to Order: To view these records, order Series RG 10-145, container B 972.\" ;\n    rico:instantiationExtent \"ca. 200 photographs\" .\n\n<ontology://generated-from-draw-io/mock#O%27Rourke> a owl:NamedIndividual,\n        rico:Person ;\n    rdfs:label \"O'Rourke\" .\n\n<ontology://generated-from-draw-io/mock#Ontario.%20Dept.%20Of%20Health> a owl:NamedIndividual,\n        rico:CorporateBody ;\n    rdfs:label \"Ontario. Dept. of Health\" .\n\n<ontology://generated-from-draw-io/mock#RG%2010-145> a owl:NamedIndividual,\n        rico:Identifier ;\n    rdfs:label \"RG 10-145\" ;\n    rico:hasIdentifierType <ontology://generated-from-draw-io/mock#Current%20Reference%20Code> .\n\n<ontology://generated-from-draw-io/mock#Series> a owl:NamedIndividual,\n        rico:RecordSetType ;\n    rdfs:label \"Series\" .\n\n<ontology://generated-from-draw-io/mock#Status%3A%20Approved> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Status: Approved\" .\n\n<ontology://generated-from-draw-io/mock#Web%20Enabled%3A%20Y> a owl:NamedIndividual,\n        rico:RecordState ;\n    rdfs:label \"Web Enabled: Y\" .\n\n", format="turtle")
