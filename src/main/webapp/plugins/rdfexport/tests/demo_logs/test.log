    actual_data = "@base <ontology://generated-from-draw-io/mock#> .\n@prefix : <ontology://generated-from-draw-io/mock#> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n\n<ontology://generated-from-draw-io/mock> a owl:Ontology ;\n    owl:imports rico: .\n\n<ontology://generated-from-draw-io/mock#Closing%20Of%20Walkerton%20Inquiry> a owl:NamedIndividual,\n        rico:Event ;\n    rdfs:label \"Closing of Walkerton Inquiry\" ;\n    rico:occurredAtDate <ontology://generated-from-draw-io/mock#May%2023%2C%202002> .\n\n<ontology://generated-from-draw-io/mock#Establishment%20Of%20Walkerton%20Inquiry> a owl:NamedIndividual,\n        rico:Event ;\n    rdfs:label \"Establishment of Walkerton Inquiry\" ;\n    rico:occurredAtDate <ontology://generated-from-draw-io/mock#June%2013%2C%202000> .\n\n<ontology://generated-from-draw-io/mock#Records%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210%29> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Records of the Walkerton Inquiry (RG 18-210)\" ;\n    rico:hasCreator <ontology://generated-from-draw-io/mock#Walkerton%20Inquiry%20%28BA619%29> ;\n    rico:hasOrHadHolder <ontology://generated-from-draw-io/mock#Archives%20Of%20Ontario%20%28ON00009%29> ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Series> ;\n    rico:includesOrIncluded <ontology://generated-from-draw-io/mock#Administrative%20Files%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-10%29>,\n        <ontology://generated-from-draw-io/mock#Agendas%2C%20Submissions%20And%20Transcripts%20For%20The%20Public%20And%20Town%20Hall%20Meetings%20Of%20Part%20Two%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-6%29>,\n        <ontology://generated-from-draw-io/mock#Commissioned%20Issue%20Papers%20Prepared%20For%20Part%20Two%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-7%29>,\n        <ontology://generated-from-draw-io/mock#Exhibits%20For%20Part%20One%20Hearings%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-3%29>,\n        <ontology://generated-from-draw-io/mock#Files%20Relating%20To%20Participants%20In%20Part%20Two%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-8%29>,\n        <ontology://generated-from-draw-io/mock#General%20Submissions%20To%20The%20Walkerton%20Inquiry%20%28RG%2018-210-5%29>,\n        <ontology://generated-from-draw-io/mock#Incoming%20Correspondence%20Files%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-11%29>,\n        <ontology://generated-from-draw-io/mock#Reference%20Database%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-2%29>,\n        <ontology://generated-from-draw-io/mock#Search%20Warrants%20For%20The%20Walkerton%20Inquiry%20%28RG%2018-210-12%29>,\n        <ontology://generated-from-draw-io/mock#Subject%20Files%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-9%29>,\n        <ontology://generated-from-draw-io/mock#Transcripts%20Of%20Part%20One%20Hearings%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-4%29>,\n        <ontology://generated-from-draw-io/mock#Website%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-1%29> ;\n    rico:isAssociatedWithEvent <ontology://generated-from-draw-io/mock#Walkerton%20E.%20Coli%20Outbreak> ;\n    rico:isAssociatedWithPlace <ontology://generated-from-draw-io/mock#Walkerton%2C%20Ontario> ;\n    rico:scopeAndContent \"Series consists of records generated during the course of the Walkerton Inquiry into the tainted water tragedy that occurred in Walkerton, Ontario in May 2000. At that time Walkerton’s   drinking water system became contaminated with deadly bacteria, primarily Escherichia coli O157:H7.1 Seven people died, and more than 2,300 became ill.     The Ontario government called the Inquiry to investigate what actually happened in Walkerton. The mandate of the Inquiry was to determine the causes of the E-coli outbreak, find out who was responsible, and to investigate if it could have been prevented.     Commissioner O'Connor divided the Inquiry into two Parts. The purpose of Part One was to fulfil the mandate of discovering what had happened in Walkerton, and why, and to make recommendations based on those findings. Part One involved a great deal of fact finding and included evidentiary hearings. Part Two of the Inquiry was broader in scope and dealt with policy issues related to safe drinking water. The primary purpose of Part Two was to make recommendations regarding Ontario's drinking water system.     The records in this series have been arranged into sub-series that broadly reflect Parts One and Two of the Inquiry, and also include general administrative records created by the Inquiry's   staff. Included in the sub-series are records connected with the hearings and meetings held by the Inquiry, commissioned research reports, correspondence, the reference database of   documents used by the Inquiry and the Inquiry's website.\" .\n\n<ontology://generated-from-draw-io/mock#Acts%20%2F%20Studies%20%28RG%2018-210-9-1%29> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Acts / Studies  (RG 18-210-9-1)\" ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#File> .\n\n<ontology://generated-from-draw-io/mock#Administrative%20Files%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-10%29> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Administrative files of the Walkerton Inquiry   (RG 18-210-10)\" ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Sub-series> .\n\n<ontology://generated-from-draw-io/mock#Adverse%20Water%20Incidence%20Reports%20%28RG%2018-210-9-2%29> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Adverse Water incidence reports   (RG 18-210-9-2)\" ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#File> .\n\n<ontology://generated-from-draw-io/mock#Agendas%2C%20Submissions%20And%20Transcripts%20For%20The%20Public%20And%20Town%20Hall%20Meetings%20Of%20Part%20Two%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-6%29> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Agendas, submissions and transcripts for the public and town hall meetings   of Part Two of the Walkerton Inquiry (RG 18-210-6)\" ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Sub-series> .\n\n<ontology://generated-from-draw-io/mock#Archives%20Of%20Ontario%20%28ON00009%29> a owl:NamedIndividual,\n        rico:AgentName,\n        rico:CorporateBody ;\n    rdfs:label \"Archives of Ontario (ON00009)\" .\n\n<ontology://generated-from-draw-io/mock#Bytes> a owl:NamedIndividual,\n        rico:UnitOfMeasurement ;\n    rdfs:label \"Bytes\" .\n\n<ontology://generated-from-draw-io/mock#Commissioned%20Issue%20Papers%20Prepared%20For%20Part%20Two%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-7%29> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Commissioned issue papers prepared for Part Two of the Walkerton Inquiry   (RG 18-210-7)\" ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Sub-series> .\n\n<ontology://generated-from-draw-io/mock#Dennis%20R.%20O%27Connor> a owl:NamedIndividual,\n        rico:AgentName,\n        rico:Person ;\n    rdfs:label \"Dennis R. O'Connor\" ;\n    rico:authorizedBy <ontology://generated-from-draw-io/mock#Order%20In%20Council%201170%2F2000> ;\n    rico:occupiesOrOccupied <ontology://generated-from-draw-io/mock#Commissioner> .\n\n<ontology://generated-from-draw-io/mock#Exhibits%20For%20Part%20One%20Hearings%20Of%20The%20Walkerton%20Inquiry%20%28RG%2018-210-3%29> a owl:NamedIndividual,\n        rico:RecordSet ;\n    rdfs:label \"Exhibits for Part One hearings of the Walkerton Inquiry   (RG 18-210-3)\" ;\n    rico:hasRecordSetType <ontology://generated-from-draw-io/mock#Sub-series> .\n\n<ontology://generated-from-draw-io/mock#File%20Size> a owl:NamedIndividual,\n        rico:ExtentType ;\n    rdfs: