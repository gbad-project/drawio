{
  "name": "rdfexport",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "dependencies": {
    "pyodide": "^0.28.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/bun": "latest",
    "@xmldom/xmldom": "^0.8.11",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "volta": {
    "node": "22.19.0"
  },
  "scripts": {
    "uv": "command -v uv >/dev/null 2>&1 || (curl -LsSf https://astral.sh/uv/install.sh | sh && source $HOME/.local/bin/env); uv sync",
    "build": "bun build --outfile=dist/rdfexport.js src/rdfexport.ts && cp dist/rdfexport.js ..",
    "test": "bash scripts/test_legacy.sh && bun --check test",
    "format": "ruff format . && prettier --write .",
    "format:check": "ruff format --check . && prettier --check .",
    "lint": "ruff check . && eslint .",
    "lint:fix": "ruff check --fix . && eslint --fix .",
    "check": "bun run lint && bun run format:check",
    "fix": "bun run lint:fix && bun run format",
    "serve": "cd ../../../../.. && python -m http.server 8000"
  }
}
