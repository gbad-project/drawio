{
  "name": "rdfexport",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "dependencies": {
    "pyodide": "^0.28.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/bun": "latest",
    "@xmldom/xmldom": "^0.8.11",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "volta": {
    "node": "22.19.0"
  },
  "scripts": {
    "setup:uv": "command -v uv >/dev/null 2>&1 || (curl -LsSf https://astral.sh/uv/install.sh | sh && source $HOME/.local/bin/env); uv sync",
    "setup:pyodide": "bash scripts/download_pyodide_assets.sh",
    "setup": "bun install; bun run setup:uv; bun run setup:pyodide",
    "build": "bun run build.ts && cp dist/rdfexport.js ..",
    "test": "bash scripts/test_legacy.sh; bun --check test",
    "test:log:macos": "LOGFILE=\"tests/demo_logs/test.log\" && script \"$LOGFILE\" bun run test",
    "test:log:linux": "LOGFILE=\"tests/demo_logs/test.log\" && script -c \"bun run test\" \"$LOGFILE\"",
    "test:log:show": "LOGFILE=\"tests/demo_logs/test.log\" && cat \"$LOGFILE\"",
    "format:py": "ruff format .",
    "format:ts": "prettier --write .",
    "format": "bun run format:py; bun run format:ts",
    "format:check:py": "ruff format --check .",
    "format:check:ts": "prettier --check .",
    "format:check": "bun run format:check:py; bun run format:check:ts",
    "lint:py": "ruff check .",
    "lint:ts": "eslint .",
    "lint": "bun run lint:py; bun run lint:ts",
    "lint:fix:py": "ruff check --fix .",
    "lint:fix:ts": "eslint --fix .",
    "lint:fix": "bun run lint:fix:py; bun run lint:fix:ts",
    "check": "bun run lint && bun run format:check",
    "fix": "bun run lint:fix && bun run format",
    "serve": "cd ../../../../.. && python -m http.server 8000"
  }
}
