@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<https://data.archives.gov.on.test.gbad.ca/Schema/Mapping/triples-map/general-add> a rr:TriplesMap ;
    rml:logicalSource [ rml:referenceFormulation ql:CSV ;
            rml:source "gbad/mapping/source/preprocessed/General ADD (Descriptions and Listings) to RiC-O Model_2025-06-20_PZ.csv" ] ;
    rr:predicateObjectMap [ rr:objectMap [ rml:reference "SCOPE" ] ;
            rr:predicate rico:scopeAndContent ],
        [ rr:objectMap [ rml:reference "REFD" ] ;
            rr:predicate rico:identifier ],
        [ rr:objectMap [ rml:reference "TITLE" ] ;
            rr:predicate rdfs:label ],
        [ rr:objectMap [ rml:reference "DATECR" ] ;
            rr:predicate rico:creationDate ] ;
    rr:subjectMap [ rr:class rico:RecordSet ;
            rr:template "https://data.archives.gov.on.test.gbad.ca/Schema/Mapping/record-set/{SISN}" ;
            rr:termType rr:IRI ] .

