rdfs:label a owl:DatatypeProperty .

rdfs:subPropertyOf a owl:ObjectProperty .

<https://data.archives.gov.on.test.gbad.ca/%2FKB%2FCreationRelation%2F%7BREFD_FILE%7D%2F%7BOFFICEABC%7D%2Furn%3Auuid%3A%7BUUID%7D> a owl:NamedIndividual,
        rico:CreationRelation ;
    rdfs:label "{TITLE} - {OFFICEABC} (Creation Relation). Context:" ;
    rico:date "{DATEOFF}" ;
    rico:hasBeginningDate <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FDate%2F%7BDATEOFF_BEGINNING%7D> ;
    rico:hasEndDate <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FDate%2F%7BDATEOFF_END%7D> ;
    rico:relationHasSource <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FRecordSet%2F%7BREFD_FILE%7D> ;
    rico:relationHasTarget <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FAgent%2F%7BABC_REFA%7D> .

