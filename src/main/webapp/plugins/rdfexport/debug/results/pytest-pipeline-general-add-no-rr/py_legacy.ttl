<https://data.archives.gov.on.test.gbad.ca/%2FKB%2FRecordSet%2F%7BREFD_FILE%7D> a owl:NamedIndividual,
        rico:RecordSet ;
    rdfs:label "{REFD_FILE} - {TITLE} (Record Set)" ;
    add:accumulationDate "{DATEACM}" ;
    add:associatedMaterial "{ASSMAT}" ;
    add:availabilityOfOtherFormats "{AVAIL}" ;
    add:custodialHistory "{CUSTOD}" ;
    add:findingAidNote "{FINDAID}" ;
    add:immediateSourceOfAcquisition "{ISA}" ;
    add:notes "{NOTES}" ;
    add:privateNote "{CMTD}",
        "{HIDDENNOTES}" ;
    add:relatedMaterial "{RELMAT}" ;
    rico:accruals "{ACCRUAL}" ;
    rico:conditionsOfAccess "{RESTRTX}",
        "{REST}" ;
    rico:conditionsOfUse "{TGU}" ;
    rico:creationDate "{DATECR}" ;
    rico:hasContentOfType <https://data.archives.gov.on.test.gbad.ca/%2FSchema%2FDescription-Listings%2FContentType%23%7BGMD%7D> ;
    rico:hasCreator <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FAgent%2F%7BINDEXNAME%7D>,
        <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FAgent%2F%7BINDEXPROV%7D> ;
    rico:hasOrHadIdentifier <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FCurrentReferenceCode%2F%7BREFD_FILE%7D>,
        <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FFormerCode%2F%7BFCODES%7D> ;
    rico:hasOrHadInstantiation <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FInstantiation%2F%7BREFD_FILE%7D%2Furn%3Auuid%3A%7BUUID%7D> ;
    rico:hasOrHadSubject <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FAgent%2F%7BINDEXSUB%7D> ;
    rico:hasOrHadTitle <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FTitle%2F%7BTITLE%7D> ;
    rico:hasRecordSetType <https://data.archives.gov.on.test.gbad.ca/%2FSchema%2FDescription-Listings%2FLevel%23%7BLEVELDES%7D> ;
    rico:history "{ADMBIO}" ;
    rico:isAssociatedWithPlace <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FPlace%2F%7BINDEXGEO%7D> ;
    rico:isDirectlyIncludedIn <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FRecordSet%2F%7BREFD_HIGHER%7D>,
        <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FRecordSet%2F%7BREF_ADD%7D> ;
    rico:isOrWasDescribedBy <https://data.archives.gov.on.test.gbad.ca/%2FKB%2FArchivalDescriptionRecord%2F%7BREFD_FILE%7D> ;
    rico:scopeAndContent "{SCOPE}" .

