        [ rr:objectMap [ rr:template "{REFD_FILE} - {TITLE} (Instantiation). Context:" ;
                    rr:termType rr:Literal ] ;
            rr:predicate rdfs:label ] ;
    rr:subjectMap [ rr:constant "https://data.archives.gov.on.test.gbad.ca/%2FKB%2FInstantiation%2F%7BREFD_FILE%7D%2Furn%3Auuid%3A%7BUUID%7D" ;
            rr:predicateObjectMap [ rr:objectMap [ rr:constant "https://www.ica.org/standards/RiC/ontology#Instantiation" ] ;
                    rr:predicate rdf:type ],
