                    rr:termType rr:Literal ] ;
            rr:predicate rico:conditionsOfAccess ],
        [ rr:objectMap [ rr:template "{ISA}" ;
                    rr:termType rr:Literal ] ;
            rr:predicate add:immediateSourceOfAcquisition ],
        [ rr:objectMap [ rr:template "{CMTD}" ;
                    rr:termType rr:Literal ] ;
            rr:predicate add:privateNote ],
        [ rr:objectMap [ rr:template "/KB/RecordSet/{REFD_HIGHER}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:isDirectlyIncludedIn ],
        [ rr:objectMap [ rr:template "{FINDAID}" ;
                    rr:termType rr:Literal ] ;
            rr:predicate add:findingAidNote ],
        [ rr:objectMap [ rr:template "/KB/RecordSet/{REF_ADD}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:isDirectlyIncludedIn ],
        [ rr:objectMap [ rr:template "{ADMBIO}" ;
                    rr:termType rr:Literal ] ;
            rr:predicate rico:history ],
        [ rr:objectMap [ rr:template "{NOTES}" ;
                    rr:termType rr:Literal ] ;
            rr:predicate add:notes ],
        [ rr:objectMap [ rr:template "{TGU}" ;
                    rr:termType rr:Literal ] ;
            rr:predicate rico:conditionsOfUse ],
        [ rr:objectMap [ rr:template "/KB/Agent/{INDEXSUB}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasOrHadSubject ] ;
    rr:subjectMap [ rr:predicateObjectMap [ rr:objectMap [ rr:constant "http://www.w3.org/2002/07/owl#NamedIndividual" ] ;
                    rr:predicate rdf:type ],
                [ rr:objectMap [ rr:constant "https://www.ica.org/standards/RiC/ontology#RecordSet" ] ;
                    rr:predicate rdf:type ] ;
            rr:template "/KB/RecordSet/{REFD_FILE}" ;
            rr:termType rr:IRI ] .

