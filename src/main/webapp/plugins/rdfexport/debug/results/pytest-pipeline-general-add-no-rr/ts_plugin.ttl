@prefix add: <https://data.archives.gov.on.test.gbad.ca/Schema/Description-Listings/> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

[] a rr:TriplesMap ;
    rml:logicalSource [ rml:referenceFormulation ql:CSV ;
            rml:source "gbad/mapping/source/preprocessed/General ADD (Descriptions and Listings) to RiC-O Model_2025-06-20_PZ.csv" ] ;
    rr:subjectMap [ rr:predicateObjectMap [ rr:objectMap [ rr:constant "https://www.ica.org/standards/RiC/ontology#Agent" ] ;
                    rr:predicate rdf:type ],
                [ rr:objectMap [ rr:constant "http://www.w3.org/2002/07/owl#NamedIndividual" ] ;
                    rr:predicate rdf:type ] ;
            rr:template "/KB/Agent/{INDEXPROV}" ;
            rr:termType rr:IRI ] .

[] a rr:TriplesMap ;
    rml:logicalSource [ rml:referenceFormulation ql:CSV ;
            rml:source "gbad/mapping/source/preprocessed/General ADD (Descriptions and Listings) to RiC-O Model_2025-06-20_PZ.csv" ] ;
    rr:predicateObjectMap [ rr:objectMap [ rr:template "/Schema/Description-Listings/WebEnabled#{WEBD}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasRecordState ],
        [ rr:objectMap [ rr:template "/Schema/Description-Listings/Status#{STATUSD}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasRecordState ],
        [ rr:objectMap [ rr:template "{REFD_FILE} - {TITLE} (Archival Description Record)" ;
                    rr:termType rr:Literal ] ;
            rr:predicate rdfs:label ],
        [ rr:objectMap [ rr:constant "/Schema/Description-Listings/ArchivalDescriptionRecord" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasDocumentaryFormType ],
        [ rr:objectMap [ rr:template "/KB/Date/{MODDATE}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:wasLastUpdatedAtDate ],
        [ rr:objectMap [ rr:template "/Schema/Description-Listings/WebEnabled#{WEBL}" ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasRecordState ] ;
    rr:subjectMap [ rr:predicateObjectMap [ rr:objectMap [ rr:constant "http://www.w3.org/2002/07/owl#NamedIndividual" ] ;
                    rr:predicate rdf:type ],
                [ rr:objectMap [ rr:constant "https://www.ica.org/standards/RiC/ontology#Record" ] ;
                    rr:predicate rdf:type ] ;
            rr:template "/KB/ArchivalDescriptionRecord/{REFD_FILE}" ;
            rr:termType rr:IRI ] .

