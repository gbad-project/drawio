[] a rr:TriplesMap ;
    rml:logicalSource [ rml:referenceFormulation ql:CSV ;
            rml:source "gbad/mapping/source/preprocessed/General Authority to RiC-O Model_2025-06-25_PZ.csv" ] ;
    rr:predicateObjectMap [ rr:objectMap [ rr:constant "REFA" ;
                    rr:termType rr:Literal ] ;
            rr:predicate rico:normalizedValue ],
        [ rr:objectMap [ rr:constant <https://data.archives.gov.on.test.gbad.ca/Schema/Mapping#%2FSchema%2FAuthority%2FAgencyReferenceCode> ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:hasIdentifierType ] ;
    rr:subjectMap [ rr:class rico:Identifier ;
            rr:constant :Rr%3Atemplate%20%22%252FKB%252FAgencyReferenceCode%252F%257BREFA%257D%22 ;
            rr:termType rr:IRI ] .

