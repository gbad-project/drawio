    rico:followsInTime :Arkivverket .

:Knut%20Olborgs%20Forskingsnotater a owl:NamedIndividual,
        rico:RecordSet ;
    rdfs:label "Knut Olborgs Forskingsnotater" ;
    rico:hasBeginningDate :Knut%20Olborgs%20Forskningsnotater%20Start ;
    rico:hasCreator :Knut%20Olborg ;
    rico:hasEndDate :Knut%20Olborgs%20Forskningsnotater%20Slutt ;
    rico:hasOrHadDigitalInstantiation :Knut%20Olborgs%20Forskningsnotater%20Storage%20Instantiation ;
    rico:hasOrHadHolder :Arkivverket ;
    rico:hasOrganicOrFunctionalProvenance :Mappestruktur ;
    rico:hasSender :Knut%20Olborg ;
    rico:isAssociatedWithEvent :Okkupasjonstiden ;
    rico:isAssociatedWithPlace :Norge ;
    rico:isOrWasUnderAuthorityOf :Arkivverket ;
    rico:isRecordResourceAssociatedWithRecordResource :Deutscher%20Oberbefehlshaber%20Norwegen%20Samling ;
    rico:scopeAndContent "Forskerarkiv. Samling av forsker Knut Olborgs notater fra kildegransking av arkivet RAFA-2197 Deutscher Oberbefehlshaber Norwegen (DOBN). Knut Olborg har gått systematisk gjennom det, eske for eske, og tatt notater.     Notatene kan være til nytte for andre forskere og studenter som skal arbeidet med dette tyskspråklige og vanskelig tilgjengelige arkivmaterialet. Arkivverket tok imot de digitale filene i 2022. Materialet er elektronisk og består av 105 word-filer (pdf'er)." .

