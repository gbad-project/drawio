@prefix ex: <http://example/schema#> .
@prefix kb: <mock://debug-knowledge-base/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .

ex:No a owl:DatatypeProperty .

ex:Yes a owl:DatatypeProperty,
        owl:ObjectProperty .

kb:Lampdoesntwork a owl:NamedIndividual ;
    rdfs:label "kb:Lampdoesntwork" .

kb:Lamppluggedin a owl:NamedIndividual ;
    rdfs:label "kb:Lamppluggedin" ;
    ex:No "Plug in lamp" ;
    ex:Yes kb:Bulbburnedout .

<mock://debug-ontology> a owl:Ontology ;
    owl:imports rico: .

kb:Bulbburnedout a owl:NamedIndividual ;
    rdfs:label "kb:Bulbburnedout" ;
    ex:No "Repair Lamp" ;
    ex:Yes "Replace Bulb" .

