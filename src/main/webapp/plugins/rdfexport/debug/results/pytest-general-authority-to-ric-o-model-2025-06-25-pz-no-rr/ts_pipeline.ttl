@prefix auth: <https://data.archives.gov.on.test.gbad.ca/Schema/Authority/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .

rdfs:label a owl:DatatypeProperty .

auth:functionNote a owl:DatatypeProperty .

auth:privateNote a owl:DatatypeProperty .

auth:sourceNote a owl:DatatypeProperty .

<mock://pytest-debug-ontology> a owl:Ontology ;
    owl:imports rico: .

<ontology://generated-from-draw-io/mock#%2FKB%2FRule%2FRulesForArchivalDescription> a owl:NamedIndividual,
        rico:Rule ;
    rdfs:label "/KB/Rule/RulesForArchivalDescription",
        "Rules for Archival Description" ;
    rico:title "{RULES}" .

<ontology://generated-from-draw-io/mock#%2FSchema%2FAuthority%2FAgencyReferenceCode> a owl:NamedIndividual,
        rico:IdentifierType ;
    rdfs:label "/Schema/Authority/AgencyReferenceCode" .

<ontology://generated-from-draw-io/mock#%2FSchema%2FAuthority%2FAuthorityRecord> a owl:NamedIndividual,
        rico:DocumentaryFormType ;
    rdfs:label "/Schema/Authority/AuthorityRecord" .

<ontology://generated-from-draw-io/mock#%2FSchema%2FAuthority%2FNaturalAgentName> a owl:NamedIndividual,
        rico:Type ;
    rdfs:label "/Schema/Authority/NaturalAgentName" .

<ontology://generated-from-draw-io/mock#%2FSchema%2FAuthority%2FParallelAgentName> a owl:NamedIndividual,
        rico:Type ;
    rdfs:label "/Schema/Authority/ParallelAgentName" .

<ontology://generated-from-draw-io/mock#%2FSchema%2FAuthority%2FVariantAgentName> a owl:NamedIndividual,
        rico:Type ;
    rdfs:label "/Schema/Authority/VariantAgentName" .

