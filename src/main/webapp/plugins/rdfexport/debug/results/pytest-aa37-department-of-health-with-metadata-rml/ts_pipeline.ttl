        [ rr:objectMap [ rr:constant :Rules%20For%20Archival%20Description ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:isOrWasRegulatedBy ],
        [ rr:objectMap [ rr:constant "Source Note: MacTaggart, Hazel I.  Publications of the Government of Ontario, 1901-1955 (1964). Publications of the Government of Ontario, 1956-1971 (1975). Canadiana Name Authorities, 1996-12-24" ;
                    rr:termType rr:Literal ] ;
            rr:predicate rico:generalDescription ],
        [ rr:objectMap [ rr:constant :Authority%20Record%20Creation ;
                    rr:termType rr:IRI ] ;
            rr:predicate rico:resultsOrResultedFrom ] ;
    rr:subjectMap [ rr:class rico:Record ;
            rr:constant :Ontario.%20Dept.%20Of%20Health%20Authority%20Record ;
