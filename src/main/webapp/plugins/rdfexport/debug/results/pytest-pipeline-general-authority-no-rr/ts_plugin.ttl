    rr:subjectMap [ rr:constant "https://data.archives.gov.on.test.gbad.ca/%2FKB%2FAgentControlRelation%2F%7BCONTAG%7D%2F%7BHEADING%7D%2Furn%3Auuid%3A%7BUUID%7D" ;
