        rico:Title ;
    rdfs:label "Mobile Tuberculosis Testing Clinic photographs" ;
    rico:conditionsOfAccess "No restrictions on access." ;
    rico:conditionsOfUse "Crown copyright exists in these photographs. Permission to publish is required from the Archives of Ontario. Submit a Request for Permission to Publish, Exhibit or Broadcast form." ;
