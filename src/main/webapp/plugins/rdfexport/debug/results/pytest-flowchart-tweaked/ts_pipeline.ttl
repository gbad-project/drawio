@prefix kb: <mock://knowledge-base/> .
@prefix ns1: <http://example/schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .

ns1:No a owl:DatatypeProperty .

ns1:Yes a owl:DatatypeProperty,
        owl:ObjectProperty .

kb:Lampdoesntwork a owl:NamedIndividual ;
    rdfs:label "kb:Lampdoesntwork" .

kb:Lamppluggedin a owl:NamedIndividual ;
    rdfs:label "kb:Lamppluggedin" ;
    ns1:No "Plug in lamp" ;
    ns1:Yes kb:Bulbburnedout .

<mock://pytest-debug-ontology> a owl:Ontology ;
    owl:imports rico: .

kb:Bulbburnedout a owl:NamedIndividual ;
    rdfs:label "kb:Bulbburnedout" ;
    ns1:No "Repair Lamp" ;
    ns1:Yes "Replace Bulb" .

